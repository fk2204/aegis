# AEGIS Python — environment template.
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# Boot guard: the app refuses to start unless AEGIS_DATA_RESIDENCY_CONFIRMED=true
# and BEDROCK_MODEL_ID begins with "us." (regional inference profile).

# === Data residency (boot guard) ===
AEGIS_DATA_RESIDENCY_CONFIRMED=false

# === AWS Bedrock (Claude) ===
# Use a regional inference profile. Bank statements must not transit non-US regions.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6

# === Supabase ===
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# === Migrations + verification DSN (operator-zero-touch tooling) ===
# Direct Postgres URI used by scripts/apply_migrations.py AND
# scripts/db_verify.py. Get from Supabase dashboard ->
# Settings -> Database -> Connection string -> URI. Pick the Transaction
# pooler (port 6543). NOT the same as the REST service key —
# this is a raw `postgresql://` URI.
#
# Per-env variables let dev/staging/prod stay separate; --target prod is
# required to connect to a URI containing the prod project ref.
#
# Put these in .env.local (gitignored), not .env.
MIGRATIONS_DB_URL_DEV=
MIGRATIONS_DB_URL_STAGING=
MIGRATIONS_DB_URL_PROD=

# === Close CRM ===
# HTTP Basic auth: the API key is sent as the username, password blank.
CLOSE_API_KEY=
CLOSE_API_BASE=https://api.close.com
# Webhook secret (hex-encoded). Returned by Close in the subscription
# POST response as `signature_key`. Used for HMAC-SHA256 verification
# on /webhooks/close. NOT created until after deploy + subscription
# creation in the Close dashboard — leave blank for local dev.
CLOSE_WEBHOOK_SECRET=
# Opportunity status id that triggers AEGIS underwriting (Sales
# pipeline → "Docs In — Pre-UW"). Default is the verified value as of
# 2026-05-20 — override only if the status was renamed/replaced.
CLOSE_DOCS_IN_PRE_UW_STATUS_ID=stat_1YZuVqdPWC8HLjWWvnXqL3NBJUPSjw3upy9mdBYXRqI

# === API auth ===
# Bearer token for all API endpoints except /healthz. Constant-time compared.
API_BEARER_TOKEN=

# === Redis (arq job queue) ===
REDIS_URL=redis://localhost:6379

# === App ===
APP_PORT=5555
LOG_LEVEL=INFO
