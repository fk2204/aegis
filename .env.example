# AEGIS Python — environment template.
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# Boot guard: the app refuses to start unless AEGIS_DATA_RESIDENCY_CONFIRMED=true
# and BEDROCK_MODEL_ID begins with "us." (regional inference profile).

# === Data residency (boot guard) ===
AEGIS_DATA_RESIDENCY_CONFIRMED=false

# === AWS Bedrock (Claude) ===
# Use a regional inference profile. Bank statements must not transit non-US regions.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6

# === Supabase ===
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# === Migrations + verification DSN (operator-zero-touch tooling) ===
# Direct Postgres URI used by scripts/db_verify.py (and, once it ships, the
# 3C-extra migration runner). Get it from Supabase dashboard →
# Settings → Database → Connection string → URI. NOT the same as the REST
# service key — this is a raw `postgresql://` URI.
#
# Per-env variables let dev/staging/prod stay separate; --target prod is
# required to connect to a URI containing the prod project ref.
#
# Put these in .env.local (gitignored), not .env.
MIGRATIONS_DB_URL_DEV=
MIGRATIONS_DB_URL_STAGING=
MIGRATIONS_DB_URL_PROD=

# === Zoho CRM ===
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ACCOUNTS_BASE=https://accounts.zoho.com
ZOHO_API_BASE=https://www.zohoapis.com
ZOHO_WEBHOOK_SECRET=

# === API auth ===
# Bearer token for all API endpoints except /healthz. Constant-time compared.
API_BEARER_TOKEN=

# === Redis (arq job queue) ===
REDIS_URL=redis://localhost:6379

# === App ===
APP_PORT=5555
LOG_LEVEL=INFO
