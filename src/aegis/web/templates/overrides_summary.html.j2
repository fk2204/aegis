{% extends "base.html.j2" %}
{% set active = 'Admin' %}
{% block title %}AEGIS — Operator Overrides Summary{% endblock %}

{% block deck %}
<header class="deck">
  <h1>Operator overrides<em> · confusion matrix per reason code</em></h1>
  <div class="meta">
    {{ total_overrides }} override{{ '' if total_overrides == 1 else 's' }} captured across {{ summary_rows|length }} reason{{ '' if summary_rows|length == 1 else 's' }}
  </div>
</header>
{% endblock %}

{% block body %}
<section class="body">

  {# Override flywheel stats — INT 4 / migration 098. Counts overrides
     that have at least one linked deal_outcomes row, with the funded
     and declined percentages of THAT linked subset. Empty-state when
     no outcomes have been linked yet (day-zero post-migration). #}
  {% if flywheel %}
  <div class="flywheel-stats" data-test-id="flywheel-summary"
       style="display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:20px;font-size:13px">
    <div class="stat-cell" style="padding:10px 12px;border:1px solid var(--rule,#d8d8d4);border-radius:4px;background:var(--ink-bg,#fafaf7)">
      <div style="font-size:11px;color:var(--ink-2,#666);text-transform:uppercase;letter-spacing:0.06em">Total overrides</div>
      <div style="font-size:18px;font-weight:600;margin-top:2px">{{ flywheel.total }}</div>
    </div>
    <div class="stat-cell" data-test-id="flywheel-linked"
         style="padding:10px 12px;border:1px solid var(--rule,#d8d8d4);border-radius:4px;background:var(--ink-bg,#fafaf7)">
      <div style="font-size:11px;color:var(--ink-2,#666);text-transform:uppercase;letter-spacing:0.06em">With outcomes</div>
      <div style="font-size:18px;font-weight:600;margin-top:2px">{{ flywheel.with_outcomes }}</div>
    </div>
    <div class="stat-cell" data-test-id="override-accuracy"
         style="padding:10px 12px;border:1px solid var(--rule,#d8d8d4);border-radius:4px;background:var(--ink-bg,#fafaf7)">
      <div style="font-size:11px;color:var(--ink-2,#666);text-transform:uppercase;letter-spacing:0.06em">Funded after override</div>
      <div style="font-size:18px;font-weight:600;margin-top:2px;{% if flywheel.funded_pct > 50 %}color:#2d7a2d{% endif %}">{{ flywheel.funded_pct }}%</div>
    </div>
    <div class="stat-cell" style="padding:10px 12px;border:1px solid var(--rule,#d8d8d4);border-radius:4px;background:var(--ink-bg,#fafaf7)">
      <div style="font-size:11px;color:var(--ink-2,#666);text-transform:uppercase;letter-spacing:0.06em">Declined after override</div>
      <div style="font-size:18px;font-weight:600;margin-top:2px;{% if flywheel.declined_pct > 50 %}color:#c75252{% endif %}">{{ flywheel.declined_pct }}%</div>
    </div>
  </div>
  {% endif %}

  {% if summary_rows %}
  <table class="data" data-test-id="overrides-summary">
    <thead>
      <tr>
        <th>Reason code</th>
        <th>Count</th>
        {% for col in outcome_columns %}
          <th>{{ col|replace('_', ' ') }}</th>
        {% endfor %}
      </tr>
    </thead>
    <tbody>
      {% for row in summary_rows %}
      <tr data-reason-code="{{ row.reason_code }}">
        <td><code>{{ row.reason_code }}</code></td>
        <td><strong>{{ row.total }}</strong></td>
        {% for col in outcome_columns %}
          <td data-outcome="{{ col }}">{{ row.counts.get(col, 0) }}</td>
        {% endfor %}
      </tr>
      {% endfor %}
    </tbody>
  </table>
  <p class="muted small" style="margin-top:14px">
    The <strong>pending</strong> column counts overrides whose outcome
    has not yet been stamped (no funder reply ingested for the deal yet).
    Funder reply ingestion stamps outcomes via
    <code>funder_replies</code>; this view reads only
    <code>overrides.outcome</code>.
  </p>
  {% else %}
  <p class="muted">No operator overrides captured yet. Click <em>Override recommendation</em> from any merchant dossier.</p>
  {% endif %}
</section>
{% endblock %}
