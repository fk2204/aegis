{% extends "base.html.j2" %}
{% set active = 'Admin' %}
{% block title %}AEGIS — Operator Overrides Summary{% endblock %}

{% block deck %}
<header class="deck">
  <h1>Operator overrides<em> · confusion matrix per reason code</em></h1>
  <div class="meta">
    {{ total_overrides }} override{{ '' if total_overrides == 1 else 's' }} captured across {{ summary_rows|length }} reason{{ '' if summary_rows|length == 1 else 's' }}
  </div>
</header>
{% endblock %}

{% block body %}
<section class="body">
  {% if summary_rows %}
  <table class="data" data-test-id="overrides-summary">
    <thead>
      <tr>
        <th>Reason code</th>
        <th>Count</th>
        {% for col in outcome_columns %}
          <th>{{ col|replace('_', ' ') }}</th>
        {% endfor %}
      </tr>
    </thead>
    <tbody>
      {% for row in summary_rows %}
      <tr data-reason-code="{{ row.reason_code }}">
        <td><code>{{ row.reason_code }}</code></td>
        <td><strong>{{ row.total }}</strong></td>
        {% for col in outcome_columns %}
          <td data-outcome="{{ col }}">{{ row.counts.get(col, 0) }}</td>
        {% endfor %}
      </tr>
      {% endfor %}
    </tbody>
  </table>
  <p class="muted small" style="margin-top:14px">
    The <strong>pending</strong> column counts overrides whose outcome
    has not yet been stamped (no funder reply ingested for the deal yet).
    Funder reply ingestion stamps outcomes via
    <code>funder_replies</code>; this view reads only
    <code>overrides.outcome</code>.
  </p>
  {% else %}
  <p class="muted">No operator overrides captured yet. Click <em>Override recommendation</em> from any merchant dossier.</p>
  {% endif %}
</section>
{% endblock %}
