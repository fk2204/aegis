{# Editable funder-note draft, swapped into #funder-note-draft-host after
   the operator clicks "Generate funder note". The form's Submit posts
   the (possibly edited) text to the durable submissions table; Discard
   throws the draft away (no DB write, audit row only). Both routes are
   operator-gated; the draft itself is NEVER auto-submitted (extraction-
   assists-not-replaces rule). #}
<div class="funder-note-draft-result"
     data-test-id="funder-note-draft-result"
     style="display:flex;flex-direction:column;gap:10px;padding:12px 14px;margin:0 0 14px;border:1px solid var(--ink, #233);border-radius:6px;background:rgba(45,90,71,0.02)">
  <div style="display:flex;align-items:baseline;gap:10px">
    <strong style="font-size:12px;color:#222">Draft for {{ funder_name }}</strong>
    <span style="font-size:11px;color:#666">{{ note_text|length }} characters · review and edit before submitting</span>
  </div>
  <form hx-post="/ui/merchants/{{ merchant_id }}/funder-note/submit"
        hx-target="#funder-note-draft-host"
        hx-swap="innerHTML"
        data-test-id="funder-note-draft-submit-form"
        style="display:flex;flex-direction:column;gap:8px;margin:0">
    <input type="hidden" name="funder_id" value="{{ funder_id }}">
    <textarea name="note_text"
              data-test-id="funder-note-draft-textarea"
              rows="10"
              style="width:100%;font-family:Menlo,Consolas,monospace;font-size:12px;padding:8px;border:1px solid #ccc;border-radius:4px;line-height:1.45">{{ note_text }}</textarea>
    <div style="display:flex;gap:10px">
      <button type="submit"
              class="btn btn-primary funder-note-draft-submit-btn"
              data-test-id="funder-note-draft-submit-btn">
        Submit to {{ funder_name }}
      </button>
      <button type="button"
              class="btn"
              hx-post="/ui/merchants/{{ merchant_id }}/funder-note/discard"
              hx-target="#funder-note-draft-host"
              hx-swap="innerHTML"
              hx-vals='{"funder_id": "{{ funder_id }}"}'
              data-test-id="funder-note-draft-discard-btn">
        Discard
      </button>
    </div>
  </form>
</div>
