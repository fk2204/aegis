{% extends "base.html.j2" %}
{% set active = 'Renewals' %}
{% block title %}Upcoming renewals — AEGIS{% endblock %}

{% block deck %}
{% set title = "Upcoming renewals" %}
{% set subtitle = "· operator visibility · " ~ window_days ~ "-day window" %}
{% set meta = (rows|length|string) ~ " merchant" ~ ('' if rows|length == 1 else 's') ~ " approaching maturity" %}
{% set actions = [
    {"label": "Merchants", "href": "/ui/merchants"},
    {"label": "Compliance", "href": "/ui/compliance/obligations"},
] %}
{% include "_page_header.html.j2" %}
{% endblock %}

{% block body %}
<section class="body cols-1">
  <div>
    <div class="empty" role="note" style="margin-bottom:1rem">
      <strong>Operator visibility only.</strong>
      <span class="copy">
        AEGIS surfaces upcoming maturities; the funder owns the
        regulatory disclosure obligation (CA SB 362 § 22806 — 60 days
        pre-maturity; NY 23 NYCRR § 600.17 — 30 days pre-maturity).
        Verify the funder has issued the required notice on each row,
        then capture an operator attestation here so the calendar
        reflects reality.
      </span>
    </div>

    {% if flash %}
      <div class="empty" role="status" style="margin-bottom:1rem">
        <strong>{{ flash }}</strong>
      </div>
    {% endif %}

    {# ============== Renewal pipeline (Feature 3 — 14-day) ============== #}
    <header class="sect-head" data-test-id="renewal-pipeline-header">
      <h2>Renewal pipeline · 14-day window</h2>
      <div class="rule"></div>
      <div class="meta">n = {{ pipeline_rows|length }} · operator queue</div>
    </header>
    <p class="copy" style="color:var(--ink-3);margin-bottom:12px;font-size:12px">
      Merchants whose <code>maturity_date</code> falls within 14 days (or
      is already past). Re-engage in order — overdue rows are surfaced
      with a negative <em>days</em> count so they don't get lost.
    </p>
    {% if not pipeline_rows %}
      <div class="empty" data-test-id="renewal-pipeline-empty">
        No merchants are within 14 days of maturity.
        <span class="copy">
          The pipeline reads <code>maturity_date</code>; merchants whose
          column is unset never appear here. The 90-day attestation
          calendar below shows the regulatory-disclosure horizon.
        </span>
      </div>
    {% else %}
      <table class="queue" data-test-id="renewal-pipeline-table">
        <thead>
          <tr>
            <th>Merchant</th>
            <th class="num">Days until maturity</th>
            <th>Maturity</th>
            <th>Last score tier</th>
            <th class="num">Suggested renewal amount</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody>
          {% for p in pipeline_rows %}
            <tr id="renewal-row-{{ p.merchant_id }}"
                data-test-id="renewal-pipeline-row"
                data-merchant-id="{{ p.merchant_id }}">
              <td class="merchant">
                <a href="/ui/merchants/{{ p.merchant_id }}">{{ p.business_name }}</a>
              </td>
              <td class="mono-cell"
                  style="text-align:right;{% if p.days_until_maturity < 0 %}color:var(--decline, #b94a2a);font-weight:600{% endif %}"
                  data-overdue="{{ 'true' if p.days_until_maturity < 0 else 'false' }}">
                {{ p.days_until_maturity }}
              </td>
              <td class="mono-cell">{{ p.maturity_date.isoformat() }}</td>
              <td>
                {% if p.last_score_tier %}
                  <span class="chip info">{{ p.last_score_tier }}</span>
                {% else %}
                  <span class="sub">—</span>
                {% endif %}
              </td>
              <td class="mono-cell" style="text-align:right">
                {% if p.suggested_renewal_amount is not none %}
                  ${{ "{:,.0f}".format(p.suggested_renewal_amount) }}
                {% else %}
                  <span class="sub">—</span>
                {% endif %}
              </td>
              <td>
                <button type="button"
                        class="btn primary"
                        data-test-id="prepare-renewal-button"
                        hx-post="/ui/merchants/{{ p.merchant_id }}/prepare-renewal"
                        hx-target="#renewal-row-{{ p.merchant_id }}"
                        hx-swap="outerHTML">
                  Prepare Renewal
                </button>
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    {% endif %}

    {# ============== Attestation calendar (existing) ============== #}
    <header class="sect-head" style="margin-top:32px">
      <h2>Maturities within {{ window_days }} days</h2>
      <div class="rule"></div>
      <div class="meta">n = {{ rows|length }}{% if schema_missing %} · maturity_date column absent{% endif %}</div>
    </header>

    {% if schema_missing %}
      <div class="empty">
        Maturity data unavailable
        <span class="copy">
          AEGIS has no <code>maturity_date</code> column on the
          <code>merchants</code> table yet. Add the column via an
          additive migration (operator decision — not auto-applied) to
          populate this calendar. See
          <code>src/aegis/merchants/repository.py::list_upcoming_renewals</code>
          for the contract this view expects.
        </span>
      </div>
    {% elif not rows %}
      <div class="empty" data-test-id="attestation-calendar-empty">
        No renewals approaching maturity in the next {{ window_days }} days.
        <span class="copy">
          Adjust the window with <code>?window_days=N</code>.
        </span>
      </div>
    {% else %}
      <table class="queue" data-test-id="attestation-calendar-table">
        <thead>
          <tr>
            <th>Merchant</th>
            <th>State</th>
            <th>Industry</th>
            <th>Maturity</th>
            <th class="num">Days to maturity</th>
            <th class="num">Days to state deadline</th>
            <th>Disclosure status</th>
            <th>Attest funder transmission</th>
          </tr>
        </thead>
        <tbody>
          {% for r in rows %}
            <tr>
              <td class="merchant">
                <a href="/ui/merchants/{{ r.merchant_id }}">{{ r.business_name }}</a>
                <span class="sub">{{ r.merchant_id|string|truncate(8, True, '') }}</span>
              </td>
              <td class="mono-cell">{{ r.state or '—' }}</td>
              <td>{{ r.industry_naics or '—' }}</td>
              <td class="mono-cell">{{ r.maturity_date.isoformat() }}</td>
              <td class="mono-cell" style="text-align:right">{{ r.days_until_maturity }}</td>
              <td class="mono-cell" style="text-align:right">
                {% if r.days_until_state_deadline is not none %}
                  {{ r.days_until_state_deadline }}
                {% else %}
                  N/A
                {% endif %}
              </td>
              <td>
                {% if r.renewal_status == 'disclosure_sent' %}
                  <span class="chip pos">SENT</span>
                {% elif r.renewal_status == 'disclosure_pending' %}
                  <span class="chip warn">PENDING</span>
                {% elif r.renewal_status == 'disclosure_overdue' %}
                  <span class="chip neg">OVERDUE</span>
                {% else %}
                  <span class="chip info">FUNDER OWNS</span>
                {% endif %}
              </td>
              <td>
                {% if r.renewal_status == 'disclosure_sent' %}
                  <span class="sub">attestation recorded</span>
                {% else %}
                  <form method="post"
                        action="/ui/renewals/{{ r.merchant_id }}/attest"
                        class="inline-form">
                    <input type="hidden"
                           name="maturity_date"
                           value="{{ r.maturity_date.isoformat() }}">
                    <label class="sub" for="funder_name_{{ r.merchant_id }}">Funder</label>
                    <input type="text"
                           id="funder_name_{{ r.merchant_id }}"
                           name="funder_name"
                           placeholder="Funder name"
                           required
                           maxlength="255">
                    <label class="sub" for="disclosure_sent_at_{{ r.merchant_id }}">Sent on</label>
                    <input type="date"
                           id="disclosure_sent_at_{{ r.merchant_id }}"
                           name="disclosure_sent_at"
                           required>
                    <label class="sub" for="notes_{{ r.merchant_id }}">Notes</label>
                    <input type="text"
                           id="notes_{{ r.merchant_id }}"
                           name="notes"
                           placeholder="optional"
                           maxlength="2000">
                    <button type="submit">Record</button>
                  </form>
                {% endif %}
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    {% endif %}
  </div>
</section>
{% endblock %}
