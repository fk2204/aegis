{% extends "base.html.j2" %}
{% set active = 'Funders' %}
{% block title %}Review Extracted Funder — AEGIS{% endblock %}

{% block deck %}
<header class="deck">
  <h1>Review Extraction<em> · funder draft</em></h1>
  <div class="meta">
    overall confidence
    <strong style="margin-left:6px;color:{% if extraction.overall_confidence >= 80 %}var(--approve){% elif extraction.overall_confidence >= 60 %}var(--review){% else %}var(--decline){% endif %}">{{ extraction.overall_confidence }}/100</strong>
    &nbsp;·&nbsp; low-confidence fields highlighted
  </div>
  <div class="actions">
    <a class="btn ghost" href="/ui/funders/import">Cancel</a>
  </div>
</header>
{% endblock %}

{% block body %}
<section class="body cols-1" style="max-width:920px;margin:0 auto">
  <div>
    {% set d = extraction.draft %}
    {% set conf = extraction.confidence_by_field %}

    {% macro field(label, name, value, kind="text") %}
      {% set c = conf.get(name, 100) %}
      {% set lo = c < low_confidence_threshold %}
      <div class="field {% if lo %}conf-low{% endif %}" style="padding:12px 14px;background:{% if lo %}var(--review-soft){% else %}var(--paper-2){% endif %};border-left:3px solid {% if lo %}var(--review){% else %}var(--rule){% endif %}">
        <label style="display:flex;justify-content:space-between;align-items:baseline">
          <span>{{ label }}</span>
          <span style="font-family:var(--mono);font-size:9.5px;letter-spacing:0.10em;color:{% if lo %}var(--review){% else %}var(--ink-3){% endif %}">conf {{ c }}/100</span>
        </label>
        {% if kind == "checkbox" %}
          <div style="display:flex;align-items:center;gap:8px;padding-top:4px">
            <input type="checkbox" name="{{ name }}" {% if value %}checked{% endif %} style="width:auto">
            <span style="font-family:var(--serif);font-size:13px;color:var(--ink-2)">enabled</span>
          </div>
        {% elif kind == "textarea" %}
          <textarea name="{{ name }}" rows="3">{{ value or "" }}</textarea>
        {% else %}
          <input type="{{ kind }}" name="{{ name }}" value="{{ value if value is not none else '' }}">
        {% endif %}
      </div>
    {% endmacro %}

    <header class="sect-head">
      <h2>Edit draft</h2>
      <div class="rule"></div>
      <div class="meta">FunderRow · {{ conf|length }} fields</div>
    </header>

    <form class="form" method="post" action="/ui/funders/import/save" style="margin-top:14px">
      {{ field("Funder name", "name", d.name) }}
      <div class="row two">
        {{ field("Min monthly revenue", "min_monthly_revenue", d.min_monthly_revenue, "number") }}
        {{ field("Min avg daily balance", "min_avg_daily_balance", d.min_avg_daily_balance, "number") }}
      </div>
      <div class="row two">
        {{ field("Min credit score", "min_credit_score", d.min_credit_score, "number") }}
        {{ field("Min months in business", "min_months_in_business", d.min_months_in_business, "number") }}
      </div>
      <div class="row two">
        {{ field("Max positions", "max_positions", d.max_positions, "number") }}
        {{ field("Accepts stacking", "accepts_stacking", d.accepts_stacking, "checkbox") }}
      </div>
      <div class="row two">
        {{ field("Max NSF tolerance", "max_nsf_tolerance", d.max_nsf_tolerance, "number") }}
        {{ field("Min advance", "min_advance", d.min_advance, "number") }}
      </div>
      <div class="row two">
        {{ field("Max advance", "max_advance", d.max_advance, "number") }}
        {{ field("Typical factor low", "typical_factor_low", d.typical_factor_low, "number") }}
      </div>
      <div class="row two">
        {{ field("Typical factor high", "typical_factor_high", d.typical_factor_high, "number") }}
        {{ field("Typical holdback low", "typical_holdback_low", d.typical_holdback_low, "number") }}
      </div>
      <div class="row two">
        {{ field("Typical holdback high", "typical_holdback_high", d.typical_holdback_high, "number") }}
        {{ field("Excluded industries · comma-separated", "excluded_industries", d.excluded_industries|join(", ")) }}
      </div>
      {{ field("Excluded states · comma-separated 2-letter codes", "excluded_states", d.excluded_states|join(", ")) }}

      {# Step C structured fields. Contact / auto-decline / conditional /
         notes_residual are editable here. Tiers are read-only (rich
         tier editing is a future "edit funder" feature) — extracted
         tiers ride through save in a hidden JSON input. #}
      <header class="sect-head" style="margin-top:24px">
        <h2>Contact</h2>
        <div class="rule"></div>
      </header>
      <div class="row two">
        {{ field("Contact name", "contact_name", d.contact_name) }}
        {{ field("Contact phone", "contact_phone", d.contact_phone) }}
      </div>
      <div class="row two">
        {{ field("Contact email", "contact_email", d.contact_email) }}
        {{ field("Submission email · used for sending deals", "submission_email", d.submission_email) }}
      </div>

      {% if d.tiers %}
        <header class="sect-head" style="margin-top:24px">
          <h2>Tiers · read-only</h2>
          <div class="rule"></div>
          <div class="meta">{{ d.tiers|length }} tier{{ '' if d.tiers|length == 1 else 's' }} · re-extract to change</div>
        </header>
        <table class="queue tier-table" style="margin-top:8px">
          <thead>
            <tr>
              <th>Tier</th>
              <th class="num">Buy rate</th>
              <th class="num">Min TIB</th>
              <th class="num">Min FICO</th>
              <th class="num">Min MRR</th>
              <th class="num">Max pos</th>
              <th class="num">Max advance</th>
              <th class="num">Max holdback</th>
            </tr>
          </thead>
          <tbody>
            {% for t in d.tiers %}
              <tr class="no-click">
                <td class="tier-name">{{ t.name }}</td>
                <td class="mono-cell num">{% if t.buy_rate_low and t.buy_rate_high %}{% if t.buy_rate_low == t.buy_rate_high %}{{ t.buy_rate_low }}{% else %}{{ t.buy_rate_low }}–{{ t.buy_rate_high }}{% endif %}{% else %}<span class="dash">—</span>{% endif %}</td>
                <td class="mono-cell num">{% if t.min_months_in_business is not none %}{{ t.min_months_in_business }}{% else %}<span class="dash">—</span>{% endif %}</td>
                <td class="mono-cell num">{% if t.min_credit_score is not none %}{{ t.min_credit_score }}{% else %}<span class="dash">—</span>{% endif %}</td>
                <td class="mono-cell num">{% if t.min_monthly_revenue %}${{ "{:,.0f}".format(t.min_monthly_revenue) }}{% else %}<span class="dash">—</span>{% endif %}</td>
                <td class="mono-cell num">{% if t.max_positions is not none %}{{ t.max_positions }}{% else %}<span class="dash">—</span>{% endif %}</td>
                <td class="mono-cell num">{% if t.max_advance %}${{ "{:,.0f}".format(t.max_advance) }}{% else %}<span class="dash">—</span>{% endif %}</td>
                <td class="mono-cell num">{% if t.max_holdback %}{{ "{:.0%}".format(t.max_holdback) }}{% else %}<span class="dash">—</span>{% endif %}</td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      {% endif %}
      {# Hidden tier JSON — serialised route-side via Pydantic's
         model_dump(mode='json') so Decimal precision survives the
         round-trip. The save route's _parse_tiers_json reconstructs
         FunderTier instances. Empty list when no tiers extracted. #}
      <input type="hidden" name="tiers_json" value="{{ tiers_json }}">

      <header class="sect-head" style="margin-top:24px">
        <h2>Conditions</h2>
        <div class="rule"></div>
        <div class="meta">one bullet per line</div>
      </header>
      <div class="row two">
        {{ field("Auto-decline · absolute disqualifiers", "auto_decline_conditions", d.auto_decline_conditions|join("\n"), "textarea") }}
        {{ field("Conditional · gated allowances", "conditional_requirements", d.conditional_requirements|join("\n"), "textarea") }}
      </div>

      <header class="sect-head" style="margin-top:24px">
        <h2>Notes</h2>
        <div class="rule"></div>
      </header>
      {{ field("Operator notes · added by you, not the extractor", "notes", d.notes, "textarea") }}
      {{ field("Notes residual · prose the extractor couldn't categorise", "notes_residual", d.notes_residual, "textarea") }}

      {% if extraction.unparseable_fragments %}
        <header class="sect-head" style="margin-top:6px">
          <h2>Unparseable fragments</h2>
          <div class="rule"></div>
          <div class="meta">{{ extraction.unparseable_fragments|length }} item{{ '' if extraction.unparseable_fragments|length == 1 else 's' }}</div>
        </header>
        <div class="feed">
          {% for frag in extraction.unparseable_fragments %}
            <div class="event"><div class="t">·</div><div class="txt">{{ frag }}</div></div>
          {% endfor %}
        </div>
      {% endif %}

      <div class="form-actions">
        <button class="btn primary" type="submit">Save funder</button>
        <a class="btn ghost" href="/ui/funders/import">Cancel</a>
      </div>
    </form>
  </div>
</section>
{% endblock %}
