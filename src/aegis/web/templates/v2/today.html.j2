{% extends "v2/base.html.j2" %}
{% import "v2/_macros.html.j2" as ui %}
{% set active = 'today' %}
{% block title %}Today · AEGIS{% endblock %}
{% block content %}
  <div class="eyebrow">Underwriting desk</div>
  <h1 class="desk">Today</h1>
  <div class="desk-sub">Pipeline triaged by what blocks a decision, not upload time.</div>

  {% if kpis %}
  <div class="kpis">
    {% for k in kpis %}
    <div class="kpi {{ 'alert' if k.is_alert }}"><div class="k">{{ k.label }}</div><div class="v">{{ k.value }}</div><div class="d">{{ k.detail }}</div></div>
    {% endfor %}
  </div>
  {% endif %}

  {% if mix %}
  <div class="mix">
    <div class="mix-head" style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px">
      <h3 style="margin:0">Pipeline by product</h3>
      <span style="font-size:11px;color:var(--ink-3);text-transform:uppercase;letter-spacing:.05em">{{ total | default(queue | length) }} FILES · {{ total_requested | default('$0') }} REQUESTED</span>
    </div>
    <div class="mixbar">{% for m in mix %}<i style="width:{{ m.pct }}%;background:{{ m.color }}"></i>{% endfor %}</div>
    <div class="mixleg">{% for m in mix %}<span><i style="background:{{ m.color }}"></i>{{ m.product }} <b>{{ m.count }}</b></span>{% endfor %}</div>
  </div>
  {% endif %}

  <div class="queue-head"><h2>Attention queue</h2></div>
  {% for q in queue %}
    <div class="qcard {{ q.verdict_kind }}"><div class="spine"></div>
      <div class="qbody">
        <div class="qtop"><span class="qnm">{{ q.name }}</span><span class="prodtag">{{ q.product }}</span>{{ ui.pill(q.status_kind, q.status_text) }}</div>
        <div class="qmeta">{{ q.meta }}</div>
        <div class="qwhy">{{ q.why | safe }}</div>
      </div>
      <div class="qside">
        {% if q.score_value %}<div class="miniscore"><div class="ms">{{ q.score_value }}</div><div class="ml">{{ q.score_label }}</div></div>{% endif %}
        <a href="/v2/deal/{{ q.deal_id }}">
          <button type="button" class="qact {{ 'p' if q.verdict_kind == 'p' else 'k' if q.verdict_kind == 'k' else '' }}">
            {{ 'Open & issue →' if q.verdict_kind == 'p' else 'Open & clear →' if q.verdict_kind == 'k' else 'Open file →' }}
          </button>
        </a>
      </div>
    </div>
  {% else %}
    <div class="card"><div class="bd"><p style="margin:0;color:var(--ink-3)">No pipeline data yet — wire <code>build_today_view()</code> to the real pipeline service (see MIGRATION.md §6). The shell and styling are working.</p></div></div>
  {% endfor %}

  <footer class="desk-foot" style="margin-top:32px;padding:12px 0;border-top:1px solid var(--line);font-size:11px;color:var(--ink-3)">
    <span class="dot" style="background:var(--pass);width:7px;height:7px;border-radius:50%;display:inline-block;margin-right:6px"></span>
    LIVE · aegis-prod · parser v4.2.1 · {{ queue | length }} files · {{ mix | length }} products configured · queue depth {{ queue_depth | default(0) }}
  </footer>
{% endblock %}
