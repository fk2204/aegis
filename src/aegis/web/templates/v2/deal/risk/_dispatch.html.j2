{# Renders exactly one product module server-side (no client switcher in prod). #}
{% if deal.product == 'rbf' %}
  {% include "v2/deal/risk/_mca.html.j2" ignore missing %}
  <div id="classification-wrap">{% include "v2/deal/_classification.html.j2" ignore missing %}</div>
{% elif deal.product in ('term', 'loc') %}
  {% include "v2/deal/risk/_term.html.j2" ignore missing %}
{% elif deal.product == 'equipment' %}
  {% include "v2/deal/risk/_equipment.html.j2" ignore missing %}
{% elif deal.product in ('factoring', 'abl') %}
  {% include "v2/deal/risk/_factoring.html.j2" ignore missing %}
{% endif %}
