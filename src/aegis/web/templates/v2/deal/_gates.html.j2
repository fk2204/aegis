{# _gates.html.j2 — kill / warn gates (spec 2C).

   The view model emits ``severity`` as ``kill`` or ``warn``. Legacy
   callers that still pass ``amber`` collapse to ``warn`` here so the
   render never regresses on the rename.
#}
{% for gate in gates %}
{% set sev = 'kill' if gate.severity == 'kill' else 'warn' %}
<div class="gate gate-{{ sev }}">
  <div class="gate-icon">{{ '!' if sev == 'kill' else '⚠' }}</div>
  <div class="gate-body">
    <div class="gate-title">{{ gate.title }}</div>
    <div class="gate-why">{{ gate.body }}</div>
  </div>
  {% if gate.action_label %}
  <a href="{{ gate.action_url or '#' }}">
    <button type="button" class="gate-btn">{{ gate.action_label }}</button>
  </a>
  {% endif %}
</div>
{% endfor %}
