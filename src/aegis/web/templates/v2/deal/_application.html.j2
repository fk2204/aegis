{# _application.html.j2 — "what the merchant told us" side card (spec 2E).

   Same ``application.rows`` view-model shape the legacy rail
   consumed. UNVERIFIED chip keys the operator to the fact that these
   values come from the Close application, not the bank statement.
#}
<div class="card side-card" id="application">
  <div class="head">
    <h2>What the merchant told us</h2>
    <span class="c warn">UNVERIFIED</span>
  </div>
  <div class="bd">
    {% for row in application.rows %}
    <div class="kv">
      <span class="k">{{ row.k }}</span>
      <span class="v">{{ row.v }}</span>
    </div>
    {% endfor %}
  </div>
</div>
