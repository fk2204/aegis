{% extends "base.html.j2" %}
{% set active = 'Review' %}
{% block title %}Manual review — AEGIS{% endblock %}

{% block subhead %}
<div class="subhead">
  <div>
    <h1>Manual review queue</h1>
    <div class="meta" style="margin-top:4px">
      <span><span class="dot"></span>{{ rows|length }} document{{ '' if rows|length == 1 else 's' }} flagged</span>
      <span>parse_status = manual_review · re-upload after fixing the source PDF</span>
    </div>
  </div>
  <div style="display:flex;gap:8px">
    <a class="btn btn-primary" href="/ui/upload">+ Re-upload</a>
  </div>
</div>
{% endblock %}

{% block body %}
<div class="body cols-1">
  <main class="main">
    <div class="panel">
      <div class="panel-head">
        <span class="panel-title">Documents in manual review</span>
        <span class="panel-actions mono">n = {{ rows|length }}</span>
      </div>
      <div class="panel-body flush">
        {% if not rows %}
          <div style="padding:32px;text-align:center;color:var(--muted)">
            <div style="font-size:14px;margin-bottom:6px">No documents in manual-review state.</div>
            <div style="font-size:12px">Pipeline is clean.</div>
          </div>
        {% else %}
          <table class="data">
            <thead>
              <tr>
                <th>Uploaded</th>
                <th>Merchant</th>
                <th>File</th>
                <th class="num">Fraud score</th>
                <th>Flags</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              {% for r in rows %}
              <tr>
                <td><span class="mono" style="font-size:11.5px">{{ r.uploaded_at }}</span></td>
                <td>{{ r.merchant_label }}</td>
                <td><span class="mono" style="font-size:11px;color:var(--muted)">{{ r.filename }}</span></td>
                <td class="num"><span class="tag neg"><span class="dot"></span>{{ r.fraud_score }}</span></td>
                <td>
                  {% if r.flags %}
                    <div style="display:flex;flex-wrap:wrap;gap:4px">
                      {% for f in r.flags[:5] %}
                        <span class="tag warn"><span class="dot"></span>{{ f }}</span>
                      {% endfor %}
                      {% if r.flags|length > 5 %}
                        <span style="font-family:var(--mono);font-size:11px;color:var(--muted)">+{{ r.flags|length - 5 }} more</span>
                      {% endif %}
                    </div>
                  {% else %}
                    <span style="color:var(--muted);font-family:var(--mono);font-size:11.5px">—</span>
                  {% endif %}
                </td>
                <td><a class="btn" href="/ui/upload">Re-upload</a></td>
              </tr>
              {% endfor %}
            </tbody>
          </table>
        {% endif %}
      </div>
    </div>
  </main>
</div>
{% endblock %}
