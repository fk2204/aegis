{% extends "base.html.j2" %}
{% set active = 'Review' %}
{% block title %}Manual review — AEGIS{% endblock %}

{% block deck %}
<header class="deck">
  <h1>Review<em> · manual queue</em></h1>
  <div class="meta">
    {{ rows|length }} document{{ '' if rows|length == 1 else 's' }} &nbsp;·&nbsp; parse_status = manual_review
  </div>
  <div class="actions">
    <a class="btn primary" href="/ui/upload">+ Re-upload</a>
  </div>
</header>
{% endblock %}

{% block body %}
<section class="body cols-1">
  <div>
    <header class="sect-head">
      <h2>Documents in manual review</h2>
      <div class="rule"></div>
      <div class="meta">n = {{ rows|length }} &nbsp;·&nbsp; all rows scored ≥ 65</div>
    </header>

    {% if not rows %}
      <div class="empty">No documents in manual-review state<span class="copy">Pipeline is clean.</span></div>
    {% else %}
      <table class="queue">
        <thead>
          <tr>
            <th>Uploaded</th>
            <th>Merchant</th>
            <th>File</th>
            <th class="num">Fraud</th>
            <th>Flags</th>
            <th class="act"></th>
          </tr>
        </thead>
        <tbody>
          {% for r in rows %}
            <tr class="no-click">
              <td class="mono-cell">{{ r.uploaded_at }}</td>
              <td class="merchant">{{ r.merchant_label }}</td>
              <td class="mono-cell">{{ r.filename }}</td>
              <td class="score {% if r.fraud_score is number and r.fraud_score >= 65 %}bad{% elif r.fraud_score is number and r.fraud_score >= 35 %}warn{% elif r.fraud_score is number %}calm{% endif %}">
                {% if r.fraud_score is number %}{{ r.fraud_score }}<span class="of">/100</span>{% else %}—{% endif %}
              </td>
              <td class="flags">
                {% if r.flags %}
                  {% for f in r.flags[:3] %}<span class="chip warn">{{ f }}</span>{% endfor %}
                  {% if r.flags|length > 3 %}
                    <details class="flags-more">
                      <summary>+{{ r.flags|length - 3 }} more</summary><span class="flags-more-extras">{% for f in r.flags[3:] %}<span class="chip warn">{{ f }}</span>{% endfor %}</span>
                    </details>
                  {% endif %}
                {% else %}
                  —
                {% endif %}
              </td>
              <td class="act"><a href="/ui/upload">re-upload ↗</a></td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    {% endif %}
  </div>
</section>
{% endblock %}
