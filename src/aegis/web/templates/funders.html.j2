{% extends "base.html.j2" %}
{% set active = 'Funders' %}
{% block title %}Funders — AEGIS{% endblock %}

{# Relative-time formatter for the "Last submission" column. Pure Jinja —
   no external helper available. Bucketing: today / Nd / Nw / Nmo / Ny.
   Input: a tz-aware datetime; falls back to em-dash when None. #}
{% macro relative_time(dt, now) -%}
{%- if dt is none -%}—
{%- else -%}
  {%- set delta = (now - dt) -%}
  {%- set secs = delta.total_seconds()|int -%}
  {%- if secs < 60 -%}just now
  {%- elif secs < 3600 -%}{{ (secs // 60) }}m ago
  {%- elif secs < 86400 -%}{{ (secs // 3600) }}h ago
  {%- elif secs < 86400 * 30 -%}{{ (secs // 86400) }}d ago
  {%- elif secs < 86400 * 365 -%}{{ (secs // (86400 * 30)) }}mo ago
  {%- else -%}{{ (secs // (86400 * 365)) }}y ago
  {%- endif -%}
{%- endif -%}
{%- endmacro %}

{% block deck %}
{% set title = "Funders" %}
{% set subtitle = "· criteria" %}
{% set meta = (funders|length|string) ~ " funder" ~ ("" if funders|length == 1 else "s") ~ " · click row → full guideline" %}
{% set actions = [
  {"label": "+ New funder", "href": "/ui/funders/new", "variant": "primary"},
  {"label": "+ Import PDF", "href": "/ui/funders/import", "variant": "ghost"},
] %}
{% include "_page_header.html.j2" %}
{% endblock %}

{% block body %}
<section class="body cols-1">
  <div>
    <header class="sect-head">
      <h2>Active funders</h2>
      <div class="rule"></div>
      <div class="meta">n = {{ funders|length }} &nbsp;·&nbsp; sorted by approval rate · last {{ performance_window_days }} days</div>
    </header>

    {% if not funder_rows %}
      <div class="empty">No funders yet. Import a funder's guideline PDF to get started.<span class="copy"><a class="btn primary" href="/ui/funders/import">Import</a></span></div>
    {% else %}
      {# === Active-only toggle ===
         Client-side filter on data-active="true|false". The route
         currently calls list_active() so every rendered row carries
         data-active="true"; the toggle is wired for the future when
         the repo grows a list_all(). Default = on (only active rows
         shown), matching today's behaviour. #}
      <div class="funders-controls" data-test-id="funders-controls"
           style="display:flex;flex-wrap:wrap;gap:12px;align-items:center;margin:14px 0 16px 0">
        <label style="display:flex;align-items:center;gap:6px;font-size:12px;opacity:0.9">
          <input type="checkbox"
                 id="funders-active-only"
                 data-test-id="funders-active-only"
                 checked>
          Active only
        </label>
        {# "Hide paused" filters out rows whose operator_status="paused".
           Default ON — paused funders are not in this week's match flow
           and adding them to the rolling-window approval-rate scan adds
           noise. Toggle off to manage the paused list. #}
        <label style="display:flex;align-items:center;gap:6px;font-size:12px;opacity:0.9">
          <input type="checkbox"
                 id="funders-hide-paused"
                 data-test-id="funders-hide-paused"
                 checked>
          Hide paused
        </label>
      </div>

      {#
        Default sort: approval_rate DESC, funders with None last.
        Server-side ordering — funder_rows is rebuilt here in sorted
        order so the table renders correct from the first paint
        regardless of JS. None ratings sort after every real rating
        (treated as -inf for the DESC ordering by mapping to a
        negative sentinel that we explicitly compare against).
      #}
      {% set _rated = funder_rows|selectattr('approval_rate')|list %}
      {% set _unrated = funder_rows|rejectattr('approval_rate')|list %}
      {% set _rated_sorted = _rated|sort(attribute='approval_rate', reverse=true) %}
      {% set _sorted_rows = _rated_sorted + _unrated %}

      {% set _op_status_labels = {
        "active": "Active",
        "paused": "Paused",
        "first_position_only": "First-pos only",
        "selective": "Selective",
      } %}
      {% set _op_status_tones = {
        "active": "pos",
        "paused": "bad",
        "first_position_only": "warn",
        "selective": "info",
      } %}

      <table class="queue" data-test-id="funders-table">
        <thead>
          <tr>
            <th>Funder</th>
            <th>Status</th>
            <th class="num">Approval rate</th>
            <th>Last submission</th>
            <th class="num">Min revenue</th>
            <th class="num">Min FICO</th>
            <th class="num">Min TIB · mo</th>
            <th class="num">Max pos</th>
            <th>Stacking</th>
            <th>Excludes</th>
            <th>Submit</th>
          </tr>
        </thead>
        <tbody data-test-id="funders-tbody">
          {% for row in _sorted_rows %}
            {% set f = row.funder %}
            <tr data-test-id="funders-row"
                data-active="{{ 'true' if f.active else 'false' }}"
                data-op-status="{{ f.operator_status }}"
                onclick="window.location.href='/ui/funders/{{ f.id }}'">
              <td class="merchant">
                <a href="/ui/funders/{{ f.id }}">{{ f.name }}</a>
                <span class="sub">{{ f.id|string|truncate(8, True, '') }}</span>
              </td>

              {# === Operator status chip ===
                 4-state appetite chip — paused/first-position-only/selective
                 are the operator-facing reasons that matter at-a-glance. #}
              <td data-test-id="funders-op-status">
                <span class="chip {{ _op_status_tones[f.operator_status] }}"
                      data-test-id="funders-op-status-chip">
                  {{ _op_status_labels[f.operator_status] }}
                </span>
                {# Marketplace badge — funder is active but carries no
                   published underwriting criteria. Mirrors the matched-
                   funder card badge on the dossier so the operator can
                   spot aggregator/no-criteria rows in either surface
                   without comparing columns. See ``_is_marketplace_funder``
                   in src/aegis/web/routers/merchants.py for the
                   activation rule. #}
                {% if f.active and f.min_monthly_revenue is none and f.min_credit_score is none and f.max_positions is none %}
                  <span class="chip"
                        data-test-id="funders-marketplace-badge"
                        style="margin-left:6px;font-family:var(--mono);font-size:9.5px;letter-spacing:0.14em;text-transform:uppercase;background:var(--rule);color:var(--ink-2);padding:2px 6px">
                    Marketplace
                  </span>
                {% endif %}
              </td>

              {# === Approval rate ===
                 Decimal -> XX% conversion happens at the template boundary
                 (not in the math). None -> em-dash. Tooltip surfaces the
                 window so the operator can read "last 90 days" without
                 hunting for the legend. #}
              <td class="mono-cell num"
                  data-test-id="funders-approval-rate"
                  title="Approval rate · last {{ performance_window_days }} days">
                {% if row.approval_rate is not none %}
                  {{ "{:.0%}".format(row.approval_rate) }}
                {% else %}
                  —
                {% endif %}
              </td>

              {# === Last submission ===
                 Relative-time chip + absolute ISO date as tooltip for
                 precision when the operator needs it. #}
              <td class="mono-cell"
                  data-test-id="funders-last-submission"
                  {% if row.last_submitted_at %}title="{{ row.last_submitted_at.isoformat() }}"{% endif %}>
                {{ relative_time(row.last_submitted_at, now_utc) }}
              </td>

              <td class="mono-cell" style="text-align:right">{{ "${:,.0f}".format(f.min_monthly_revenue) if f.min_monthly_revenue else '—' }}</td>
              <td class="mono-cell" style="text-align:right">{{ f.min_credit_score or '—' }}</td>
              <td class="mono-cell" style="text-align:right">{{ f.min_months_in_business or '—' }}</td>
              <td class="mono-cell" style="text-align:right">{{ f.max_positions if f.max_positions is not none else '—' }}</td>
              <td>
                {% if f.accepts_stacking %}
                  {% with tone="good", label="yes" %}{% include "_status_chip.html.j2" %}{% endwith %}
                {% else %}
                  {% with tone="bad", label="no" %}{% include "_status_chip.html.j2" %}{% endwith %}
                {% endif %}
              </td>
              <td class="mono-cell">
                {% if f.excluded_states %}{{ f.excluded_states|length }} state{{ '' if f.excluded_states|length == 1 else 's' }}{% endif %}
                {% if f.excluded_states and f.excluded_industries %} · {% endif %}
                {% if f.excluded_industries %}{{ f.excluded_industries|length }} ind{% endif %}
                {% if not f.excluded_states and not f.excluded_industries %}—{% endif %}
              </td>
              <td>
                {# Per-row Submit button. Uses .btn (not .btn.primary) so
                   the row's row-as-link onclick remains the dominant
                   affordance; the button is a focused shortcut, not the
                   primary call to action. onclick stopPropagation
                   prevents the row-level navigation handler from firing
                   when the operator clicks the modal button. #}
                <button class="btn"
                        type="button"
                        data-test-id="funders-submit-button"
                        hx-get="/ui/funders/{{ f.id }}/submit-modal"
                        hx-target="#funders-submit-modal-host"
                        hx-swap="innerHTML"
                        onclick="event.stopPropagation()">
                  Submit a deal
                </button>
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    {% endif %}
  </div>
</section>

{# Modal mount point — submit-a-deal modal swaps its HTML in here via HTMX. #}
<div id="funders-submit-modal-host"></div>

{% if funder_rows %}
<script>
// Funder list filters: "Active only" + "Hide paused". Pure JS, no deps.
// Each row carries data-active="true|false" and data-op-status="<state>".
// Active-only hides inactive rows; Hide-paused hides operator_status="paused"
// rows. Filters compose with AND.
(function () {
  const activeOnlyToggle = document.getElementById("funders-active-only");
  const hidePausedToggle = document.getElementById("funders-hide-paused");
  if (!activeOnlyToggle && !hidePausedToggle) return;
  const rows = Array.from(
    document.querySelectorAll('tr[data-test-id="funders-row"]')
  );
  function applyToggles() {
    const activeOnly = activeOnlyToggle ? activeOnlyToggle.checked : false;
    const hidePaused = hidePausedToggle ? hidePausedToggle.checked : false;
    for (const row of rows) {
      const isActive = row.getAttribute("data-active") === "true";
      const isPaused = row.getAttribute("data-op-status") === "paused";
      const hideForActive = activeOnly && !isActive;
      const hideForPaused = hidePaused && isPaused;
      row.style.display = (hideForActive || hideForPaused) ? "none" : "";
    }
  }
  if (activeOnlyToggle) activeOnlyToggle.addEventListener("change", applyToggles);
  if (hidePausedToggle) hidePausedToggle.addEventListener("change", applyToggles);
  applyToggles();
})();
</script>
{% endif %}
{% endblock %}
