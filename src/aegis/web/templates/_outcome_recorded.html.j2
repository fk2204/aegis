{# Confirmation swap after the operator clicks one of the four
   funder-outcome buttons on the dossier. Renders an inline
   "recorded" affirmation in place of the buttons. #}
<div class="funder-outcome-recorded"
     data-test-id="funder-outcome-recorded"
     style="background:#d4edda;border:1px solid #c3e6cb;color:#155724;padding:10px 14px;border-radius:6px;font-size:13px">
  <strong>✓ Outcome recorded.</strong>
  {{ message }}
</div>
