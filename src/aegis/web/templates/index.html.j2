{% extends "base.html.j2" %}
{% set active = 'Today' %}
{% block title %}AEGIS — Today{% endblock %}

{% block subhead %}
<div class="subhead">
  <div>
    <h1>Today · Underwriting desk</h1>
    <div class="meta" style="margin-top:4px">
      <span><span class="dot"></span>All systems nominal</span>
      <span>{{ now|default('') }}</span>
    </div>
  </div>
  <div style="display:flex;gap:8px">
    <a class="btn" href="/ui/upload">Upload statement</a>
    <a class="btn btn-primary" href="/ui/intake">+ New deal</a>
  </div>
</div>
{% endblock %}

{% block body %}
<div class="body cols-2" style="grid-template-columns:220px 1fr">
  <aside class="side">
    <div class="side-section">
      <div class="side-label">Queue</div>
      <div class="side-item {{ 'active' if manual_review_count > 0 else '' }}"><a href="/ui/review" style="color:inherit;text-decoration:none;flex:1">Manual review</a><span class="count">{{ manual_review_count }}</span></div>
      <div class="side-item"><a href="/ui/deals" style="color:inherit;text-decoration:none;flex:1">All deals</a><span class="count">{{ in_pipeline }}</span></div>
      <div class="side-item"><a href="/ui/merchants" style="color:inherit;text-decoration:none;flex:1">All merchants</a><span class="count">{{ merchant_total }}</span></div>
    </div>
    <div class="side-section">
      <div class="side-label">Parse status</div>
      <div class="side-item"><span>Proceed</span><span class="count">{{ proceed_count }}</span></div>
      <div class="side-item"><span>Review</span><span class="count">{{ review_count }}</span></div>
      <div class="side-item"><span>Manual review</span><span class="count">{{ manual_review_count }}</span></div>
      <div class="side-item"><span>Pending</span><span class="count">{{ pending_count }}</span></div>
      <div class="side-item"><span>Error</span><span class="count">{{ error_count }}</span></div>
    </div>
    <div class="side-section">
      <div class="side-label">Jump to</div>
      <div class="side-item"><a href="/ui/upload" style="color:inherit;text-decoration:none;flex:1">Upload</a><span class="count mono">PDF</span></div>
      <div class="side-item"><a href="/ui/intake" style="color:inherit;text-decoration:none;flex:1">New deal</a><span class="count mono">+</span></div>
      <div class="side-item"><a href="/ui/funders" style="color:inherit;text-decoration:none;flex:1">Funders</a><span class="count mono">$</span></div>
    </div>
  </aside>

  <main class="main">
    <div class="kpi-row">
      <div class="kpi">
        <div class="label">Merchants</div>
        <div class="value">{{ merchant_total }}</div>
        <div class="delta">total in book</div>
      </div>
      <div class="kpi">
        <div class="label">In pipeline</div>
        <div class="value">{{ in_pipeline }}</div>
        <div class="delta">documents not yet declined</div>
      </div>
      <div class="kpi">
        <div class="label">Cleared (proceed)</div>
        <div class="value">{{ proceed_count }}</div>
        <div class="delta">parse_status = proceed</div>
      </div>
      <div class="kpi">
        <div class="label">Manual review</div>
        <div class="value" style="color:{% if manual_review_count > 0 %}var(--warn){% else %}var(--ink){% endif %}">{{ manual_review_count }}</div>
        <div class="delta"><a href="/ui/review">open queue</a></div>
      </div>
      <div class="kpi">
        <div class="label">Errors</div>
        <div class="value" style="color:{% if error_count > 0 %}var(--neg){% else %}var(--ink){% endif %}">{{ error_count }}</div>
        <div class="delta">parse_status = error</div>
      </div>
    </div>

    <div class="grid-2">
      <div class="panel">
        <div class="panel-head">
          <span class="panel-title">Pipeline funnel</span>
          <span class="panel-actions mono">live · parse_status + audit_log</span>
        </div>
        <div class="panel-body">
          <div class="funnel">
            {% for row in funnel_rows %}
              <div class="funnel-row">
                <span>{{ row.label }}</span>
                <div class="funnel-bar"><div class="funnel-fill {{ row.cls }}" style="width:{{ row.width }}%"></div></div>
                <span class="funnel-num">{{ row.count }}</span>
              </div>
            {% endfor %}
          </div>
        </div>
      </div>

      <div class="panel">
        <div class="panel-head">
          <span class="panel-title">Quick links</span>
          <span class="panel-actions mono">workflows</span>
        </div>
        <div class="panel-body">
          <div class="kv">
            <span class="k">Upload</span>
            <span class="v ui"><a href="/ui/upload">Drop bank statements (PDF)</a></span>
            <span class="k">Intake</span>
            <span class="v ui"><a href="/ui/intake">Start a new deal</a></span>
            <span class="k">Deals</span>
            <span class="v ui"><a href="/ui/deals">Live pipeline</a></span>
            <span class="k">Merchants</span>
            <span class="v ui"><a href="/ui/merchants">Merchant directory</a></span>
            <span class="k">Funders</span>
            <span class="v ui"><a href="/ui/funders">Funder criteria + matching</a></span>
            <span class="k">Review</span>
            <span class="v ui"><a href="/ui/review">Parser manual-review queue</a></span>
          </div>
        </div>
      </div>
    </div>

    <div class="panel">
      <div class="panel-head">
        <span class="panel-title">Needs your attention</span>
        <span class="panel-actions">
          <span class="risk-band-legend" title="Risk bands mirror parse_status thresholds in parser.pipeline">
            <span><span class="swatch clear"></span>0-34 clear</span>
            <span><span class="swatch review"></span>35-64 review</span>
            <span><span class="swatch decline"></span>65-100 manual</span>
          </span>
          <span class="mono" style="margin-left:10px">{{ attention|length }} document{{ '' if attention|length == 1 else 's' }} in manual_review</span>
        </span>
      </div>
      <div class="panel-body flush">
        <table class="data">
          <thead>
            <tr>
              <th>Merchant</th>
              <th class="num">Fraud score</th>
              <th>Flags</th>
              <th>Uploaded</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            {% if not attention %}
              <tr><td colspan="5" style="text-align:center;color:var(--muted);padding:24px;font-family:var(--mono);font-size:11.5px">
                no documents in manual_review · pipeline is clear
              </td></tr>
            {% else %}
              {% for a in attention %}
                <tr>
                  <td>{{ a.merchant_label }}</td>
                  <td class="num">
                    {% with score=a.fraud_score %}
                      {% include "_fraud_score_chip.html.j2" %}
                    {% endwith %}
                  </td>
                  <td><span class="mono" style="font-size:11px;color:var(--muted)">{{ a.flags or '—' }}</span></td>
                  <td><span class="mono" style="font-size:11px;color:var(--muted)">{{ a.uploaded_at }}</span></td>
                  <td><a class="btn" href="/ui/review">review</a></td>
                </tr>
              {% endfor %}
            {% endif %}
          </tbody>
        </table>
      </div>
    </div>

    <div class="panel">
      <div class="panel-head">
        <span class="panel-title">Recent activity</span>
        <span class="panel-actions mono">audit_log · last {{ recent_activity|length }}</span>
      </div>
      <div class="panel-body flush">
        {% if not recent_activity %}
          <div style="padding:16px;color:var(--muted);font-size:12px">No activity logged yet.</div>
        {% else %}
          {% for r in recent_activity %}
            <div class="activity-item">
              <span class="time">{{ r.time_short }}</span>
              <span><span class="who">{{ r.actor }}</span> <span class="what">{{ r.action }}</span>{% if r.subject_type %} <span class="obj">{{ r.subject_type }}{% if r.subject_id %} · {{ r.subject_id[:8] }}{% endif %}</span>{% endif %}</span>
            </div>
          {% endfor %}
        {% endif %}
      </div>
    </div>
  </main>
</div>
{% endblock %}
