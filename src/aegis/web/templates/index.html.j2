{% extends "base.html.j2" %}
{% set active = 'Today' %}
{% block title %}AEGIS — Today{% endblock %}

{% block deck %}
{% set title = "Today" %}
{% set subtitle = " · Underwriting desk" %}
{% set meta %}{{ merchant_total }} merchant{{ '' if merchant_total == 1 else 's' }} &nbsp;·&nbsp; {{ in_pipeline }} in pipeline{% endset %}
{% set actions = [
  {"label": "Upload PDF", "href": "/ui/upload"},
  {"label": "+ New deal", "href": "/ui/intake", "variant": "primary"},
] %}
{% include "_page_header.html.j2" %}

{# 2026-06-28 — key numbers banner. Sits ABOVE the existing stats strip
   so the operator's first read is the pipeline-state-at-a-glance. All
   five values reuse the route's already-computed counts; no extra DB
   round-trips on the dashboard render. #}
{% if key_numbers %}
<section class="key-numbers-banner" data-test-id="dashboard-key-numbers">
  <div class="key-cell">
    <div class="k">Active deals</div>
    <div class="v">{{ key_numbers.active_deals }}</div>
  </div>
  <div class="key-cell">
    <div class="k">Pending parse</div>
    <div class="v">{{ key_numbers.pending_parse }}</div>
  </div>
  <div class="key-cell">
    <div class="k">Ready to submit</div>
    <div class="v {{ 'calm' if key_numbers.ready_to_submit > 0 else '' }}">{{ key_numbers.ready_to_submit }}</div>
  </div>
  <div class="key-cell">
    <div class="k">Submitted (7d)</div>
    <div class="v">{{ key_numbers.submitted_this_week }}</div>
  </div>
  <div class="key-cell">
    <div class="k">Avg revenue (7d)</div>
    <div class="v">{% if key_numbers.avg_revenue_this_week is not none %}${{ '{:,.0f}'.format(key_numbers.avg_revenue_this_week) }}{% else %}—{% endif %}</div>
  </div>
</section>
{% endif %}

{# 2026-06-29 — FIX 1: removed the duplicate stats strip. It rendered
   the same numbers as the key-numbers banner above (Merchants / In
   pipeline / Cleared / Review / Manual review / Pending / Errors all
   come from the same parse_status histogram). Single source of truth
   is now the key-numbers banner. #}
{% endblock %}

{% block body %}
{# 2026-06-29 dashboard refresh — Fix A: the trailing-6-month gross-
   deposits strip was removed. It summed deposits across all merchants
   in the portfolio, which is operationally meaningless for an ISO
   broker that doesn't carry the receivables. Replaced with the compact
   one-liner below — three actionable counts the operator scans on
   page load. The `_compute_monthly_comparison` helper + its tests
   stay on disk (out of scope) but their result is no longer rendered.
#}
{# 2026-06-29 — FIX 1: removed the week-summary-line. The same three
   counts (pending parse / ready to submit / avg revenue 7d) already
   render in the key-numbers banner up top — the second copy here was
   the third repetition of the same data on the same page. Banner is
   the single source of truth. #}

{# Today three-column layout (2026-06-16) — attention queue / pipeline
   today / quick-actions + recent activity. Mobile (<768px) stacks the
   three columns in the order operators care about most: attention
   first, pipeline second, quick actions third. See aegis-tool.css
   "/* TODAY DASHBOARD */" at file end. #}
{# Worker-queue depth banner — surfaces when arq pending depth
   exceeds AEGIS_QUEUE_DEPTH_ALERT_THRESHOLD (default 20). Mirrors
   the cron's audit-log alert so operators see backed-up workers on
   the dashboard without grepping journald. Hidden when Redis is
   unreachable (queue_depth=None → queue_alert=False). #}
{% if queue_alert %}
<div class="system-alert"
     data-test-id="queue-depth-alert"
     style="padding:10px 16px;margin:8px 24px 0;background:#fdf0f0;border:1px solid #c75252;border-radius:4px;font-size:13px;color:#3a1414">
  <strong>Worker queue backed up</strong> — {{ queue_depth }} jobs waiting (threshold {{ queue_threshold }}). New uploads are queued but not yet parsing.
</div>
{% endif %}

<section class="body today-cols">

  {# ── LEFT 40% · Attention queue ────────────────────────────────── #}
  <div class="today-col today-col--attention" data-test-id="today-attention-queue">
    {% set total_docs = attention|sum(attribute='doc_count') %}
    {% set attn_section_total = attention|length + stale_deals_count + pending_funder_count + compliance_count %}
    <header class="sect-head">
      <h2>Attention queue</h2>
      <div class="rule"></div>
      <div class="meta">
        {{ attn_section_total }} item{{ '' if attn_section_total == 1 else 's' }} needs follow-up
      </div>
    </header>

    {# 1 — Manual-review items (existing AttentionCard payload).
       Preserved verbatim so the chip macros + flag categorization
       continue to render identically. #}
    <div class="attn-section" data-test-id="today-attn-manual-review">
      <h3 class="attn-section-head">Manual review · {{ attention|length }}</h3>
      {% if not attention %}
        <div class="empty">Pipeline clear<span class="copy">No documents awaiting manual review.</span></div>
      {% else %}
        <div class="attention-cards">
          {% for g in attention %}
            <article class="attention-card band-{{ g.fraud_band }}">
              <header class="card-head">
                <div class="card-title">
                  {% if g.merchant_id %}<a href="/ui/merchants/{{ g.merchant_id }}">{{ g.merchant_label }}</a>{% else %}<span class="card-title-text">{{ g.merchant_label }}</span>{% endif %}
                  <span class="card-sub">
                    {# 2026-06-29 dashboard refresh — Fix D: NAICS code
                       resolved to its friendly label and requested
                       amount rounded to the nearest $1k for scan-level
                       readability. The raw values are still on the
                       card (``merchant_naics`` + ``requested_amount``)
                       for any downstream consumer. #}
                    {% if g.merchant_state %}{{ g.merchant_state }}{% endif %}{% if g.naics_display %} · {{ g.naics_display }}{% endif %}{% if g.requested_display %} · Requested {{ g.requested_display }}{% endif %}
                  </span>
                </div>
                <div class="card-meta">
                  <div class="card-score {% if g.fraud_band == 'decline' %}bad{% elif g.fraud_band == 'review' %}warn{% elif g.fraud_band == 'clear' %}calm{% endif %}">
                    {% if g.worst_fraud_score is number %}{{ g.worst_fraud_score }}<span class="of">/100</span>{% else %}—{% endif %}
                    <span class="card-score-label">worst fraud</span>
                  </div>
                  {% if g.tier %}
                    <span class="card-tier tier-{{ g.tier|lower }}" title="Deal tier from score_deal on worst-scoring document">{{ g.tier }}<span class="card-tier-label">tier</span></span>
                  {% endif %}
                </div>
              </header>

              {# Decline-class signals row — ALWAYS present so workers see
                 at a glance whether the card has dealbreakers. Empty state
                 renders muted ("(none)") to read as quiet confirmation, not
                 as missing data. #}
              <div class="card-decline-row {% if g.flags.decline_class %}is-active{% else %}is-empty{% endif %}">
                {% if g.flags.decline_class %}
                  <div class="card-section-head card-section-head-decline">Decline-class · {{ g.flags.decline_class|length }}</div>
                  <div class="card-flag-list">
                    {% for hf in g.flags.decline_class %}{% include "_humanized_chip.html.j2" %}{% endfor %}
                  </div>
                {% else %}
                  <div class="card-section-head card-section-head-empty">Decline-class · <span class="card-section-empty-text">(none)</span></div>
                {% endif %}
              </div>

              {# Category groups in fixed display order — only non-empty
                 render. Each group gets its glossary label as a small-caps
                 heading. #}
              {% for category_name, category_flags in g.flags.by_category.items() %}
                <div class="card-category">
                  <div class="card-section-head">{{ category_labels.get(category_name, category_name) }}</div>
                  <div class="card-flag-list">
                    {% for hf in category_flags %}{% include "_humanized_chip.html.j2" %}{% endfor %}
                  </div>
                </div>
              {% endfor %}

              <div class="card-docs-section">
                <div class="card-section-head">Documents · {{ g.doc_count }}</div>
                <ul class="card-docs">
                  {% for d in g.documents %}
                    <li class="card-doc">
                      <span class="doc-id">doc · {{ d.document_id[:8] }}</span>
                      <span class="doc-score {% if d.fraud_score is number and d.fraud_score >= 65 %}bad{% elif d.fraud_score is number and d.fraud_score >= 35 %}warn{% elif d.fraud_score is number %}calm{% endif %}">
                        {% if d.fraud_score is number %}{{ d.fraud_score }}<span class="of">/100</span>{% else %}—{% endif %}
                      </span>
                      <span class="doc-uploaded">{{ d.uploaded_at }}</span>
                      <a class="doc-review" href="/ui/documents/{{ d.document_id }}">open document ↗</a>
                    </li>
                  {% endfor %}
                </ul>
              </div>
            </article>
          {% endfor %}
        </div>
      {% endif %}
    </div>

    {# 2 — Stale deals (no doc activity 7+ days). Compact one-line
       cards; full follow-up happens on the merchant dossier. #}
    <div class="attn-section" data-test-id="today-attn-stale-deals">
      <h3 class="attn-section-head">Stale deals · {{ stale_deals_count }}</h3>
      {% if not stale_deals_cards %}
        <div class="empty empty-mini">All deals current.</div>
      {% else %}
        <ul class="attn-list">
          {% for c in stale_deals_cards %}
            <li class="attn-card" data-test-id="{{ c.test_id }}">
              <a class="attn-card-title" href="{{ c.href }}">{{ c.merchant_label }}</a>
              <span class="attn-card-needs">{{ c.needs }}</span>
            </li>
          {% endfor %}
        </ul>
        {% if stale_deals_count > stale_deals_cards|length %}
          <div class="attn-more">+ {{ stale_deals_count - stale_deals_cards|length }} more</div>
        {% endif %}
      {% endif %}
    </div>

    {# 3.5 — Compliance deadlines within 90-day horizon.
       Red <=14 days, amber <=30, yellow <=60. Color buckets come from
       UpcomingObligation.urgency on the server so the template stays
       date-math-free, matching the rest of the obligations page. #}
    <div class="attn-section" data-test-id="today-attn-compliance">
      <h3 class="attn-section-head">Compliance deadlines · {{ compliance_count }}</h3>
      {% if not compliance_cards %}
        <div class="empty empty-mini">No compliance deadlines in the next 90 days.</div>
      {% else %}
        <ul class="attn-list">
          {% for c in compliance_cards %}
            <li class="attn-card urgency-{{ c.urgency }}" data-test-id="{{ c.test_id }}" data-urgency="{{ c.urgency }}">
              <a class="attn-card-title" href="{{ c.href }}">{{ c.state_code }} {{ c.authority }}</a>
              <span class="attn-card-needs">{{ c.needs }}</span>
            </li>
          {% endfor %}
        </ul>
        {% if compliance_count > compliance_cards|length %}
          <div class="attn-more">+ {{ compliance_count - compliance_cards|length }} more</div>
        {% endif %}
      {% endif %}
    </div>

    {# 4 — Pending submissions with no funder response after 5 days. #}
    <div class="attn-section" data-test-id="today-attn-pending-funders">
      <h3 class="attn-section-head">Awaiting funder · {{ pending_funder_count }}</h3>
      {% if not pending_funder_cards %}
        <div class="empty empty-mini">No pending submissions stalled.</div>
      {% else %}
        <ul class="attn-list">
          {% for c in pending_funder_cards %}
            <li class="attn-card" data-test-id="{{ c.test_id }}">
              <a class="attn-card-title" href="{{ c.href }}">{{ c.merchant_label }}</a>
              <span class="attn-card-needs">{{ c.needs }}</span>
            </li>
          {% endfor %}
        </ul>
        {% if pending_funder_count > pending_funder_cards|length %}
          <div class="attn-more">+ {{ pending_funder_count - pending_funder_cards|length }} more</div>
        {% endif %}
      {% endif %}
    </div>

    {# 5 — Shadow signals this week (Item 3 / 2026-06-25).
       Counts distinct documents (NOT fires) with any [SHADOW] flag in
       the last 7 days. The Wed 06:00 UTC cron writes the matching
       audit rows; this card links to /ui/shadow-review for the full
       list. #}
    <div class="attn-section" data-test-id="today-attn-shadow-review">
      <h3 class="attn-section-head">Shadow signals this week · {{ shadow_review_count }}</h3>
      {% if not shadow_review_cards %}
        <div class="empty empty-mini">No shadow flags fired in the last 7 days.</div>
      {% else %}
        <ul class="attn-list">
          {% for c in shadow_review_cards %}
            <li class="attn-card" data-test-id="{{ c.test_id }}">
              <a class="attn-card-title" href="{{ c.href }}">{{ c.merchant_name }}</a>
              <span class="attn-card-needs">{{ c.contributing_codes|join(", ") }}</span>
            </li>
          {% endfor %}
        </ul>
        {% if shadow_review_count > shadow_review_cards|length %}
          <div class="attn-more">+ {{ shadow_review_count - shadow_review_cards|length }} more</div>
        {% endif %}
      {% endif %}
    </div>
  </div>

  {# ── CENTER 35% · Pipeline today ──────────────────────────────── #}
  <div class="today-col today-col--pipeline" data-test-id="today-pipeline">
    <header class="sect-head">
      <h2>Pipeline today</h2>
      <div class="rule"></div>
      <div class="meta">since 00:00 UTC</div>
    </header>

    {# 2026-06-29 dashboard refresh — Fix F: when no deals have been
       scored yet today, surface a single empty-state message instead of
       three zeroed widgets. The key on _compute_today_pipeline's return
       is ``deals_scored`` (NOT ``scored``); ``today_pipeline`` is ``{}``
       only when the helper raised inside ``asyncio.gather``. #}
    {% if not today_pipeline or today_pipeline.deals_scored == 0 %}
      <div class="empty" data-test-id="today-pipeline-empty">
        Nothing scored yet today<span class="copy">As you upload statements + score deals, today's tiers and funnel land here.</span>
      </div>
    {% else %}
      <div class="today-scored" data-test-id="today-pipeline-scored">
        <div class="today-scored-n">{{ today_pipeline.deals_scored }}</div>
        <div class="today-scored-label">deal{{ '' if today_pipeline.deals_scored == 1 else 's' }} scored today</div>
      </div>

      <div class="tier-pills" data-test-id="today-pipeline-tiers">
        {% for letter in ['A','B','C','D','F'] %}
          <div class="tier-pill tier-pill-{{ letter }}" data-test-id="today-tier-{{ letter|lower }}">
            <span class="tier-pill-letter">{{ letter }}</span>
            <span class="tier-pill-count">{{ today_pipeline.tiers.get(letter, 0) }}</span>
          </div>
        {% endfor %}
      </div>

      <div class="today-funnel" data-test-id="today-pipeline-funnel">
        <h3 class="attn-section-head">Today's funnel</h3>
        <ol class="funnel-stages">
          {% for stage in today_pipeline.funnel_stages %}
            <li class="funnel-stage" data-test-id="today-funnel-{{ stage.label|lower }}">
              <span class="funnel-stage-count">{{ stage.count }}</span>
              <span class="funnel-stage-label">{{ stage.label }}</span>
            </li>
          {% endfor %}
        </ol>
      </div>
    {% endif %}

    {# 2026-06-29 dashboard refresh — Fix B: lifetime pipeline funnel
       removed. The aggregate-since-launch funnel competed with the
       Today-scoped funnel above it for the same operator attention,
       and the lifetime numbers weren't actionable. The
       ``_build_funnel_rows`` helper still computes the data in the
       route (cheap), but it's no longer rendered. #}
  </div>

  {# ── RIGHT 25% · Quick actions + recent activity ─────────────── #}
  <aside class="today-col today-col--actions" data-test-id="today-quick-actions">
    <header class="sect-head">
      <h2>Quick actions</h2>
      <div class="rule"></div>
      <div class="meta">start here</div>
    </header>

    <div class="qa-buttons">
      {% for a in quick_actions %}
        <a class="btn primary qa-btn" href="{{ a.href }}" data-test-id="{{ a.test_id }}">{{ a.label }}</a>
      {% endfor %}
    </div>

    <header class="sect-head" style="margin-top:32px">
      <h2>Recent activity</h2>
      <div class="rule"></div>
      <div class="meta">last {{ today_recent_activity|length }}</div>
    </header>
    <ul class="today-activity" data-test-id="today-recent-activity">
      {% if not today_recent_activity %}
        <li class="empty empty-mini">No activity yet today.</li>
      {% else %}
        {% for r in today_recent_activity %}
          <li class="today-activity-row">
            <span class="today-activity-time">{{ r.time_short }}</span>
            {# 2026-06-29 — Fix C: operator-readable display_label
               (built via _format_activity_label) replaces the raw
               humanize_audit_action output for the right-rail view. #}
            <span class="today-activity-action">{{ r.display_label }}</span>
          </li>
        {% endfor %}
      {% endif %}
    </ul>
  </aside>

</section>

{# Day's log — full-width, page bottom. Low-priority surface; sits
   below the main three-column body so the attention queue and pipeline
   funnel claim the prime real estate at the top. Preserved unchanged
   from the prior layout — operators trained on this panel keep their
   muscle memory. #}
<section class="body" style="margin-top:var(--s-section-gap)">
  <div>
    <header class="sect-head">
      <h2>Day's log</h2>
      <div class="rule"></div>
      <div class="meta">last {{ recent_activity|length }}</div>
    </header>
    <div class="feed">
      {% if not recent_activity %}
        <div class="empty" style="padding:20px 0">No activity logged yet.</div>
      {% else %}
        {% for r in recent_activity %}
          <div class="event">
            <div class="t">{{ r.time_short }}</div>
            <div class="txt">
              {# 2026-06-29 — Fix C: ``display_label`` is the
                 operator-translated event string. ``action`` is
                 retained on the dict for downstream replay / debug. #}
              <strong>{{ r.actor }}</strong> {{ r.display_label }}{% if r.subject_type %}<span class="mono-inline">· {{ r.subject_type }}{% if r.subject_id %}/{{ r.subject_id[:8] }}{% endif %}</span>{% endif %}
            </div>
          </div>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>
{% endblock %}
