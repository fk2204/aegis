{% extends "base.html.j2" %}
{% set active = 'Today' %}
{% block title %}AEGIS — Today{% endblock %}

{% block deck %}
<header class="deck">
  <h1>Today<em> · Underwriting desk</em></h1>
  <div class="meta">
    {{ merchant_total }} merchant{{ '' if merchant_total == 1 else 's' }} &nbsp;·&nbsp; {{ in_pipeline }} in pipeline
  </div>
  <div class="actions">
    <a class="btn" href="/ui/upload">Upload PDF</a>
    <a class="btn primary" href="/ui/intake">+ New deal</a>
  </div>
</header>

<section class="strip">
  <div class="cell">
    <div class="k">Merchants</div>
    <div class="v">{{ merchant_total }}</div>
  </div>
  <div class="cell">
    <div class="k">In pipeline</div>
    <div class="v">{{ in_pipeline }}</div>
  </div>
  <div class="cell">
    <div class="k">Cleared</div>
    <div class="v {{ 'calm' if proceed_count > 0 else '' }}">{{ proceed_count }}</div>
  </div>
  <div class="cell">
    <div class="k">Review</div>
    <div class="v {{ 'warn' if review_count > 0 else '' }}">{{ review_count }}</div>
  </div>
  <div class="cell">
    <div class="k">Manual review</div>
    <div class="v {{ 'bad' if manual_review_count > 0 else '' }}">{{ manual_review_count }}</div>
  </div>
  <div class="cell">
    <div class="k">Pending</div>
    <div class="v">{{ pending_count }}</div>
  </div>
  <div class="cell">
    <div class="k">Errors</div>
    <div class="v {{ 'bad' if error_count > 0 else '' }}">{{ error_count }}</div>
  </div>
</section>
{% endblock %}

{% block body %}
<section class="body cols-2">

  <div>
    {% set total_docs = attention|sum(attribute='doc_count') %}
    <header class="sect-head">
      <h2>Attention queue</h2>
      <div class="rule"></div>
      <div class="meta">
        {{ attention|length }} merchant{{ '' if attention|length == 1 else 's' }} ·
        {{ total_docs }} document{{ '' if total_docs == 1 else 's' }} · manual_review
      </div>
    </header>

    {% if not attention %}
      <div class="empty">Pipeline clear<span class="copy">No documents awaiting manual review.</span></div>
    {% else %}
      <div class="attention-cards">
        {% for g in attention %}
          <article class="attention-card band-{{ g.fraud_band }}">
            <header class="card-head">
              <div class="card-title">
                {% if g.merchant_id %}<a href="/ui/merchants/{{ g.merchant_id }}">{{ g.merchant_label }}</a>{% else %}<span class="card-title-text">{{ g.merchant_label }}</span>{% endif %}
                <span class="card-sub">
                  {% if g.merchant_state %}{{ g.merchant_state }}{% endif %}{% if g.merchant_naics %} · {{ g.merchant_naics }}{% endif %}{% if g.requested_amount %} · Requested ${{ g.requested_amount }}{% endif %}
                </span>
              </div>
              <div class="card-meta">
                <div class="card-score {% if g.fraud_band == 'decline' %}bad{% elif g.fraud_band == 'review' %}warn{% elif g.fraud_band == 'clear' %}calm{% endif %}">
                  {% if g.worst_fraud_score is number %}{{ g.worst_fraud_score }}<span class="of">/100</span>{% else %}—{% endif %}
                  <span class="card-score-label">worst fraud</span>
                </div>
                {% if g.tier %}
                  <span class="card-tier tier-{{ g.tier|lower }}" title="Deal tier from score_deal on worst-scoring document">{{ g.tier }}<span class="card-tier-label">tier</span></span>
                {% endif %}
              </div>
            </header>

            {# Decline-class signals row — ALWAYS present so workers see
               at a glance whether the card has dealbreakers. Empty state
               renders muted ("(none)") to read as quiet confirmation, not
               as missing data. #}
            <div class="card-decline-row {% if g.flags.decline_class %}is-active{% else %}is-empty{% endif %}">
              {% if g.flags.decline_class %}
                <div class="card-section-head card-section-head-decline">Decline-class · {{ g.flags.decline_class|length }}</div>
                <div class="card-flag-list">
                  {% for hf in g.flags.decline_class %}{% include "_humanized_chip.html.j2" %}{% endfor %}
                </div>
              {% else %}
                <div class="card-section-head card-section-head-empty">Decline-class · <span class="card-section-empty-text">(none)</span></div>
              {% endif %}
            </div>

            {# Category groups in fixed display order — only non-empty
               render. Each group gets its glossary label as a small-caps
               heading. #}
            {% for category_name, category_flags in g.flags.by_category.items() %}
              <div class="card-category">
                <div class="card-section-head">{{ category_labels.get(category_name, category_name) }}</div>
                <div class="card-flag-list">
                  {% for hf in category_flags %}{% include "_humanized_chip.html.j2" %}{% endfor %}
                </div>
              </div>
            {% endfor %}

            <div class="card-docs-section">
              <div class="card-section-head">Documents · {{ g.doc_count }}</div>
              <ul class="card-docs">
                {% for d in g.documents %}
                  <li class="card-doc">
                    <span class="doc-id">doc · {{ d.document_id[:8] }}</span>
                    <span class="doc-score {% if d.fraud_score is number and d.fraud_score >= 65 %}bad{% elif d.fraud_score is number and d.fraud_score >= 35 %}warn{% elif d.fraud_score is number %}calm{% endif %}">
                      {% if d.fraud_score is number %}{{ d.fraud_score }}<span class="of">/100</span>{% else %}—{% endif %}
                    </span>
                    <span class="doc-uploaded">{{ d.uploaded_at }}</span>
                    <a class="doc-review" href="/ui/documents/{{ d.document_id }}">open document ↗</a>
                  </li>
                {% endfor %}
              </ul>
            </div>
          </article>
        {% endfor %}
      </div>
    {% endif %}

    <header class="sect-head" style="margin-top:32px">
      <h2>Pipeline funnel</h2>
      <div class="rule"></div>
      <div class="meta">parse_status + audit_log</div>
    </header>
    <div class="funnel">
      {% for row in funnel_rows %}
        <div class="row">
          <span>{{ row.label }}</span>
          <div class="bar"><div class="fill {{ row.cls }}" style="width:{{ row.width }}%"></div></div>
          <span class="n">{{ row.count }}</span>
        </div>
      {% endfor %}
    </div>
  </div>

  <aside>
    <header class="sect-head">
      <h2>Day's log</h2>
      <div class="rule"></div>
      <div class="meta">last {{ recent_activity|length }}</div>
    </header>
    <div class="feed">
      {% if not recent_activity %}
        <div class="empty" style="padding:20px 0">No activity logged yet.</div>
      {% else %}
        {% for r in recent_activity %}
          <div class="event">
            <div class="t">{{ r.time_short }}</div>
            <div class="txt">
              <strong>{{ r.actor }}</strong> {{ r.action }}{% if r.subject_type %}<span class="mono-inline">· {{ r.subject_type }}{% if r.subject_id %}/{{ r.subject_id[:8] }}{% endif %}</span>{% endif %}
            </div>
          </div>
        {% endfor %}
      {% endif %}
    </div>

    <header class="sect-head" style="margin-top:28px">
      <h2>Jump to</h2>
      <div class="rule"></div>
    </header>
    <div class="feed">
      <div class="event"><div class="t">→</div><div class="txt"><a href="/ui/upload"><strong>Upload</strong> bank statement (PDF)</a></div></div>
      <div class="event"><div class="t">→</div><div class="txt"><a href="/ui/intake"><strong>Intake</strong> new merchant</a></div></div>
      <div class="event"><div class="t">→</div><div class="txt"><a href="/ui/deals"><strong>Deals</strong> live pipeline</a></div></div>
      <div class="event"><div class="t">→</div><div class="txt"><a href="/ui/merchants"><strong>Merchants</strong> directory</a></div></div>
      <div class="event"><div class="t">→</div><div class="txt"><a href="/ui/funders"><strong>Funders</strong> criteria + matching</a></div></div>
      <div class="event"><div class="t">→</div><div class="txt"><a href="/ui/review"><strong>Review</strong> manual queue</a></div></div>
    </div>
  </aside>

</section>
{% endblock %}
