{% extends "base.html.j2" %}
{% set active = 'Portfolio' %}
{% block title %}Portfolio — AEGIS{% endblock %}

{# Portfolio analytics view (M11 / U11).

   Read-only aggregations over existing tables. Math lives in
   ``aegis.deals.portfolio_analytics.compute_portfolio_metrics``; this
   template only renders.

   Surface contract: the route handler populates ``metrics``
   (``PortfolioMetrics``) and ``now``. The model fields are documented
   inline in portfolio_analytics.py — every percentage that may be
   ``None`` renders as an em-dash so the operator never reads a
   manufactured 0%.
#}

{% block deck %}
{% set title = "Portfolio" %}
{% set subtitle = "· outcomes" %}
{% set meta %}
  From {{ metrics.from_date.isoformat() }} to {{ metrics.to_date.isoformat() }}
  &nbsp;·&nbsp;
  {{ metrics.total_deals }} scored deal{{ '' if metrics.total_deals == 1 else 's' }}
{% endset %}
{% set actions = [
  {"label": "Today", "href": "/ui/"},
  {"label": "Deals", "href": "/ui/deals"},
] %}
{% include "_page_header.html.j2" %}

{# Date-range form — GET so the URL stays bookmarkable + stays out of
   POST audit lanes. PII never lands in the query string by construction:
   the only params are ``from`` and ``to`` (date strings). #}
<form method="get" action="/ui/portfolio" class="inline-form" style="margin: 0.5rem 0 1rem;">
  <label class="sub" for="portfolio_from">From</label>
  <input type="date" id="portfolio_from" name="from" value="{{ metrics.from_date.isoformat() }}">
  <label class="sub" for="portfolio_to">To</label>
  <input type="date" id="portfolio_to" name="to" value="{{ metrics.to_date.isoformat() }}">
  <button type="submit">Apply</button>
</form>

<section class="strip">
  <div class="cell">
    <div class="k">Scored deals</div>
    <div class="v">{{ metrics.total_deals }}</div>
  </div>
  <div class="cell">
    <div class="k">Approval rate</div>
    <div class="v {{ 'calm' if metrics.approval_rate_pct is not none and metrics.approval_rate_pct >= 50 else '' }}">
      {% if metrics.approval_rate_pct is not none %}{{ metrics.approval_rate_pct }}%{% else %}—{% endif %}
    </div>
  </div>
  <div class="cell">
    <div class="k">Decline rate</div>
    <div class="v {{ 'bad' if metrics.decline_rate_pct is not none and metrics.decline_rate_pct >= 50 else '' }}">
      {% if metrics.decline_rate_pct is not none %}{{ metrics.decline_rate_pct }}%{% else %}—{% endif %}
    </div>
  </div>
  <div class="cell">
    <div class="k">Median tier</div>
    <div class="v">{% if metrics.avg_tier %}{{ metrics.avg_tier }}{% else %}—{% endif %}</div>
  </div>
  <div class="cell">
    <div class="k">Fraud catches</div>
    <div class="v {{ 'warn' if metrics.fraud_catch_count > 0 else '' }}">
      {{ metrics.fraud_catch_count }}<span class="sub"> / {{ metrics.fraud_total_scored }}</span>
    </div>
  </div>
  <div class="cell">
    <div class="k">Catch rate</div>
    <div class="v">
      {% if metrics.fraud_catch_rate_pct is not none %}{{ metrics.fraud_catch_rate_pct }}%{% else %}—{% endif %}
    </div>
  </div>
  {# Disclosure render queue tile (U21). Counts ``needs_review`` +
     ``apr_compute_failed`` events in the same window; the "Triage →"
     link routes to /ui/disclosure-events for the per-row triage page.
     Two-line breakdown so the operator sees which bucket needs
     attention at a glance. #}
  <div class="cell">
    <div class="k">Disclosure render queue</div>
    <div class="v {{ 'warn' if metrics.disclosure_render_queue.actionable_count > 0 else '' }}">
      {{ metrics.disclosure_render_queue.actionable_count }}<span class="sub"> / {{ metrics.disclosure_render_queue.total_in_window }}</span>
    </div>
    <div class="sub">
      needs_review {{ metrics.disclosure_render_queue.needs_review_count }}
      · apr_failed {{ metrics.disclosure_render_queue.apr_compute_failed_count }}
      · <a href="/ui/disclosure-events">Triage →</a>
    </div>
  </div>
</section>
{% endblock %}

{% block body %}
<section class="body cols-1">

  {# Pipeline state — derived bucket counts. The empty-pipeline branch
     surfaces the honest message instead of zeros so the operator
     doesn't read it as "we have data". #}
  <div>
    <header class="sect-head">
      <h2>Pipeline state</h2>
      <div class="rule"></div>
      <div class="meta">n = {{ metrics.pipeline.total }} merchant{{ '' if metrics.pipeline.total == 1 else 's' }}</div>
    </header>
    {% if metrics.pipeline.total == 0 %}
      <div class="empty">No submissions tracked yet. Submit a deal to a funder to start tracking outcomes.</div>
    {% else %}
      <table class="queue">
        <thead>
          <tr>
            <th>State</th>
            <th class="num">Merchants</th>
            <th>Description</th>
          </tr>
        </thead>
        <tbody>
          <tr><td><span class="chip info">NEW</span></td><td class="mono-cell" style="text-align:right">{{ metrics.pipeline.new }}</td><td class="sub">No statement uploaded yet or just-pending parse.</td></tr>
          <tr><td><span class="chip info">IN REVIEW</span></td><td class="mono-cell" style="text-align:right">{{ metrics.pipeline.in_review }}</td><td class="sub">Parsed, awaiting submission.</td></tr>
          <tr><td><span class="chip pos">APPROVED</span></td><td class="mono-cell" style="text-align:right">{{ metrics.pipeline.approved }}</td><td class="sub">Submitted to at least one funder.</td></tr>
          <tr><td><span class="chip neg">DECLINED</span></td><td class="mono-cell" style="text-align:right">{{ metrics.pipeline.declined }}</td><td class="sub">Latest doc landed in manual_review / error.</td></tr>
          <tr><td><span class="chip pos">FUNDED</span></td><td class="mono-cell" style="text-align:right">{{ metrics.pipeline.funded }}</td><td class="sub">Audit log shows a deal.funded event.</td></tr>
          <tr><td><span class="chip warn">ABANDONED</span></td><td class="mono-cell" style="text-align:right">{{ metrics.pipeline.abandoned }}</td><td class="sub">Stale provisional / no follow-up for 30+ days.</td></tr>
        </tbody>
      </table>
    {% endif %}
  </div>

  {# Approval rate by funder — read straight from funder_replies +
     deal.submit_to_funders audit rows. #}
  <div>
    <header class="sect-head">
      <h2>Approval rate by funder</h2>
      <div class="rule"></div>
      <div class="meta">{{ metrics.funder_table|length }} funder{{ '' if metrics.funder_table|length == 1 else 's' }} with activity in window</div>
    </header>
    {% if not metrics.funder_table %}
      <div class="empty">No submissions or replies in this window<span class="copy">Send a packet via the merchant dossier to populate this table.</span></div>
    {% else %}
      <table class="queue">
        <thead>
          <tr>
            <th>Funder</th>
            <th class="num">Submitted</th>
            <th class="num">Approved</th>
            <th class="num">Declined</th>
            <th class="num">Countered</th>
            <th class="num">No response</th>
            <th class="num">Pending</th>
            <th class="num">Accept rate</th>
          </tr>
        </thead>
        <tbody>
          {% for row in metrics.funder_table %}
            <tr>
              <td class="merchant">
                <a href="/ui/funders/{{ row.funder_id }}">{{ row.funder_name }}</a>
              </td>
              <td class="mono-cell" style="text-align:right">{{ row.submitted }}</td>
              <td class="mono-cell" style="text-align:right">{{ row.approved }}</td>
              <td class="mono-cell" style="text-align:right">{{ row.declined }}</td>
              <td class="mono-cell" style="text-align:right">{{ row.countered }}</td>
              <td class="mono-cell" style="text-align:right">{{ row.no_response }}</td>
              <td class="mono-cell" style="text-align:right">{{ row.pending }}</td>
              <td class="mono-cell" style="text-align:right">
                {% if row.approval_rate_pct is not none %}{{ row.approval_rate_pct }}%{% else %}—{% endif %}
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    {% endif %}
  </div>

  {# Decisions by tier — count of deal.score audit rows per tier
     letter. The row reads "tier counts", not "tier rate" — operators
     are after the raw distribution. #}
  <div>
    <header class="sect-head">
      <h2>Decisions by tier</h2>
      <div class="rule"></div>
      <div class="meta">n = {{ metrics.tier_counts.total }} scored deal{{ '' if metrics.tier_counts.total == 1 else 's' }}</div>
    </header>
    {% if metrics.tier_counts.total == 0 %}
      <div class="empty">No deals scored in this window<span class="copy">Score a deal from the merchant dossier to populate this panel.</span></div>
    {% else %}
      <table class="queue">
        <thead>
          <tr><th>Tier</th><th class="num">Count</th><th>Share</th></tr>
        </thead>
        <tbody>
          {% for tier, count in metrics.tier_counts.as_ordered() %}
            <tr>
              <td><span class="chip {{ 'pos' if tier in ['A', 'B'] else ('warn' if tier == 'C' else 'neg') }}">{{ tier }}</span></td>
              <td class="mono-cell" style="text-align:right">{{ count }}</td>
              <td class="sub">
                {% if metrics.tier_counts.total > 0 %}
                  {{ ((count / metrics.tier_counts.total) * 100) | round | int }}%
                {% else %}—{% endif %}
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    {% endif %}
  </div>

  {# Decisions by state — top 10 states by deal count. #}
  <div>
    <header class="sect-head">
      <h2>Decisions by state</h2>
      <div class="rule"></div>
      <div class="meta">top {{ metrics.state_counts|length }} state{{ '' if metrics.state_counts|length == 1 else 's' }}</div>
    </header>
    {% if not metrics.state_counts %}
      <div class="empty">No scored deals to break down by state<span class="copy">Set the merchant state on the dossier so this table populates.</span></div>
    {% else %}
      <table class="queue">
        <thead>
          <tr><th>State</th><th class="num">Deals</th></tr>
        </thead>
        <tbody>
          {% for row in metrics.state_counts %}
            <tr>
              <td class="mono-cell">{{ row.state }}</td>
              <td class="mono-cell" style="text-align:right">{{ row.count }}</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    {% endif %}
  </div>

  {# Recent activity — last 20 scored deals. PII (business_name)
     surfaces here per the existing dashboard pattern. #}
  <div>
    <header class="sect-head">
      <h2>Recent activity</h2>
      <div class="rule"></div>
      <div class="meta">last {{ metrics.recent_activity|length }} scoring event{{ '' if metrics.recent_activity|length == 1 else 's' }}</div>
    </header>
    {% if not metrics.recent_activity %}
      <div class="empty">No scoring events in this window<span class="copy">Score a deal to populate this table.</span></div>
    {% else %}
      <table class="queue">
        <thead>
          <tr>
            <th>Merchant</th>
            <th>Tier</th>
            <th>Recommendation</th>
            <th>Scored at</th>
          </tr>
        </thead>
        <tbody>
          {% for row in metrics.recent_activity %}
            <tr>
              <td class="merchant">
                {% if row.merchant_id %}
                  <a href="/ui/merchants/{{ row.merchant_id }}">{{ row.business_name }}</a>
                {% else %}
                  {{ row.business_name }}
                {% endif %}
              </td>
              <td>
                {% if row.tier %}
                  <span class="chip {{ 'pos' if row.tier in ['A', 'B'] else ('warn' if row.tier == 'C' else 'neg') }}">{{ row.tier }}</span>
                {% else %}
                  <span class="mono-cell">—</span>
                {% endif %}
              </td>
              <td class="sub">{{ row.recommendation or '—' }}</td>
              <td class="mono-cell">
                {% if row.scored_at %}{{ row.scored_at.strftime('%Y-%m-%d %H:%M') }}{% else %}—{% endif %}
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    {% endif %}
  </div>

  {# ============== Sprint 3 — funder_note_submissions analytics ============== #}
  {% if sprint3_metrics %}
  <div class="card" data-test-id="sprint3-portfolio">
    <h3>Submissions intelligence
      <span class="footnote">funder_note_submissions · 90-day window</span>
    </h3>

    <div class="kpi-row" style="display:flex;gap:24px;flex-wrap:wrap;margin:14px 0;font-size:13px">
      <div data-test-id="sprint3-monthly">
        <div class="sub" style="text-transform:uppercase;letter-spacing:0.08em;font-size:11px;color:var(--ink-3)">Deals submitted</div>
        <div style="font-size:22px;font-weight:600">{{ sprint3_metrics.deals_this_month }}</div>
        <div class="sub">this month
          {% if sprint3_metrics.deals_month_delta_pct is not none %}
            · <strong>{{ '+' if sprint3_metrics.deals_month_delta_pct > 0 }}{{ sprint3_metrics.deals_month_delta_pct }}%</strong> vs last month ({{ sprint3_metrics.deals_last_month }})
          {% else %}
            · {{ sprint3_metrics.deals_last_month }} last month
          {% endif %}
        </div>
      </div>
      <div data-test-id="sprint3-tier-breakdown">
        <div class="sub" style="text-transform:uppercase;letter-spacing:0.08em;font-size:11px;color:var(--ink-3)">Tier breakdown</div>
        <div style="display:flex;gap:8px;margin-top:4px;align-items:baseline">
          {% for letter in ['A', 'B', 'C', 'D', 'F', 'unknown'] %}
            {% set count = sprint3_metrics.tier_breakdown.get(letter, 0) %}
            {% if count > 0 %}
              <span class="chip {% if letter == 'A' %}pos{% elif letter == 'F' %}neg{% endif %}"
                    data-tier="{{ letter }}">
                {{ letter }} · {{ count }}
              </span>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    </div>

    {# Monthly submission volume — trailing 6 months, inline-CSS bar
       chart. Each bar's height scales to ``monthly_peak`` (computed in
       the route) so the operator reads the same axis across months.
       No JS, no chart library — divs + inline width-style only. The
       zero-bar branch renders the friendly empty state instead of six
       flat zeros so the operator doesn't think the chart is broken. #}
    <h4 style="margin-top:18px">Monthly submission volume
      <span class="footnote">last {{ sprint3_metrics.monthly_volume_last_6|length }} calendar months</span>
    </h4>
    {% set total_in_chart = sprint3_metrics.monthly_volume_last_6|sum(attribute='count') %}
    {% if total_in_chart == 0 %}
      <p class="sub">No submissions in the last {{ sprint3_metrics.monthly_volume_last_6|length }} months. Submit a deal from the merchant dossier to populate this chart.</p>
    {% else %}
      <div class="bar-chart" data-test-id="sprint3-monthly-bars"
           style="display:flex;align-items:flex-end;gap:8px;height:120px;margin:8px 0 4px;padding:4px 0;border-bottom:1px solid var(--ink-3)">
        {% for bar in sprint3_metrics.monthly_volume_last_6 %}
          {% set height_pct = (bar.count / monthly_peak * 100) | round | int %}
          <div style="flex:1 1 0;display:flex;flex-direction:column;align-items:center;justify-content:flex-end;height:100%;min-width:24px"
               data-month="{{ bar.month_label }}"
               data-count="{{ bar.count }}"
               title="{{ bar.month_label }}: {{ bar.count }} submission{{ '' if bar.count == 1 else 's' }}">
            <div class="mono-cell" style="font-size:11px;color:var(--ink-3);margin-bottom:2px">{{ bar.count }}</div>
            <div style="width:100%;background:var(--accent, #4a90e2);height:{{ height_pct if bar.count > 0 else 0 }}%;min-height:{{ 2 if bar.count > 0 else 0 }}px;border-radius:2px 2px 0 0"></div>
          </div>
        {% endfor %}
      </div>
      <div style="display:flex;gap:8px;font-size:11px;color:var(--ink-3);margin-bottom:6px">
        {% for bar in sprint3_metrics.monthly_volume_last_6 %}
          <div class="mono-cell" style="flex:1 1 0;text-align:center;min-width:24px">{{ bar.month_label }}</div>
        {% endfor %}
      </div>
    {% endif %}

    {# AEGIS score tier breakdown — current calendar month only. The
       existing tile (above, in the KPI row) covers the cumulative
       90-day window; this panel restricts to the month containing
       ``now`` so the operator sees what just landed. #}
    <h4 style="margin-top:18px">AEGIS score tier breakdown
      <span class="footnote">submitted deals this month</span>
    </h4>
    {% set total_this_month = sprint3_metrics.tier_breakdown_this_month.values()|sum %}
    {% if total_this_month == 0 %}
      <p class="sub">No submissions yet this calendar month.</p>
    {% else %}
      <div data-test-id="sprint3-tier-breakdown-this-month"
           style="display:flex;gap:8px;flex-wrap:wrap;margin:6px 0 10px">
        {% for letter in ['A', 'B', 'C', 'D', 'F', 'unknown'] %}
          {% set count = sprint3_metrics.tier_breakdown_this_month.get(letter, 0) %}
          {% if count > 0 %}
            <span class="chip {% if letter == 'A' %}pos{% elif letter == 'B' %}pos{% elif letter == 'C' %}warn{% elif letter == 'F' %}neg{% endif %}"
                  data-tier="{{ letter }}">
              {{ letter }} · {{ count }}
            </span>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}

    <h4 style="margin-top:14px">Approval rate per funder</h4>
    {% if not sprint3_metrics.approval_rate_per_funder %}
      <p class="sub">No submissions in the last 90 days.</p>
    {% else %}
      <table class="ledger" data-test-id="sprint3-funder-table">
        <thead>
          <tr>
            <th>Funder</th>
            <th class="num">Submitted</th>
            <th class="num">Approved</th>
            <th class="num">Declined</th>
            <th class="num">Countered</th>
            <th class="num">Pending</th>
            <th class="num">Approval rate</th>
            <th class="num">Avg response</th>
          </tr>
        </thead>
        <tbody>
          {% for row in sprint3_metrics.approval_rate_per_funder %}
            {% set funder_key = row.funder_id|string %}
            {% set funder_name = funder_name_by_id.get(funder_key) %}
            <tr data-funder-id="{{ row.funder_id }}">
              <td>
                <a href="/ui/funders/{{ row.funder_id }}/performance">{% if funder_name %}{{ funder_name }}{% else %}{{ funder_key|truncate(8, True, '') }}{% endif %}</a>
              </td>
              <td class="mono-cell" style="text-align:right">{{ row.submitted }}</td>
              <td class="mono-cell" style="text-align:right">{{ row.approved }}</td>
              <td class="mono-cell" style="text-align:right">{{ row.declined }}</td>
              <td class="mono-cell" style="text-align:right">{{ row.countered }}</td>
              <td class="mono-cell" style="text-align:right">{{ row.pending }}</td>
              <td class="mono-cell" style="text-align:right">
                {% if row.approval_rate_pct is not none %}{{ row.approval_rate_pct }}%{% else %}—{% endif %}
              </td>
              <td class="mono-cell" style="text-align:right">
                {% if row.avg_response_hours is not none %}
                  {% if row.avg_response_hours < 48 %}{{ row.avg_response_hours }}h{% else %}{{ (row.avg_response_hours / 24)|round(1) }}d{% endif %}
                {% else %}—{% endif %}
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    {% endif %}

    <div style="display:flex;gap:32px;margin-top:14px;flex-wrap:wrap">
      <div style="min-width:280px;flex:1">
        <h4>Top industries by volume</h4>
        {% if not sprint3_metrics.top_industries_by_volume %}
          <p class="sub">No submissions in the last 90 days.</p>
        {% else %}
          <table class="ledger" data-test-id="sprint3-industry-volume">
            <thead><tr><th>Industry</th><th class="num">Submitted</th></tr></thead>
            <tbody>
              {% for row in sprint3_metrics.top_industries_by_volume %}
                <tr><td>{{ row.industry }}</td><td class="mono-cell" style="text-align:right">{{ row.submitted }}</td></tr>
              {% endfor %}
            </tbody>
          </table>
        {% endif %}
      </div>
      <div style="min-width:280px;flex:1">
        <h4>Top industries by decline rate</h4>
        {% if not sprint3_metrics.top_industries_by_decline_rate %}
          <p class="sub">No industry with ≥3 submissions in the last 90 days.</p>
        {% else %}
          <table class="ledger" data-test-id="sprint3-industry-decline">
            <thead><tr><th>Industry</th><th class="num">Submitted</th><th class="num">Declined</th><th class="num">Decline %</th></tr></thead>
            <tbody>
              {% for row in sprint3_metrics.top_industries_by_decline_rate %}
                <tr>
                  <td>{{ row.industry }}</td>
                  <td class="mono-cell" style="text-align:right">{{ row.submitted }}</td>
                  <td class="mono-cell" style="text-align:right">{{ row.declined }}</td>
                  <td class="mono-cell" style="text-align:right">
                    {% if row.decline_rate_pct is not none %}{{ row.decline_rate_pct }}%{% else %}—{% endif %}
                  </td>
                </tr>
              {% endfor %}
            </tbody>
          </table>
        {% endif %}
      </div>
    </div>

    <h4 style="margin-top:14px">Stale merchants — no activity in 30+ days</h4>
    {% if not sprint3_metrics.stale_merchants %}
      <p class="sub">No stale merchants. Every finalized merchant has recent activity.</p>
    {% else %}
      <table class="ledger" data-test-id="sprint3-stale">
        <thead>
          <tr>
            <th>Merchant</th>
            <th>State</th>
            <th class="num">Days since activity</th>
            <th>Last activity</th>
          </tr>
        </thead>
        <tbody>
          {% for row in sprint3_metrics.stale_merchants %}
            <tr data-merchant-id="{{ row.merchant_id }}">
              <td><a href="/ui/merchants/{{ row.merchant_id }}">{{ row.business_name }}</a></td>
              <td>{{ row.state or '—' }}</td>
              <td class="mono-cell" style="text-align:right">
                {% if row.days_since_activity is not none %}{{ row.days_since_activity }}{% else %}—{% endif %}
              </td>
              <td class="mono-cell">
                {% if row.last_activity_at %}{{ row.last_activity_at.strftime('%Y-%m-%d') }}{% else %}never{% endif %}
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    {% endif %}
  </div>
  {% endif %}

</section>
{% endblock %}
