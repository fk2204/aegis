{# Compliance ribbon for the merchant findings panel.

  Inputs:
    - merchant: MerchantRow
    - state_tier: 1 | 2 | 3 | "unserved"
    - ofac_status: "checked" | "stale" | "unavailable" | "not_consulted"
    - ofac_match: bool | None
#}
<div style="display:flex;flex-wrap:wrap;gap:6px">
  {% if state_tier == 1 %}
    <span class="tag pos"><span class="dot"></span>State: {{ merchant.state }} · Tier 1</span>
  {% elif state_tier == 2 %}
    <span class="tag accent"><span class="dot"></span>State: {{ merchant.state }} · Tier 2</span>
  {% elif state_tier == 3 %}
    <span class="tag warn"><span class="dot"></span>State: {{ merchant.state }} · Tier 3 unaudited</span>
  {% else %}
    <span class="tag neg"><span class="dot"></span>State: {{ merchant.state }} · NOT SERVED</span>
  {% endif %}

  {% if ofac_status == 'checked' and ofac_match %}
    <span class="tag neg"><span class="dot"></span>OFAC: MATCH (decline)</span>
  {% elif ofac_status == 'checked' %}
    <span class="tag pos"><span class="dot"></span>OFAC: clear</span>
  {% elif ofac_status == 'stale' %}
    <span class="tag warn"><span class="dot"></span>OFAC: stale cache</span>
  {% elif ofac_status == 'unavailable' %}
    <span class="tag warn"><span class="dot"></span>OFAC: unavailable</span>
  {% else %}
    <span class="tag"><span class="dot"></span>OFAC: not consulted</span>
  {% endif %}

  {% if merchant.is_renewal %}
    <span class="tag accent"><span class="dot"></span>Renewal</span>
  {% endif %}

  {% if merchant.broker_source %}
    <span class="tag"><span class="dot"></span>Source: {{ merchant.broker_source }}</span>
  {% endif %}

  {% if merchant.intake_date %}
    <span class="tag"><span class="dot"></span>Intake {{ merchant.intake_date }}</span>
  {% endif %}
</div>
