{% extends "base.html.j2" %}
{% set active = 'Merchants' %}
{% block title %}{{ merchant.business_name }} — AEGIS{% endblock %}

{% block subhead %}
<div class="deal-head">
  <div class="merch">
    <span class="merch-mark" style="width:48px;height:48px;font-size:16px">{{ merchant.business_name[:2]|upper }}</span>
  </div>
  <div>
    <div class="id">{{ merchant.id|string|truncate(8, True, '') }}</div>
    <h2>{{ merchant.business_name }}</h2>
    <div class="meta-row">
      <span><span class="lbl">Owner</span>{{ merchant.owner_name }}</span>
      <span><span class="lbl">State</span>{{ merchant.state }}</span>
      {% if merchant.industry_naics %}<span><span class="lbl">NAICS</span>{{ merchant.industry_naics }}</span>{% endif %}
      {% if merchant.entity_type %}<span><span class="lbl">Entity</span>{{ merchant.entity_type }}</span>{% endif %}
      {% if merchant.zoho_lead_id %}<span><span class="lbl">Zoho lead</span>{{ merchant.zoho_lead_id }}</span>{% endif %}
      {% if merchant.zoho_deal_id %}<span><span class="lbl">Zoho deal</span>{{ merchant.zoho_deal_id }}</span>{% endif %}
      {% if merchant.submitted_to_funder_ids %}<span><span class="lbl">Submitted</span>{{ merchant.submitted_to_funder_ids|length }} funder{{ '' if merchant.submitted_to_funder_ids|length == 1 else 's' }}{% if merchant.last_submitted_at %} · {{ merchant.last_submitted_at.strftime('%Y-%m-%d %H:%M') }}{% endif %}</span>{% endif %}
    </div>
  </div>
  <div style="display:flex;gap:8px;align-items:flex-start;flex-wrap:wrap">
    <a class="btn" href="/ui/merchants/{{ merchant.id }}/edit">Edit</a>
    <a class="btn btn-primary" href="/ui/merchants/{{ merchant.id }}/match">Match funders</a>
    <a class="btn" href="/ui/merchants/{{ merchant.id }}/findings.csv" title="Auditor-internal CSV with full source-id traceability">Download audit CSV</a>
  </div>
</div>
{% endblock %}

{% block body %}
<div class="body cols-1">
  <main class="main">
    {% if from_intake %}
      <div class="panel" style="border-color:color-mix(in oklch, var(--pos) 30%, var(--line));background:var(--pos-soft);margin-bottom:14px">
        <div class="panel-head" style="background:transparent">
          <span class="panel-title" style="color:var(--pos)">Merchant created · what's next</span>
          <span class="panel-actions mono" style="color:var(--pos)">
            {% if intake_docs_uploaded == 0 %}no statements uploaded yet
            {% elif intake_docs_uploaded == 1 %}1 statement queued for parsing
            {% else %}{{ intake_docs_uploaded }} statements queued for parsing{% endif %}
            {% if intake_docs_failed > 0 %} · {{ intake_docs_failed }} failed{% endif %}
          </span>
        </div>
        <div class="panel-body" style="background:transparent">
          <div style="font-size:12.5px;margin-bottom:10px;color:var(--ink-2)">
            {% if intake_docs_uploaded > 0 %}
              <strong>{{ merchant.business_name }}</strong> was created and {{ intake_docs_uploaded }} statement{{ '' if intake_docs_uploaded == 1 else 's' }} {{ 'is' if intake_docs_uploaded == 1 else 'are' }} now in the parsing queue. Parsing typically completes in 30-90 seconds per document. Refresh this page to see parse status, fraud score, and pattern analysis fill in.
            {% else %}
              <strong>{{ merchant.business_name }}</strong> was created. No statements were uploaded at intake — upload one now to score the deal and match funders.
            {% endif %}
            {% if intake_docs_failed > 0 %}
              <br><span style="color:var(--neg)">{{ intake_docs_failed }} file{{ '' if intake_docs_failed == 1 else 's' }} failed to upload — retry from the upload page.</span>
            {% endif %}
          </div>
          <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center">
            {% if intake_docs_uploaded > 0 %}
              <a class="btn btn-primary" href="/ui/merchants/{{ merchant.id }}/match">Match funders →</a>
            {% endif %}
            <a class="btn{% if intake_docs_uploaded == 0 %} btn-primary{% endif %}" href="/ui/upload">Upload statements{% if intake_docs_failed > 0 %} (retry){% endif %}</a>
            <a class="btn" href="/ui/merchants/{{ merchant.id }}/edit">Edit merchant</a>
            <a class="btn" href="/ui/intake">+ Another intake</a>
          </div>
        </div>
      </div>
    {% endif %}

    <div class="panel">
      <div class="panel-head">
        <span class="panel-title">Compliance ribbon</span>
      </div>
      <div class="panel-body">
        {% include "_compliance_ribbon.html.j2" %}
      </div>
    </div>

    {% if score_window %}
      <div class="panel">
        <div class="panel-head">
          <span class="panel-title">Scoring window</span>
          <span class="panel-actions mono">{{ score_window.months_used }} statement{{ '' if score_window.months_used == 1 else 's' }} · {{ score_window.period_start }} → {{ score_window.period_end }}</span>
        </div>
        <div class="panel-body" style="display:flex;gap:14px;flex-wrap:wrap;font-size:12px;color:var(--muted)">
          {% if score_window.months_used == 1 %}
            <span class="tag warn" style="font-size:11px"><span class="dot"></span>single-month score — trend not visible until more statements upload</span>
          {% else %}
            <span>Tier &amp; recommendation reflect the trailing {{ score_window.months_used }}-month window, not just the latest statement.</span>
          {% endif %}
          {% if score_window.any_manual_review %}
            <span class="tag neg" style="font-size:11px"><span class="dot"></span>{{ score_window.months_used }}-month window includes manual_review statements</span>
          {% endif %}
        </div>
      </div>
    {% endif %}

    {% if merchant.requested_amount or merchant.requested_factor or merchant.requested_term_days or merchant.credit_score or merchant.time_in_business_months %}
      <div class="panel">
        <div class="panel-head">
          <span class="panel-title">Underwriting target</span>
        </div>
        <div class="panel-body">
          <div class="kv">
            {% if merchant.requested_amount %}<span class="k">Requested</span><span class="v">{{ merchant.requested_amount | whole_money }}</span>{% endif %}
            {% if merchant.requested_factor %}<span class="k">Factor</span><span class="v">{{ merchant.requested_factor }}<span class="unit-hint">× payback</span></span>{% endif %}
            {% if merchant.requested_term_days %}<span class="k">Term</span><span class="v">{{ merchant.requested_term_days }} days</span>{% endif %}
            {% if merchant.credit_score %}<span class="k">Owner credit</span><span class="v">{{ merchant.credit_score }}<span class="unit-hint">FICO</span></span>{% endif %}
            {% if merchant.time_in_business_months %}<span class="k">TIB</span><span class="v">{{ merchant.time_in_business_months }}<span class="unit-hint">months</span></span>{% endif %}
          </div>
        </div>
      </div>
    {% endif %}

    {% if trend %}
      <div class="panel">
        <div class="panel-head">
          <span class="panel-title">Trend</span>
          <span class="panel-actions mono">across {{ trend.statement_count }} statements</span>
        </div>
        <div class="panel-body">
          <div class="kv">
            {% if trend.revenue_delta_pct is not none %}
              <span class="k">Revenue</span>
              <span class="v">{{ trend.revenue_latest }} vs {{ trend.revenue_prior }}
                <span style="color:{% if trend.revenue_delta_pct > 0 %}var(--pos){% else %}var(--neg){% endif %};margin-left:6px">
                  {{ '+' if trend.revenue_delta_pct > 0 }}{{ trend.revenue_delta_pct }}%
                </span>
              </span>
            {% endif %}
            {% if trend.nsf_delta is not none %}
              <span class="k">NSF</span>
              <span class="v">{{ trend.nsf_latest }} vs {{ trend.nsf_prior }}
                <span style="color:{% if trend.nsf_delta > 0 %}var(--neg){% else %}var(--pos){% endif %};margin-left:6px">
                  {{ '+' if trend.nsf_delta > 0 }}{{ trend.nsf_delta }}
                </span>
              </span>
            {% endif %}
            {% if trend.adb_delta_pct is not none %}
              <span class="k">ADB</span>
              <span class="v">{{ trend.adb_latest }} vs {{ trend.adb_prior }}
                <span style="color:{% if trend.adb_delta_pct > 0 %}var(--pos){% else %}var(--neg){% endif %};margin-left:6px">
                  {{ '+' if trend.adb_delta_pct > 0 }}{{ trend.adb_delta_pct }}%
                </span>
              </span>
            {% endif %}
          </div>
        </div>
      </div>
    {% endif %}

    <div class="panel">
      <div class="panel-head">
        <span class="panel-title">Documents</span>
        <span class="panel-actions mono">{{ documents|length }} statement{{ '' if documents|length == 1 else 's' }}</span>
      </div>
      <div class="panel-body flush">
        {% if not documents %}
          <div style="padding:24px;text-align:center;color:var(--muted)">
            <div style="font-size:13px;margin-bottom:4px">No documents uploaded yet.</div>
            <div style="font-size:12px"><a href="/ui/upload">Upload statements →</a></div>
          </div>
        {% else %}
          <div style="padding:6px 14px 0 14px;display:flex;gap:14px;flex-wrap:wrap;align-items:center">
            <span class="risk-band-legend" title="Risk bands mirror parse_status thresholds in parser.pipeline">
              <span class="mono" style="color:var(--muted);text-transform:uppercase;letter-spacing:0.05em;margin-right:4px">Fraud band:</span>
              <span><span class="swatch clear"></span>0-34 clear</span>
              <span><span class="swatch review"></span>35-64 review</span>
              <span><span class="swatch decline"></span>65-100 manual</span>
            </span>
            <span class="mono" style="font-size:10.5px;color:var(--muted)">money columns in USD · ADB = average daily balance · days neg = calendar days the balance went below $0</span>
          </div>
          <table class="data">
            <thead>
              <tr>
                <th>Period</th>
                <th>Status</th>
                <th class="num" title="Fraud score 0-100. Higher = riskier.">Fraud</th>
                <th class="num" title="Number of NSF (non-sufficient-funds) fees in the statement period.">NSF</th>
                <th class="num" title="Deposits net of transfers and chargebacks — operator-side revenue proxy.">True revenue</th>
                <th class="num" title="Average daily balance across the statement period.">ADB</th>
                <th class="num" title="Calendar days the running balance was below $0.">Days neg</th>
                <th>Uploaded</th>
              </tr>
            </thead>
            <tbody>
              {% for entry in documents %}
                {% set d = entry.document %}
                {% set a = entry.analysis %}
                {% set _cls = {
                  'proceed': 'pos',
                  'review': 'warn',
                  'manual_review': 'neg',
                  'error': 'neg',
                  'pending': '',
                  'no_upload': '',
                } %}
                <tr>
                  <td>
                    {% if a %}
                      <span class="mono" style="font-size:11.5px">{{ a.statement_period_start }} → {{ a.statement_period_end }}</span>
                    {% else %}
                      <span style="color:var(--muted);font-style:italic;font-size:11.5px">(not parsed)</span>
                    {% endif %}
                  </td>
                  <td><span class="tag {{ _cls.get(d.parse_status, '') }}"><span class="dot"></span>{{ d.parse_status }}</span></td>
                  <td class="num">
                    {% with score=d.fraud_score, compact=true %}
                      {% include "_fraud_score_chip.html.j2" %}
                    {% endwith %}
                  </td>
                  <td class="num">{{ a.num_nsf if a else '—' }}</td>
                  <td class="num">{{ (a.true_revenue if a else None) | whole_money }}</td>
                  <td class="num">{{ (a.avg_daily_balance if a else None) | whole_money }}</td>
                  <td class="num">{{ a.days_negative | days_label if a else '—' }}</td>
                  <td><span class="mono" style="font-size:11px;color:var(--muted)">{{ d.uploaded_at.strftime("%Y-%m-%d") }}</span></td>
                </tr>
                {% if d.parse_status in ('manual_review', 'review', 'error') and d.all_flags %}
                  <tr class="flag-detail-row">
                    <td colspan="8" style="padding:6px 14px 12px 14px;border-top:none">
                      <div style="display:flex;flex-wrap:wrap;gap:6px;align-items:center">
                        <span class="mono" style="font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:0.5px">why →</span>
                        {% for f in d.all_flags %}
                          <span class="tag {{ 'neg' if d.parse_status in ('manual_review','error') else 'warn' }}" style="font-size:10.5px;font-family:var(--mono)">{{ f }}</span>
                        {% endfor %}
                      </div>
                    </td>
                  </tr>
                {% endif %}
              {% endfor %}
            </tbody>
          </table>
        {% endif %}
      </div>
    </div>

    {% if document is not none %}
      {% set _cls = {
        'proceed': 'pos',
        'review': 'warn',
        'manual_review': 'neg',
        'error': 'neg',
        'pending': '',
        'no_upload': '',
      } %}
      <div class="panel">
        <div class="panel-head">
          <span class="panel-title">Latest aggregate detail</span>
          <span class="panel-actions">
            <span class="tag {{ _cls.get(document.parse_status, '') }}"><span class="dot"></span>{{ document.parse_status }}</span>
            {% if analysis %}<span class="mono" style="font-size:11px;color:var(--muted)">sha256 {{ document.file_hash[:12] }}…</span>{% endif %}
          </span>
        </div>
        <div class="panel-body">
          {% if analysis %}
            <div style="font-family:var(--mono);font-size:11px;color:var(--muted);margin-bottom:14px">
              {{ analysis.statement_period_start }} → {{ analysis.statement_period_end }}
              · {{ analysis.statement_days }} days
            </div>

            {% set agg_metrics = [
                ('true_revenue', analysis.true_revenue),
                ('avg_daily_balance', analysis.avg_daily_balance),
                ('num_nsf', analysis.num_nsf),
                ('days_negative', analysis.days_negative),
                ('mca_daily_total', analysis.mca_daily_total),
              ] %}

            <div class="kpi-row" style="grid-template-columns:repeat(5, 1fr)">
              {% for key, value in agg_metrics %}
                {% set _kind = aggregate_unit_kind.get(key, 'count') %}
                <div class="kpi">
                  <div class="label">{{ aggregate_labels[key] }}</div>
                  <div class="value">
                    {% if _kind == 'money' %}{{ value | whole_money }}
                    {% elif _kind == 'days' %}{{ value | days_label }}
                    {% else %}{{ value if value is not none else '—' }}
                    {% endif %}
                  </div>
                  <div class="delta" style="font-size:10.5px;color:var(--muted)">
                    {% if _kind == 'money' %}USD · sourced from {{ key | replace('_', ' ') }}
                    {% elif _kind == 'days' %}calendar days
                    {% elif key == 'num_nsf' %}non-sufficient-funds fee count
                    {% else %}{{ key | replace('_', ' ') }}
                    {% endif %}
                  </div>
                  <div class="delta">
                    <button class="btn" style="padding:3px 8px;font-size:11px;margin-top:4px"
                            hx-get="/ui/documents/{{ document.id }}/aggregate/{{ key }}"
                            hx-target="#drilldown"
                            hx-swap="innerHTML">drill down</button>
                  </div>
                </div>
              {% endfor %}
            </div>

            <div id="drilldown" style="margin-top:14px"></div>
          {% else %}
            <div style="padding:16px;text-align:center;color:var(--muted);font-size:12px">
              Document is parsing or no analysis is available yet.
            </div>
          {% endif %}
        </div>
      </div>

      {% if analysis %}
        <div class="panel">
          <div class="panel-head">
            <span class="panel-title">Score breakdown</span>
          </div>
          <div class="panel-body">
            {% include "_score_breakdown.html.j2" %}
          </div>
        </div>

        <div class="panel">
          <div class="panel-head">
            <span class="panel-title">MCA stacking</span>
          </div>
          <div class="panel-body{% if stacking is none %}{% else %} flush{% endif %}">
            {% if stacking is none %}
              <div style="color:var(--muted);font-size:12px">No MCA debits detected.</div>
            {% else %}
              {% include "_stacking_card.html.j2" %}
            {% endif %}
          </div>
        </div>

        <div class="panel">
          <div class="panel-head">
            <span class="panel-title">Pattern analysis</span>
            <span class="panel-actions">
              <span class="mono" style="font-size:10.5px;color:var(--muted)">{{ pattern_cards|length }} pattern{{ '' if pattern_cards|length == 1 else 's' }} surfaced</span>
              {% if document.all_flags %}
                <span class="mono" style="margin-left:10px;font-size:10.5px;color:var(--muted)">all codes: {{ document.all_flags|join(', ') }}</span>
              {% endif %}
            </span>
          </div>
          <div class="panel-body" style="background:var(--paper)">
            {% if pattern_cards %}
              {% for card in pattern_cards %}
                {% include "_pattern_card.html.j2" %}
              {% endfor %}
            {% elif document.all_flags %}
              {# Codes raised but no detail card for them (mca_stacking is
                 rendered above; recent_account_opening is on score
                 breakdown; anything else is a parser-side new detector
                 missing operator copy in aegis.web._pattern_cards). #}
              <div style="padding:8px 0;color:var(--muted);font-size:12px">
                Flags raised on this statement are rendered in other panels (MCA stacking, score breakdown) or pending operator-facing descriptions.
              </div>
            {% else %}
              <div style="padding:16px;color:var(--muted);font-size:12px">No pattern flags raised. Underwriting may proceed against the score breakdown above.</div>
            {% endif %}
          </div>
        </div>
      {% endif %}
    {% endif %}

    {% if history %}
      <div class="panel">
        <div class="panel-head">
          <span class="panel-title">Audit history</span>
          <span class="panel-actions mono">last {{ history|length }} event{{ '' if history|length == 1 else 's' }} · newest first</span>
        </div>
        <div class="panel-body flush">
          <table class="data">
            <thead>
              <tr>
                <th style="width:170px">When</th>
                <th style="width:120px">Actor</th>
                <th style="width:220px">Action</th>
                <th>Details</th>
              </tr>
            </thead>
            <tbody>
              {% for h in history %}
                <tr>
                  <td><span class="mono" style="font-size:11px;color:var(--muted)">{{ (h.created_at or '—')|string|truncate(19, True, '') }}</span></td>
                  <td><span class="mono" style="font-size:11.5px">{{ h.actor }}</span></td>
                  <td><span class="mono" style="font-size:11.5px">{{ h.action }}</span></td>
                  <td>
                    {% if h.details %}
                      <span class="mono" style="font-size:11px;color:var(--ink-2);white-space:normal;word-break:break-word">
                        {% for k, v in h.details.items() %}
                          {% if v is not none %}<span style="color:var(--muted)">{{ k }}=</span><span>{{ v|string|truncate(80, True, '…') }}</span>{% if not loop.last %} · {% endif %}{% endif %}
                        {% endfor %}
                      </span>
                    {% else %}
                      <span style="color:var(--muted)">—</span>
                    {% endif %}
                  </td>
                </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>
    {% endif %}
  </main>
</div>
{% endblock %}
