{% extends "base.html.j2" %}
{% block title %}{{ merchant.business_name }} — AEGIS{% endblock %}
{% block content %}
  <h1>{{ merchant.business_name }}</h1>
  <p class="src-ref">
    {{ merchant.owner_name }} · {{ merchant.state }}
    {% if merchant.industry_naics %} · NAICS {{ merchant.industry_naics }}{% endif %}
    {% if merchant.entity_type %} · {{ merchant.entity_type }}{% endif %}
    {% if merchant.zoho_deal_id %} · Zoho {{ merchant.zoho_deal_id }}{% endif %}
    · <a href="/ui/merchants/{{ merchant.id }}/edit">Edit</a>
    · <a href="/ui/merchants/{{ merchant.id }}/match">Match Funders</a>
    · <a href="/ui/merchants/{{ merchant.id }}/findings.csv">Download CSV</a>
  </p>

  {% include "_compliance_ribbon.html.j2" %}

  {% if merchant.requested_amount or merchant.requested_factor or merchant.requested_term_days %}
    <p class="src-ref">
      Requested: ${{ merchant.requested_amount or "?" }}
      @ {{ merchant.requested_factor or "?" }}
      / {{ merchant.requested_term_days or "?" }} days
      {% if merchant.credit_score %} · Credit {{ merchant.credit_score }}{% endif %}
      {% if merchant.time_in_business_months %} · TIB {{ merchant.time_in_business_months }} mo{% endif %}
    </p>
  {% endif %}

  <h2>Documents</h2>
  {% if not documents %}
    <p>No documents uploaded yet for this merchant. <a href="/ui/upload">Upload statements →</a></p>
  {% else %}
    <table>
      <thead>
        <tr>
          <th>Period</th>
          <th>Status</th>
          <th>Fraud</th>
          <th style="text-align: right;">NSF</th>
          <th style="text-align: right;">True Revenue</th>
          <th style="text-align: right;">ADB</th>
          <th style="text-align: right;">Days Neg</th>
          <th>Uploaded</th>
        </tr>
      </thead>
      <tbody>
        {% for entry in documents %}
          {% set d = entry.document %}
          {% set a = entry.analysis %}
          <tr>
            <td>
              {% if a %}
                {{ a.statement_period_start }} → {{ a.statement_period_end }}
              {% else %}
                <span class="src-ref">(not parsed)</span>
              {% endif %}
            </td>
            <td><span class="tag tag-{{ d.parse_status }}">{{ d.parse_status }}</span></td>
            <td>{{ d.fraud_score if d.fraud_score is not none else "—" }}</td>
            <td style="text-align: right;">{{ a.num_nsf if a else "—" }}</td>
            <td style="text-align: right;">{{ a.true_revenue if a else "—" }}</td>
            <td style="text-align: right;">{{ a.avg_daily_balance if a else "—" }}</td>
            <td style="text-align: right;">{{ a.days_negative if a else "—" }}</td>
            <td class="src-ref">{{ d.uploaded_at.strftime("%Y-%m-%d") }}</td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  {% endif %}

  {% if document is not none %}
    <h2>
      Latest aggregate detail
      <span class="tag tag-{{ document.parse_status }}">{{ document.parse_status }}</span>
    </h2>
    {% if analysis %}
      <p class="src-ref">
        Statement {{ analysis.statement_period_start }} →
        {{ analysis.statement_period_end }} ({{ analysis.statement_days }} days) ·
        sha256 {{ document.file_hash[:12] }}…
      </p>

      {% set agg_metrics = [
          ("true_revenue", analysis.true_revenue),
          ("avg_daily_balance", analysis.avg_daily_balance),
          ("num_nsf", analysis.num_nsf),
          ("days_negative", analysis.days_negative),
          ("mca_daily_total", analysis.mca_daily_total),
        ] %}

      {% for key, value in agg_metrics %}
        <div class="tile">
          <div class="tile-label">{{ aggregate_labels[key] }}</div>
          <div class="tile-value">{{ value }}</div>
          <button hx-get="/ui/documents/{{ document.id }}/aggregate/{{ key }}"
                  hx-target="#drilldown"
                  hx-swap="innerHTML">drill down</button>
        </div>
      {% endfor %}

      <div id="drilldown" style="margin-top: 24px;"></div>

      <h2>Score breakdown</h2>
      {% include "_score_breakdown.html.j2" %}

      <h2>Stacking</h2>
      {% if stacking is none %}
        <p class="src-ref">No MCA debits detected. Card hidden.</p>
      {% else %}
        {% include "_stacking_card.html.j2" %}
      {% endif %}

      <h2>Pattern flags</h2>
      {% if document.all_flags %}
        <ul>
          {% for f in document.all_flags %}<li class="src-ref">{{ f }}</li>{% endfor %}
        </ul>
      {% else %}
        <p class="src-ref">No pattern flags raised.</p>
      {% endif %}
    {% else %}
      <p>Document is parsing or no analysis is available yet.</p>
    {% endif %}
  {% endif %}
{% endblock %}
