{% extends "base.html.j2" %}
{% block title %}Import Funder Criteria — AEGIS{% endblock %}
{% block content %}
  <h1>Import Funder Criteria</h1>
  <p class="src-ref">
    Upload a funder's underwriting-criteria PDF. AEGIS runs Claude
    extraction, surfaces a draft <code>FunderRow</code> with per-field
    confidence, you review/edit, and we save.
  </p>

  {% if error %}
    <p class="tag tag-manual_review" style="display: block; padding: 8px 12px;">
      {{ error }}
    </p>
  {% endif %}

  <form method="post" enctype="multipart/form-data" action="/ui/funders/import">
    <p>
      <label>Criteria PDF<br>
        <input type="file" name="pdf" accept="application/pdf" required>
      </label>
    </p>
    <p>
      <button type="submit" style="padding: 8px 16px; background: #1a1a2e; color: #fff; border: none; border-radius: 4px; font-weight: 600; cursor: pointer;">
        Run extraction
      </button>
      <a href="/ui/funders" style="margin-left: 12px;">Cancel</a>
    </p>
  </form>

  <p class="src-ref" style="margin-top: 32px;">
    Max 25 MB. The extraction runs synchronously and may take 10–30
    seconds against a real LLM. Low-confidence fields will be highlighted
    on the review page.
  </p>
{% endblock %}
