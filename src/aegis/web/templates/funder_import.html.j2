{% extends "base.html.j2" %}
{% set active = 'Funders' %}
{% block title %}Import Funder Criteria — AEGIS{% endblock %}

{% block deck %}
<header class="deck">
  <h1>Import<em> · funder criteria</em></h1>
  <div class="meta">
    PDF upload &nbsp;·&nbsp; Claude extracts a draft FunderRow &nbsp;·&nbsp; operator reviews + saves
  </div>
  <div class="actions">
    <a class="btn ghost" href="/ui/funders">Cancel</a>
  </div>
</header>
{% endblock %}

{% block body %}
<section class="body cols-1" style="max-width:920px;margin:0 auto">
  <div>
    {% if error %}<div class="form-error">{{ error }}</div>{% endif %}

    <header class="sect-head">
      <h2>Upload criteria PDF</h2>
      <div class="rule"></div>
      <div class="meta">max 25 MB · 10-30s extraction</div>
    </header>

    <form class="form" method="post" enctype="multipart/form-data" action="/ui/funders/import" style="margin-top:14px">
      <div class="field">
        <label>Criteria PDF</label>
        <div class="dropzone">
          <div class="big">Drop a funder's criteria PDF</div>
          <div class="small">or pick a file below</div>
          <input type="file" name="pdf" accept="application/pdf" required>
        </div>
      </div>
      <div class="form-actions">
        <button class="btn primary" type="submit">Run extraction</button>
        <a class="btn ghost" href="/ui/funders">Cancel</a>
      </div>
    </form>

    <header class="sect-head" style="margin-top:32px">
      <h2>How this works</h2>
      <div class="rule"></div>
    </header>
    <div class="feed">
      <div class="event"><div class="t">1</div><div class="txt">Upload runs synchronously against Bedrock · ~10-30 s</div></div>
      <div class="event"><div class="t">2</div><div class="txt">Review page highlights low-confidence fields</div></div>
      <div class="event"><div class="t">3</div><div class="txt">Edit any field before saving — AEGIS never auto-creates funders</div></div>
      <div class="event"><div class="t">4</div><div class="txt">Save persists the FunderRow + source PDF hash for audit</div></div>
    </div>
  </div>
</section>
{% endblock %}
