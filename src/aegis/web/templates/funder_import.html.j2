{% extends "base.html.j2" %}
{% set active = 'Funders' %}
{% block title %}Import Funder Criteria — AEGIS{% endblock %}

{% block subhead %}
<div class="subhead">
  <div>
    <h1>Import Funder Criteria</h1>
    <div class="meta" style="margin-top:4px">
      <span><span class="dot"></span>PDF upload</span>
      <span>Claude extracts a draft FunderRow with per-field confidence · operator reviews + saves</span>
    </div>
  </div>
</div>
{% endblock %}

{% block body %}
<div class="body cols-1">
  <main class="main" style="max-width:780px">
    {% if error %}
      <div class="form-error">{{ error }}</div>
    {% endif %}

    <div class="panel">
      <div class="panel-head">
        <span class="panel-title">Upload criteria PDF</span>
        <span class="panel-actions mono">max 25 MB · 10–30s extraction</span>
      </div>
      <div class="panel-body">
        <form method="post" enctype="multipart/form-data" action="/ui/funders/import">
          <label>Criteria PDF</label>
          <div class="dropzone">
            <div class="big">Drop a funder's criteria PDF</div>
            <div class="small">…or use the file picker below</div>
            <input type="file" name="pdf" accept="application/pdf" required style="max-width:none;background:transparent">
          </div>
          <div class="form-actions">
            <button class="btn btn-primary" type="submit">Run extraction</button>
            <a class="btn" href="/ui/funders">Cancel</a>
          </div>
        </form>
      </div>
    </div>

    <div class="panel">
      <div class="panel-head">
        <span class="panel-title">How this works</span>
      </div>
      <div class="panel-body" style="color:var(--ink-2);font-size:12.5px;line-height:1.6">
        <div>1. Upload runs synchronously against Bedrock (~10–30s).</div>
        <div>2. Review page highlights low-confidence fields.</div>
        <div>3. Edit any field before saving — AEGIS never auto-creates funders.</div>
        <div>4. Save persists the FunderRow + source PDF hash for audit.</div>
      </div>
    </div>
  </main>
</div>
{% endblock %}
