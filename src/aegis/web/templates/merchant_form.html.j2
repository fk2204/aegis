{% extends "base.html.j2" %}
{% set is_edit = merchant is not none %}
{% set form_data = form if form is defined else {} %}
{% block title %}
  {% if is_edit %}Edit {{ merchant.business_name }}{% else %}New Merchant{% endif %} — AEGIS
{% endblock %}
{% block content %}
  <h1>{% if is_edit %}Edit Merchant{% else %}New Merchant{% endif %}</h1>

  {% if error %}
    <p class="tag tag-manual_review" style="display: block; padding: 8px 12px;">
      {{ error }}
    </p>
  {% endif %}

  {% set action = "/ui/merchants/" ~ merchant.id ~ "/edit" if is_edit else "/ui/merchants/new" %}
  <form method="post" action="{{ action }}" style="max-width: 600px;">
    <p>
      <label>Business name<br>
        <input name="business_name" required value="{{ form_data.get('business_name') or (merchant.business_name if is_edit else '') }}">
      </label>
    </p>
    <p>
      <label>DBA<br>
        <input name="dba" value="{{ form_data.get('dba') or (merchant.dba if is_edit and merchant.dba else '') }}">
      </label>
    </p>
    <p>
      <label>Owner name<br>
        <input name="owner_name" required value="{{ form_data.get('owner_name') or (merchant.owner_name if is_edit else '') }}">
      </label>
    </p>
    <p>
      <label>State (2-letter)<br>
        <input name="state" required maxlength="2" minlength="2" style="text-transform: uppercase;"
               value="{{ form_data.get('state') or (merchant.state if is_edit else '') }}">
      </label>
      <span class="src-ref">
        Served: 45 states. TX/VA/CT/UT/MO/DC and territories rejected.
      </span>
    </p>
    <p>
      <label>NAICS code<br>
        <input name="industry_naics" value="{{ form_data.get('industry_naics') or (merchant.industry_naics if is_edit and merchant.industry_naics else '') }}">
      </label>
    </p>
    <p>
      <label>Credit score (300–850)<br>
        <input name="credit_score" type="number" min="300" max="850"
               value="{{ form_data.get('credit_score') or (merchant.credit_score if is_edit and merchant.credit_score else '') }}">
      </label>
    </p>
    <p>
      <label>Time in business (months)<br>
        <input name="time_in_business_months" type="number" min="0"
               value="{{ form_data.get('time_in_business_months') or (merchant.time_in_business_months if is_edit and merchant.time_in_business_months else '') }}">
      </label>
    </p>
    <p>
      <label>Email<br>
        <input name="email" type="email"
               value="{{ form_data.get('email') or (merchant.email if is_edit and merchant.email else '') }}">
      </label>
    </p>
    <p>
      <label>Phone<br>
        <input name="phone"
               value="{{ form_data.get('phone') or (merchant.phone if is_edit and merchant.phone else '') }}">
      </label>
    </p>

    <h3>Intake context</h3>
    <p>
      <label>Entity type<br>
        <select name="entity_type">
          {% set selected_entity = form_data.get('entity_type') or (merchant.entity_type if is_edit and merchant.entity_type else '') %}
          <option value="" {% if not selected_entity %}selected{% endif %}>—</option>
          {% for opt in ["llc", "corp", "sole_prop", "partnership", "other"] %}
            <option value="{{ opt }}" {% if selected_entity == opt %}selected{% endif %}>{{ opt }}</option>
          {% endfor %}
        </select>
      </label>
    </p>
    <p>
      <label>EIN<br>
        <input name="ein" placeholder="XX-XXXXXXX"
               value="{{ form_data.get('ein') or (merchant.ein if is_edit and merchant.ein else '') }}">
      </label>
      <span class="src-ref">PII — masked in logs and excluded from CSV/JSON exports.</span>
    </p>
    <p>
      <label>Requested advance ($)<br>
        <input name="requested_amount" type="number" step="0.01" min="0"
               value="{{ form_data.get('requested_amount') or (merchant.requested_amount if is_edit and merchant.requested_amount else '') }}">
      </label>
    </p>
    <p>
      <label>Requested factor (e.g. 1.30)<br>
        <input name="requested_factor" type="number" step="0.01" min="1"
               value="{{ form_data.get('requested_factor') or (merchant.requested_factor if is_edit and merchant.requested_factor else '') }}">
      </label>
    </p>
    <p>
      <label>Requested term (days)<br>
        <input name="requested_term_days" type="number" min="1"
               value="{{ form_data.get('requested_term_days') or (merchant.requested_term_days if is_edit and merchant.requested_term_days else '') }}">
      </label>
    </p>
    <p>
      <label>Source / broker<br>
        <input name="broker_source" placeholder="John @ ABC Brokers"
               value="{{ form_data.get('broker_source') or (merchant.broker_source if is_edit and merchant.broker_source else '') }}">
      </label>
    </p>
    <p>
      <label>Intake date<br>
        <input name="intake_date" type="date"
               value="{{ form_data.get('intake_date') or (merchant.intake_date if is_edit and merchant.intake_date else '') }}">
      </label>
    </p>
    <p>
      {% set is_renewal = form_data.get('is_renewal') in ['true','on','yes','1'] or (is_edit and merchant.is_renewal) %}
      <label>
        <input type="checkbox" name="is_renewal" value="true"
               {% if is_renewal %}checked{% endif %}>
        Renewal of a prior AEGIS-served deal
      </label>
    </p>

    <p>
      <button type="submit" style="padding: 8px 16px; background: #1a1a2e; color: #fff; border: none; border-radius: 4px; font-weight: 600; cursor: pointer;">
        {% if is_edit %}Save{% else %}Create{% endif %}
      </button>
      {% if is_edit %}
        <a href="/ui/merchants/{{ merchant.id }}" style="margin-left: 12px;">Cancel</a>
      {% else %}
        <a href="/ui/merchants" style="margin-left: 12px;">Cancel</a>
      {% endif %}
    </p>
  </form>
{% endblock %}
