{# SBA referral package — printable HTML view (G1, 2026-06-30).
   Loaded via the "Generate SBA referral package" button on the
   dossier when sba_eligibility.eligible is True. Operator opens
   the page, reviews, prints (Cmd/Ctrl+P) or emails as PDF. Full
   PDF-via-WeasyPrint generation is a follow-up. #}
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>SBA Referral Package — {{ merchant.business_name }}</title>
  <style>
    body { font-family: Georgia, serif; max-width: 720px; margin: 40px auto; padding: 20px; line-height: 1.5; color: #1a1a1a; }
    h1 { font-size: 22px; margin-bottom: 4px; }
    h2 { font-size: 15px; margin-top: 28px; padding-bottom: 4px; border-bottom: 1px solid #ddd; }
    .subhead { color: #666; font-size: 13px; margin-bottom: 24px; }
    .kv { display: grid; grid-template-columns: 200px 1fr; gap: 4px 16px; font-size: 13px; margin: 8px 0; }
    .kv dt { color: #666; }
    .kv dd { margin: 0; font-weight: 500; }
    .narrative { background: #f8f8f5; padding: 12px 16px; border-left: 3px solid #2d7a2d; margin: 16px 0; font-size: 13px; }
    .program { background: #e8f4e8; padding: 4px 10px; border-radius: 3px; font-size: 12px; font-weight: 600; color: #155724; display: inline-block; }
    .contact { margin-top: 36px; font-size: 12px; color: #555; }
    .footer { margin-top: 36px; padding-top: 12px; border-top: 1px solid #ddd; font-size: 11px; color: #888; }
    @media print { body { margin: 0; padding: 24px; } .no-print { display: none; } }
  </style>
</head>
<body>
  <button onclick="window.print()" class="no-print" style="float:right;padding:6px 14px;background:#2d7a2d;color:white;border:none;border-radius:4px;cursor:pointer">Print / Save as PDF</button>

  <h1>SBA Referral Package</h1>
  <div class="subhead">Generated by AEGIS on {{ generated_at }} for {{ merchant.business_name }}</div>

  <span class="program">SBA {{ sba.program }} Eligible</span>
  {% if sba.estimated_max_amount %}
    <span style="margin-left:8px;font-size:13px">Estimated max: <strong>${{ "{:,.0f}".format(sba.estimated_max_amount) }}</strong></span>
  {% endif %}

  <h2>Business</h2>
  <dl class="kv">
    <dt>Legal name</dt><dd>{{ merchant.business_name }}</dd>
    {% if merchant.dba %}<dt>DBA</dt><dd>{{ merchant.dba }}</dd>{% endif %}
    <dt>State</dt><dd>{{ merchant.state or "—" }}</dd>
    <dt>Entity type</dt><dd>{{ merchant.entity_type or "—" }}</dd>
    <dt>NAICS</dt><dd>{{ merchant.naics_code or "—" }}</dd>
    <dt>Time in business</dt><dd>{{ merchant.months_in_business or "—" }} months</dd>
  </dl>

  <h2>Owner</h2>
  <dl class="kv">
    <dt>Name</dt><dd>{{ merchant.owner_name or "—" }}</dd>
    <dt>FICO</dt><dd>{{ merchant.fico or "—" }}</dd>
    {% if merchant.email %}<dt>Email</dt><dd>{{ merchant.email }}</dd>{% endif %}
    {% if merchant.phone %}<dt>Phone</dt><dd>{{ merchant.phone }}</dd>{% endif %}
  </dl>

  <h2>Financial summary</h2>
  <dl class="kv">
    <dt>Monthly revenue</dt><dd>${{ "{:,.0f}".format(merchant.monthly_revenue or 0) }}</dd>
    {% if analysis %}
      {% if analysis.true_revenue %}<dt>True revenue (AEGIS)</dt><dd>${{ "{:,.0f}".format(analysis.true_revenue) }}/mo</dd>{% endif %}
    {% endif %}
    <dt>Requested amount</dt><dd>${{ "{:,.0f}".format(merchant.requested_amount or 0) }}</dd>
  </dl>

  {% if narrator_summary %}
    <h2>AEGIS narrative</h2>
    <div class="narrative">{{ narrator_summary }}</div>
  {% endif %}

  <h2>Contact</h2>
  <div class="contact">
    Commera Capital LLC — internal pre-screen by AEGIS.<br>
    For partner SBA referral coordination, contact the deal owner
    listed in Close CRM.
  </div>

  <div class="footer">
    This package is an INTERNAL pre-screening artifact. It is not a
    loan application, not a credit decision, and not a regulator-
    facing document. SBA program eligibility is preliminary and
    subject to lender underwriting.
  </div>
</body>
</html>
