{% extends "base.html.j2" %}
{% set active = 'Merchants' %}
{% block title %}Merchants — AEGIS{% endblock %}

{% block deck %}
<header class="deck">
  <h1>Merchants<em> · directory</em></h1>
  <div class="meta">
    {{ merchants|length }} merchant{{ '' if merchants|length == 1 else 's' }} &nbsp;·&nbsp; click row → dossier
  </div>
  <div class="actions">
    <a class="btn" href="/ui/upload">Upload PDF</a>
    <a class="btn primary" href="/ui/intake">+ New merchant</a>
  </div>
</header>
{% endblock %}

{% block body %}
<section class="body cols-1">
  <div>
    <header class="sect-head">
      <h2>All merchants</h2>
      <div class="rule"></div>
      <div class="meta">n = {{ merchants|length }}</div>
    </header>

    {% if not merchants %}
      <div class="empty">No merchants yet<span class="copy"><a href="/ui/intake">Create one</a> to begin.</span></div>
    {% else %}
      <table class="queue">
        <thead>
          <tr>
            <th>Business</th>
            <th>Owner</th>
            <th>State</th>
            <th>Industry</th>
            <th class="num">FICO</th>
            <th class="num">TIB · mo</th>
            <th>Zoho</th>
          </tr>
        </thead>
        <tbody>
          {% for m in merchants %}
            <tr onclick="window.location.href='/ui/merchants/{{ m.id }}'">
              <td class="merchant">
                <a href="/ui/merchants/{{ m.id }}">{{ m.business_name }}</a>
                <span class="sub">{{ m.id|string|truncate(8, True, '') }}</span>
              </td>
              <td>{{ m.owner_name }}</td>
              <td class="mono-cell">{{ m.state }}</td>
              <td>{{ m.industry_naics or '—' }}</td>
              <td class="mono-cell" style="text-align:right">{{ m.credit_score or '—' }}</td>
              <td class="mono-cell" style="text-align:right">{{ m.time_in_business_months or '—' }}</td>
              <td>
                {% if m.zoho_lead_id or m.zoho_deal_id %}
                  <span class="chip info">{{ 'lead' if m.zoho_lead_id else 'deal' }}</span>
                {% else %}
                  <span class="mono-cell">—</span>
                {% endif %}
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    {% endif %}
  </div>
</section>
{% endblock %}
