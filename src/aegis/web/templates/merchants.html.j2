{% extends "base.html.j2" %}
{% set active = 'Deals' %}
{% block title %}Merchants — AEGIS{% endblock %}

{% block deck %}
{% set title = "Merchants" %}
{% set subtitle = "· directory" %}
{% set meta = (merchant_rows|length|string) ~ " merchant" ~ ('' if merchant_rows|length == 1 else 's') ~ " · click row → dossier · sorted by last activity" %}
{% set actions = [
    {"label": "Upload PDF", "href": "/ui/upload"},
    {"label": "+ Add manually", "href": "/ui/merchants/new"},
    {"label": "+ New from statements", "href": "/ui/intake", "variant": "primary"},
] %}
{% include "_page_header.html.j2" %}
{% endblock %}

{% block body %}
<section class="body cols-1">
  <div>
    <header class="sect-head">
      <h2>All merchants</h2>
      <div class="rule"></div>
      <div class="meta">n = {{ merchant_rows|length }}</div>
      <div class="merchants-filters" style="margin-left:auto">
        {# "My deals" filter chip — toggle via ?mine=1. The bare /ui/merchants
           link clears the filter; the &mine=1 link shows only the current
           operator's assignments. #}
        {% if mine_only %}
          <a href="/ui/merchants"
             class="filter-chip filter-chip--active"
             data-test-id="merchants-filter-clear">
            ✓ My deals
            <span class="filter-chip__clear" aria-label="Clear filter">×</span>
          </a>
        {% else %}
          <a href="/ui/merchants?mine=1"
             class="filter-chip"
             data-test-id="merchants-filter-mine">
            My deals
          </a>
        {% endif %}
      </div>
    </header>

    {% if not merchant_rows %}
      <div class="empty">
        {% if mine_only %}
          No merchants assigned to you yet.<span class="copy"><a class="btn" href="/ui/merchants">See all</a></span>
        {% else %}
          No merchants yet. Create one to get started.<span class="copy"><a class="btn primary" href="/ui/intake">Create</a></span>
        {% endif %}
      </div>
    {% else %}
      {# Operator-useful columns (2026-06-28). Default sort:
         last-activity DESC (route-side). Click any row to open the
         dossier. Each row is the latest-document snapshot for the
         merchant; the dossier exposes the full history. #}
      <table class="queue" data-test-id="merchants-list-table">
        <thead>
          <tr>
            <th>Status</th>
            <th>Business</th>
            <th>State</th>
            <th class="num">Stated rev</th>
            <th class="num">Measured rev</th>
            <th>Paper</th>
            <th>Parse</th>
            <th class="num">Last activity</th>
            <th>Assigned to</th>
            <th>Close</th>
          </tr>
        </thead>
        <tbody>
          {% for r in merchant_rows %}
            <tr onclick="window.location.href='/ui/merchants/{{ r.id }}'" data-test-id="merchants-list-row">
              <td>
                {% if r.is_provisional %}
                  {% with tone="warn", label="PROVISIONAL" %}{% include "_status_chip.html.j2" %}{% endwith %}
                {% elif r.needs_manual_naming %}
                  {% with tone="warn", label="NEEDS NAMING" %}{% include "_status_chip.html.j2" %}{% endwith %}
                {% else %}
                  <span class="mono-cell">—</span>
                {% endif %}
              </td>
              <td class="merchant">
                <a href="/ui/merchants/{{ r.id }}">{{ r.business_name }}</a>
                <span class="sub">
                  {{ r.id|string|truncate(8, True, '') }}{% if r.owner_name %} · {{ r.owner_name }}{% endif %}{% if r.industry_naics %} · {{ r.naics_name or r.industry_naics }}{% endif %}
                </span>
              </td>
              <td class="mono-cell">{{ r.state }}</td>
              <td class="mono-cell" style="text-align:right" data-test-id="merchants-list-stated-rev">
                {% if r.stated_revenue is not none %}${{ '{:,.0f}'.format(r.stated_revenue) }}{% else %}—{% endif %}
              </td>
              <td class="mono-cell" style="text-align:right" data-test-id="merchants-list-measured-rev">
                {% if r.measured_revenue is not none %}${{ '{:,.0f}'.format(r.measured_revenue) }}{% else %}—{% endif %}
              </td>
              <td data-test-id="merchants-list-paper-grade">
                {% if r.paper_grade %}
                  <span class="tier-badge tier-badge--{{ r.paper_grade|lower }}" title="Derived from latest document fraud band">{{ r.paper_grade }}</span>
                {% else %}
                  <span class="mono-cell">—</span>
                {% endif %}
              </td>
              <td data-test-id="merchants-list-parse-status">
                {# 2026-06-28 — plain-English status badges. Replaces the
                   raw enum chip ("proceed", "manual_review", etc.) so
                   non-engineers reading the merchant list scan it like
                   English. Macros vs inline if/elif: the inline map is
                   simpler given the limited shape and one-call site. #}
                {% set _parse_label = {
                  'proceed':       ('✓ Clean',         'badge-proceed'),
                  'manual_review': ('⚠ Needs review',  'badge-manual'),
                  'review':        ('⚠ Review band',   'badge-manual'),
                  'pending':       ('⏳ Parsing',       'badge-pending'),
                  'error':         ('✗ Error',         'badge-error'),
                  'no_upload':     ('— No upload',     'badge-none'),
                } %}
                {% set _entry = _parse_label.get(r.parse_status, (r.parse_status, '')) %}
                <span class="badge {{ _entry[1] }}">{{ _entry[0] }}</span>
              </td>
              <td class="mono-cell" style="text-align:right" data-test-id="merchants-list-last-activity">
                {# Server-computed ``last_activity_display`` renders the
                   "today" / "yesterday" / "Nd ago" branching; falls back
                   to em-dash when no document is on file. #}
                {{ r.last_activity_display or "—" }}
              </td>
              <td data-test-id="merchants-list-assignee">
                {% if r.assignee_label and r.assignee_label != '—' %}
                  <span class="assignee-pill" title="Assigned to {{ r.assignee_label }}">{{ r.assignee_label }}</span>
                {% else %}
                  <span class="mono-cell">—</span>
                {% endif %}
              </td>
              <td>
                {% if r.close_lead_id %}
                  <span class="chip info">lead</span>
                {% else %}
                  <span class="mono-cell">—</span>
                {% endif %}
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    {% endif %}
  </div>
</section>
{% endblock %}
