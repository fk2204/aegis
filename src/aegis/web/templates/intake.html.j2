{% extends "base.html.j2" %}
{% set active = 'Intake' %}
{% block title %}Intake — AEGIS{% endblock %}

{% block subhead %}
<div class="subhead">
  <div>
    <h1>New merchant + statements</h1>
    <div class="meta" style="margin-top:4px">
      <span><span class="dot"></span>One-shot intake</span>
      <span>6 required fields · everything else editable from the merchant page</span>
    </div>
  </div>
</div>
{% endblock %}

{% block body %}
<div class="body cols-1">
  <main class="main" style="max-width:780px">
    {% if error %}
      <div class="form-error">{{ error }}</div>
    {% endif %}

    <div class="panel">
      <div class="panel-head">
        <span class="panel-title">Merchant intake</span>
        <span class="panel-actions mono">required fields marked *</span>
      </div>
      <div class="panel-body">
        <form method="post" action="/ui/intake" enctype="multipart/form-data">
          <h3>Merchant</h3>

          <label>Business name *</label>
          <input name="business_name" required value="{{ form.get('business_name', '') }}">

          <label>DBA</label>
          <input name="dba" value="{{ form.get('dba', '') }}">

          <label>Owner name *</label>
          <input name="owner_name" required value="{{ form.get('owner_name', '') }}">

          <label>State (2-letter) *</label>
          <input name="state" required maxlength="2" minlength="2" style="text-transform:uppercase;max-width:80px" value="{{ form.get('state', '') }}">
          <span class="field-help">Served: 45 states. TX/VA/CT/UT/MO/DC and territories rejected.</span>

          <label>Entity type</label>
          <select name="entity_type">
            <option value="">—</option>
            {% for opt in ['llc','corp','sole_prop','partnership','other'] %}
              <option value="{{ opt }}" {% if form.get('entity_type') == opt %}selected{% endif %}>{{ opt }}</option>
            {% endfor %}
          </select>

          <label>EIN</label>
          <input name="ein" placeholder="XX-XXXXXXX" value="{{ form.get('ein', '') }}">
          <span class="field-help">PII — masked in logs and excluded from CSV/JSON exports.</span>

          <label>NAICS code</label>
          <input name="industry_naics" value="{{ form.get('industry_naics', '') }}">

          <label>Owner credit score (300–850)</label>
          <input name="credit_score" type="number" min="300" max="850" value="{{ form.get('credit_score', '') }}">

          <label>Time in business (months)</label>
          <input name="time_in_business_months" type="number" min="0" value="{{ form.get('time_in_business_months', '') }}">

          <label>Email</label>
          <input name="email" type="email" value="{{ form.get('email', '') }}">

          <label>Phone</label>
          <input name="phone" value="{{ form.get('phone', '') }}">

          <h3>Underwriting target</h3>

          <label>Requested advance ($)</label>
          <input name="requested_amount" type="number" step="0.01" min="0" value="{{ form.get('requested_amount', '') }}">

          <label>Requested factor (e.g. 1.30)</label>
          <input name="requested_factor" type="number" step="0.01" min="1" value="{{ form.get('requested_factor', '') }}">

          <label>Requested term (days)</label>
          <input name="requested_term_days" type="number" min="1" value="{{ form.get('requested_term_days', '') }}">

          <label>Source / broker</label>
          <input name="broker_source" placeholder="John @ ABC Brokers" value="{{ form.get('broker_source', '') }}">

          <label>Intake date</label>
          <input name="intake_date" type="date" value="{{ form.get('intake_date', '') }}">

          <div class="checkbox-row">
            <input type="checkbox" id="is_renewal" name="is_renewal" value="true" {% if form.get('is_renewal') in ['true','on','yes','1'] %}checked{% endif %}>
            <label for="is_renewal">Renewal of a prior AEGIS-served deal</label>
          </div>

          <h3>Statements</h3>

          <label>Bank statement PDFs (3–4 months)</label>
          <input type="file" name="files" accept="application/pdf" multiple>
          <span class="field-help">Optional at intake — you can upload later from the merchant page.</span>

          <div class="form-actions">
            <button class="btn btn-primary" type="submit">Create merchant &amp; queue parse</button>
            <a class="btn" href="/ui/merchants">Cancel</a>
          </div>
        </form>
      </div>
    </div>
  </main>
</div>
{% endblock %}
