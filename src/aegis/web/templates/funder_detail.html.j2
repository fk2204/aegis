{% extends "base.html.j2" %}
{% set active = 'Funders' %}
{% block title %}{{ funder.name }} — Funder · AEGIS{% endblock %}

{% block deck %}
<header class="deck">
  <h1>{{ funder.name }}<em> · funder</em></h1>
  <div class="meta">
    {{ funder.id|string|truncate(8, True, '') }}
    {% if funder.active %}&nbsp;·&nbsp; <span style="color:var(--approve)">active</span>{% else %}&nbsp;·&nbsp; <span style="color:var(--decline)">inactive</span>{% endif %}
    {% if funder.guidelines_extracted_at %}&nbsp;·&nbsp; extracted {{ funder.guidelines_extracted_at }}{% endif %}
  </div>
  <div class="actions">
    <a class="btn ghost" href="/ui/funders">← All funders</a>
  </div>
</header>
{% endblock %}

{% block body %}
<section class="body cols-1">
  <div>

    <header class="sect-head">
      <h2>Hard gates</h2>
      <div class="rule"></div>
      <div class="meta">automatic decline if any fails</div>
    </header>
    <section class="strip" style="--strip-cols:4;padding-left:0;padding-right:0">
      <div class="cell" style="padding-left:0">
        <div class="k">Min monthly revenue</div>
        <div class="v">{{ "${:,.0f}".format(funder.min_monthly_revenue) if funder.min_monthly_revenue else "—" }}</div>
      </div>
      <div class="cell">
        <div class="k">Min ADB</div>
        <div class="v">{{ "${:,.0f}".format(funder.min_avg_daily_balance) if funder.min_avg_daily_balance else "—" }}</div>
      </div>
      <div class="cell">
        <div class="k">Min FICO</div>
        <div class="v">{{ funder.min_credit_score or "—" }}</div>
      </div>
      <div class="cell">
        <div class="k">Min TIB · mo</div>
        <div class="v">{{ funder.min_months_in_business or "—" }}</div>
      </div>
    </section>

    <section class="strip" style="--strip-cols:3;border-bottom:0;padding-left:0;padding-right:0;margin-top:14px">
      <div class="cell" style="padding-left:0">
        <div class="k">Max positions</div>
        <div class="v">{{ funder.max_positions if funder.max_positions is not none else "—" }}</div>
      </div>
      <div class="cell">
        <div class="k">Stacking</div>
        <div class="v" style="font-size:22px">
          {% if funder.accepts_stacking %}<span class="chip pos">yes</span>{% else %}<span class="chip bad">no</span>{% endif %}
        </div>
      </div>
      <div class="cell" style="border-right:0;padding-right:0">
        <div class="k">Max NSF</div>
        <div class="v">{{ funder.max_nsf_tolerance if funder.max_nsf_tolerance is not none else "—" }}</div>
      </div>
    </section>

    <header class="sect-head" style="margin-top:32px">
      <h2>Pricing envelope</h2>
      <div class="rule"></div>
    </header>
    <div class="feed">
      <div class="event"><div class="t">$</div><div class="txt"><strong>Advance range</strong>&nbsp;&nbsp;{% if funder.min_advance and funder.max_advance %}${{ "{:,.0f}".format(funder.min_advance) }} – ${{ "{:,.0f}".format(funder.max_advance) }}{% else %}—{% endif %}</div></div>
      <div class="event"><div class="t">×</div><div class="txt"><strong>Factor range</strong>&nbsp;&nbsp;{% if funder.typical_factor_low and funder.typical_factor_high %}{{ funder.typical_factor_low }} – {{ funder.typical_factor_high }}{% else %}—{% endif %}</div></div>
      <div class="event"><div class="t">%</div><div class="txt"><strong>Holdback range</strong>&nbsp;&nbsp;{% if funder.typical_holdback_low and funder.typical_holdback_high %}{{ "{:.0%}".format(funder.typical_holdback_low) }} – {{ "{:.0%}".format(funder.typical_holdback_high) }}{% else %}—{% endif %}</div></div>
    </div>

    <header class="sect-head" style="margin-top:32px">
      <h2>Compliance</h2>
      <div class="rule"></div>
    </header>
    <div style="display:flex;flex-wrap:wrap;gap:8px;margin-top:14px">
      {% if funder.requires_coj %}<span class="chip warn">Requires CoJ</span>{% else %}<span class="chip">No CoJ</span>{% endif %}
      {% if funder.charges_merchant_advance_fees %}<span class="chip bad">Charges advance fees</span>{% else %}<span class="chip pos">No advance fees</span>{% endif %}
    </div>
    {% if funder.aegis_compensation_disclosure_text %}
      <div class="feed" style="margin-top:14px">
        <div class="event"><div class="t">NY</div><div class="txt"><strong>Broker comp disclosure</strong>&nbsp;&nbsp;{{ funder.aegis_compensation_disclosure_text }}</div></div>
      </div>
    {% endif %}

    {% if funder.excluded_states or funder.excluded_industries %}
      <header class="sect-head" style="margin-top:32px">
        <h2>Exclusions</h2>
        <div class="rule"></div>
      </header>
      <div class="feed">
        {% if funder.excluded_states %}
          <div class="event"><div class="t">St</div><div class="txt"><strong>States · {{ funder.excluded_states|length }}</strong>&nbsp;&nbsp;<span class="mono-inline">{{ funder.excluded_states|join(", ") }}</span></div></div>
        {% endif %}
        {% if funder.excluded_industries %}
          <div class="event"><div class="t">In</div><div class="txt"><strong>Industries · {{ funder.excluded_industries|length }}</strong>&nbsp;&nbsp;<span class="mono-inline">{{ funder.excluded_industries|join(", ") }}</span></div></div>
        {% endif %}
      </div>
    {% endif %}

    {% if funder.notes %}
      <header class="sect-head" style="margin-top:32px">
        <h2>Notes</h2>
        <div class="rule"></div>
      </header>
      <div style="font-family:var(--serif);font-size:14px;color:var(--ink-2);white-space:pre-wrap;line-height:1.5;padding-top:14px">{{ funder.notes }}</div>
    {% endif %}

  </div>
</section>
{% endblock %}
