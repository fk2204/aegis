{# Merchant detail — "Dossier" view.

   Self-contained: does NOT extend base.html.j2 because the masthead +
   meta-row are bespoke for this surface. Topstrip still matches the
   rest of the app. Reachable at /ui/merchants/{id}. The legacy
   ?view=v2 panel layout was retired when the whole app unified on
   the dossier aesthetic.
#}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ merchant.business_name }} — AEGIS Dossier</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Poppins:wght@600;700;800&display=swap" rel="stylesheet">
  {# UI redesign Wave 1 hotfix (2026-06-03) — this template is the only
     page that does NOT extend base.html.j2, so the base's Wave-1 link
     update didn't propagate here. Without aegis-system.css loaded,
     `var(--ink)`, `var(--paper)`, `var(--sage)` etc. inside the
     dossier and tool selectors resolve to invalid fallback (the token
     block was moved out of aegis-dossier.css :15-46 by Wave 1) and the
     page renders unstyled. Same load order as base.html.j2: system first,
     then dossier, then tool. ?v= bumps to match base. #}
  <link rel="stylesheet" href="/ui/static/aegis-system.css?v=7">
  <link rel="stylesheet" href="/ui/static/aegis-dossier.css?v=14">
  <link rel="stylesheet" href="/ui/static/aegis-tool.css?v=16">
  <script src="https://unpkg.com/htmx.org@2.0.4" defer></script>
  <script src="/ui/static/evidence_copy.js?v=1" defer></script>
  <style>
    /* Fix 1 (2026-06-26) — narrator action-chip color scheme. White-on-yellow
       fails WCAG contrast so the call_first chip uses black text on yellow
       deliberately; the other three pass at the listed swatches. */
    .narrator-action--submit_now { background:#198754; color:#fff; }
    .narrator-action--call_first { background:#ffc107; color:#000; }
    .narrator-action--request_documents { background:#fd7e14; color:#fff; }
    .narrator-action--do_not_submit { background:#dc3545; color:#fff; }
    .narrator-action { padding:10px 14px; border-radius:6px; margin-top:10px; }
    .narrator-action strong { color:inherit; }
    .narrator-action a { color:inherit; }
    /* Fix 1 — visible prompt card when narrator_summary is None but the
       deal already has a scoreable analysis on file. The HTMX swap targets
       this class so the response replaces the card in place.
       2026-06-28: bumped padding + horizontal margin to match the
       deal-summary-card so the prompt actually reads as the top-of-
       dossier element underwriters land on (was getting visually
       lost under the masthead at full width). */
    .narrator-prompt {
      background:#fff3cd;
      border:1px solid #ffeeba;
      border-left:4px solid #ffc107;
      border-radius:8px;
      padding:18px 22px;
      margin:14px 24px 0;
      font-size:14px;
    }
    .narrator-prompt p { margin:0 0 10px 0; }
    .narrator-prompt button {
      padding:6px 14px;
      border:1px solid #1d1d18;
      border-radius:4px;
      background:#1d1d18;
      color:#fafaf7;
      cursor:pointer;
      font-size:12px;
      text-transform:uppercase;
      letter-spacing:0.08em;
    }
    /* Fix 2 — amber banner above the funder match grid when every
       statement is in manual_review. Keep style local: the dossier has
       no existing banner class with this exact tone. */
    .manual-review-banner {
      background:#fff3cd;
      border-left:4px solid #ffc107;
      padding:10px 14px;
      margin-bottom:12px;
    }
    /* Fix 4 — Track A plain-English block. Prominent (15px serif) above
       the technical detail; details/summary closed by default. */
    .track-a-plain {
      font-family:var(--serif, Georgia, serif);
      font-size:15px;
      line-height:1.5;
      color:var(--ink, #1d1d18);
      margin:4px 0 6px 0;
    }
    .track-a-tech-detail {
      margin-top:6px;
      font-size:12px;
      color:var(--ink-2, #3d3d38);
    }
    .track-a-tech-detail summary {
      cursor:pointer;
      font-family:var(--mono, monospace);
      font-size:11px;
      letter-spacing:0.06em;
      text-transform:uppercase;
      color:var(--ink-3, #6b6b66);
    }
    /* Fix 5 — stacking alert banner (red for confirmed, yellow for
       pattern-only). Renders above the funder match grid. */
    .stacking-alert {
      padding:10px 14px;
      border-radius:6px;
      margin-bottom:12px;
      font-size:13px;
    }
    .stacking-alert--confirmed {
      background:#f8d7da;
      border:1px solid #f5c2c7;
      color:#842029;
    }
    .stacking-alert--pattern {
      background:#fff3cd;
      border:1px solid #ffeeba;
      color:#664d03;
    }
  </style>
</head>
<body class="dossier-page body-root">

{# Fix 3 (2026-06-26) — plain-English statement label. Maps
   ``parse_status`` plus the strongest hint in ``all_flags`` (no dedicated
   ``manual_review_reason`` column lives on documents today; reasons are
   carried in-band on ``all_flags`` per parser/pipeline.py) to a single
   human label. Returns a tuple-shaped dict so callers can render the
   label + a short tag chip next to it. Tooltip surfaces the strongest
   flag match for raw inspection. #}
{% macro plain_status_label(doc) -%}
  {%- set _status = doc.parse_status -%}
  {%- set _flags_joined = ' '.join(doc.all_flags or []) | lower -%}
  {%- if _status == 'proceed' -%}
    {%- set _label -%}&check; Parsed clean{%- endset -%}
    {%- set _tag = 'proceed' -%}
    {%- set _tooltip = 'parse_status=proceed' -%}
  {%- elif _status == 'review' -%}
    {%- set _label -%}&#9888; Review band &mdash; verify findings{%- endset -%}
    {%- set _tag = 'review' -%}
    {%- set _tooltip = 'parse_status=review' -%}
  {%- elif _status == 'pending' -%}
    {%- set _label -%}&#8987; Being analyzed{%- endset -%}
    {%- set _tag = 'pending' -%}
    {%- set _tooltip = 'parse_status=pending' -%}
  {%- elif _status == 'error' -%}
    {%- set _label -%}&times; Parse error{%- endset -%}
    {%- set _tag = 'error' -%}
    {%- set _tooltip = 'parse_status=error' -%}
  {%- elif _status == 'manual_review' -%}
    {%- if 'editor' in _flags_joined and ('reconciliation' in _flags_joined or 'reconcile' in _flags_joined) -%}
      {%- set _label -%}&#9888; Possible tampering &mdash; PDF edited and math doesn&#39;t reconcile{%- endset -%}
    {%- elif 'reconciliation' in _flags_joined or 'reconcile' in _flags_joined -%}
      {%- set _label -%}&#9888; Math discrepancy &mdash; could be OCR error or real drift{%- endset -%}
    {%- elif 'period' in _flags_joined -%}
      {%- set _label -%}&#9888; Statement period couldn&#39;t be determined{%- endset -%}
    {%- elif 'extraction' in _flags_joined -%}
      {%- set _label -%}&#9888; Parser couldn&#39;t read this file{%- endset -%}
    {%- elif 'vision' in _flags_joined -%}
      {%- set _label -%}&#9888; Image-only PDF &mdash; vision parse attempted{%- endset -%}
    {%- else -%}
      {%- set _label -%}&#9888; Needs manual review{%- endset -%}
    {%- endif -%}
    {%- set _tag = 'manual_review' -%}
    {%- set _tooltip = (doc.all_flags or [])|join(' | ') -%}
  {%- else -%}
    {%- set _label = _status -%}
    {%- set _tag = _status -%}
    {%- set _tooltip = _status -%}
  {%- endif -%}
  <span class="plain-status" title="{{ _tooltip }}">
    <span class="plain-status-label">{{ _label | safe }}</span>
    <span class="pill {% if _tag == 'proceed' %}ok{% elif _tag in ('manual_review','error') %}bad{% elif _tag == 'review' %}warn{% endif %}" style="margin-left:6px;font-family:var(--mono);font-size:10px;letter-spacing:0.06em">{{ _tag }}</span>
  </span>
{%- endmacro %}

{# === compact topstrip === #}
{# Wave 2.4 (2026-06-03): use the shared `_topstrip.html.j2` partial
   instead of a divergent hand-maintained copy. The previous inline
   version had silently fallen behind base.html.j2 — missing the
   `/ui/intake` link. The dossier doesn't highlight any nav, so
   `active` is intentionally not set. #}
{% include "_topstrip.html.j2" %}

{# Wave 2.4: gate routing actions (Match funders / Sync to Close)
   behind a finalized status. A provisional or needs-manual-naming
   merchant has either a placeholder business name or no name at all,
   so funder matching and Close CRM sync would push junk downstream.
   Disabled buttons render as a static span (no href) with inline
   opacity + cursor styles. NOTE: no canonical `.is-disabled` class
   exists in any of the Wave-1 CSS files; inline styles here are a
   deliberate scope-respecting hold until a `.btn.is-disabled` rule
   is added in a follow-up CSS unit (flagged for Wave 1.5). #}
{% set _actions_locked = merchant.status != 'finalized' %}
{% set _locked_title = 'Available after merchant is finalized' %}

{# === Wave 2.4 merchant-status banner (2026-06-03) ===
   Renders for the two non-final lifecycle states (see
   merchants/models.py). Copy is intentionally NEUTRAL for
   `needs_manual_naming` — that status is reached via four distinct
   underlying causes (blank account_holder, parse exception, parse
   cancellation, processor-branch success) and cause-specific copy
   would lie about which one applies. Provisional copy explains the
   in-flight parse so the operator doesn't act on the placeholder
   business name. Styled as `.flash` to reuse the existing dossier
   flash chrome (aegis-dossier.css :196-218). #}
{% if merchant.status != 'finalized' %}
  <div class="flash">
    <div>
      <div class="copy">
        {% if merchant.status == 'needs_manual_naming' %}
          <strong>This merchant needs a name.</strong>
          Open intake to set it.
        {% elif merchant.status == 'provisional' %}
          <strong>This merchant is being created from your upload.</strong>
          The business name will fill in when parsing completes.
        {% endif %}
      </div>
      <div class="actions">
        {% if merchant.status == 'needs_manual_naming' %}
          <a class="btn primary" href="/ui/intake">Open intake →</a>
        {% endif %}
      </div>
    </div>
  </div>
{% endif %}

{# === intake flash banner (carried over from v2 Block 6) === #}
{% if from_intake %}
  <div class="flash">
    <div>
      <div class="copy">
        <strong>Merchant filed.</strong>
        {% if intake_docs_uploaded == 0 %}
          No statements at intake — upload one to score the deal and route to funders.
        {% elif intake_docs_uploaded == 1 %}
          One statement queued for parsing (30-90s). Refresh to see the score fill in.
        {% else %}
          {{ intake_docs_uploaded }} statements queued for parsing (30-90s each). Refresh to see the score fill in.
        {% endif %}
        {% if intake_docs_failed > 0 %}
          <span style="color:var(--decline);font-style:italic">{{ intake_docs_failed }} upload{{ '' if intake_docs_failed == 1 else 's' }} failed — retry from the upload page.</span>
        {% endif %}
      </div>
      <div class="actions">
        {% if intake_docs_uploaded > 0 %}
          {% if _actions_locked %}
            <span class="btn primary is-disabled" title="{{ _locked_title }}" aria-disabled="true">Match funders →</span>
          {% else %}
            <a class="btn primary" href="/ui/merchants/{{ merchant.id }}/match">Match funders →</a>
          {% endif %}
        {% endif %}
        <a class="btn{% if intake_docs_uploaded == 0 %} primary{% endif %}" href="/ui/upload">Upload statements</a>
        <a class="btn" href="/ui/merchants/{{ merchant.id }}/edit">Edit</a>
      </div>
    </div>
  </div>
{% endif %}

{# === masthead === #}
<header class="masthead">
  <div class="running">
    <div class="left">
      <span>The AEGIS Dossier</span>
      <span>Deal {{ merchant.id|string|truncate(8, True, '') }}</span>
    </div>
    <div class="center">Commera Capital · Underwriting Desk</div>
    <div class="left" style="justify-content:flex-end">
      <span>{{ now|default('') }}</span>
    </div>
  </div>

  {# split business name across two lines if it contains an obvious break word #}
  <h1 class="title">{{ merchant.business_name }}</h1>

  {# Assignment chip + mount for the HTMX-injected modal. The chip is
     rendered server-side using the `assignment_chip_assignee` context
     value populated by the merchants router; the modal mount is empty
     until the operator clicks the chip. #}
  <div class="dossier-assignment-row" data-test-id="dossier-assignment-row">
    {% include "_assignment_chip.html.j2" with context %}
  </div>
  <div id="assignment-modal-mount"></div>

  <div class="subtitle">
    {% if documents and analysis %}
      An MCA underwriting brief — {{ documents|length }} statement{{ '' if documents|length == 1 else 's' }} ({{ analysis.statement_period_start }} → {{ analysis.statement_period_end }}), {{ pattern_cards|length }} pattern finding{{ '' if pattern_cards|length == 1 else 's' }}, prepared with full source-row traceability to the underlying PDFs.
    {% elif documents %}
      An MCA underwriting brief — {{ documents|length }} statement{{ '' if documents|length == 1 else 's' }} on file; the most recent has not been fully analyzed yet.
    {% else %}
      An MCA underwriting brief — no statements uploaded yet. Drop one or more PDFs to score the deal.
    {% endif %}
  </div>

  <div class="meta-row">
    <div><span class="label">Owner</span><span class="value">{{ merchant.owner_name }}</span></div>
    <div><span class="label">State</span><span class="value">{{ merchant.state }}</span></div>
    <div><span class="label">Industry</span><span class="value">{{ (naics_name if naics_name is defined else None) or merchant.industry_naics or '—' }}</span></div>
    <div><span class="label">Entity</span><span class="value">{{ merchant.entity_type or '—' }}{% if merchant.time_in_business_months %} · <em>TIB {{ merchant.time_in_business_months }} mo</em>{% endif %}</span></div>
    <div><span class="label">Credit</span><span class="value">{{ merchant.credit_score or '—' }}{% if merchant.credit_score %} <em>FICO</em>{% endif %}</span></div>
    <div><span class="label">Intake</span><span class="value">{{ merchant.intake_date or '—' }}</span></div>
  </div>

  {# Credit-score missing warning. Funder matching uses min_credit_score
     as a hard gate on most funders; without it, matches that should
     hard-fail will silently surface as soft-concern-only. Chip nudges
     the operator to pull credit and re-run. A one-shot Close task is
     also created (idempotent on merchant_id) by push_decision_to_close
     so the prompt lands in the operator's normal Close queue. #}
  {% if merchant.credit_score is none %}
    <div class="dossier-credit-missing"
         data-test-id="dossier-credit-missing-chip"
         role="status"
         style="margin:10px 0 0 0;padding:8px 12px;border-left:3px solid var(--review);
                background:rgba(255,196,0,0.08);font-size:12px;line-height:1.5">
      <strong>⚠ Credit score not on file</strong> — funder matching may be
      incomplete for funders with minimum FICO requirements. A Close task
      to pull credit has been queued for the operator.
    </div>
  {% endif %}
</header>

{# Operator notes panel was previously positioned here (between the
   masthead and the sheet). Moved to the bottom of ``<main>`` below in
   the 2026-06-18 audit-log removal — the dossier reads top-to-bottom as
   verdict → cashflow → routing → submissions → operator notes, with
   the operator-curated notes as the closing block. #}

{# ============== Bedrock narrator summary (migration 075) ============== #}
{# Plain-English senior-underwriter handoff. Sits at the very top of the
   dossier so the operator reads the verbal summary first, then drills
   into the raw numbers as needed. Rendered from cached
   ``analyses.narrator_summary`` JSON; absent rows (legacy deals + first
   visit on a new deal) render the Fix-1 prompt card so the underwriter
   sees an actionable button instead of silence. The HTMX swap targets
   ``.narrator-prompt`` so the response replaces the card in place. #}
{% if narrator_summary is none and analysis and document %}
  <div class="narrator-prompt"
       data-test-id="narrator-prompt"
       data-narrator-prompt>
    <p><strong>No deal summary yet.</strong></p>
    <button hx-post="/ui/merchants/{{ merchant.id }}/documents/{{ document.id }}/narrator/refresh"
            hx-target=".narrator-prompt"
            hx-swap="outerHTML"
            type="submit"
            data-test-id="narrator-prompt-generate">Generate deal summary</button>
  </div>
{% endif %}
{% if narrator_summary %}
  <section class="narrator-summary"
           data-test-id="narrator-summary"
           data-action="{{ narrator_summary.recommended_action.action }}">
    <div class="narrator-deal-summary" data-test-id="narrator-deal-summary">
      {{ narrator_summary.deal_summary }}
    </div>
    {% if narrator_summary.flag_explanations %}
      <ul class="narrator-flags" data-test-id="narrator-flags">
        {% for flag in narrator_summary.flag_explanations %}
          <li class="narrator-flag-item narrator-flag-{{ flag.severity }}"
              data-flag-code="{{ flag.flag_code }}"
              data-severity="{{ flag.severity }}">
            {{ flag.explanation }}
          </li>
        {% endfor %}
      </ul>
    {% endif %}
    <div class="narrator-action narrator-action--{{ narrator_summary.recommended_action.action }}"
         data-test-id="narrator-action">
      <strong>{{ narrator_summary.recommended_action.next_step }}</strong>
      {% if narrator_summary.recommended_action.top_funder_match %}
        <div class="narrator-action-funder">
          Top match: {{ narrator_summary.recommended_action.top_funder_match }}{% if narrator_summary.recommended_action.estimated_terms %} — {{ narrator_summary.recommended_action.estimated_terms }}{% endif %}
        </div>
      {% endif %}
    </div>
    <form method="post"
          action="/ui/merchants/{{ merchant.id }}/documents/{{ document.id }}/narrator/refresh"
          class="narrator-refresh-form">
      <button type="submit"
              class="narrator-refresh-button"
              data-test-id="narrator-refresh-button">
        Refresh summary
      </button>
    </form>
  </section>
{% endif %}

{# ============== Plain-English deal summary card (2026-06-18) ============== #}
{# Sits ABOVE the sheet so it's the first thing the team reads, before
   any chips. Background colour is driven by ``deal_summary.verdict``:
   green (clean) / amber (review) / red (decline). Rule-based — no LLM
   call. Hidden when the deal isn't yet scoreable. #}
{% if deal_summary %}
  <section class="deal-summary-card deal-summary-{{ deal_summary.verdict }}"
           data-test-id="deal-summary-card"
           data-verdict="{{ deal_summary.verdict }}">
    <div class="deal-summary-headline" data-test-id="deal-summary-headline">{{ deal_summary.headline }}</div>
    <p class="deal-summary-body" data-test-id="deal-summary-body">{{ deal_summary.body }}</p>
    {% if deal_summary.flags %}
      <ul class="deal-summary-flags" data-test-id="deal-summary-flags">
        {% for flag in deal_summary.flags %}
          <li>{{ flag }}</li>
        {% endfor %}
      </ul>
    {% endif %}
  </section>
{% endif %}

{# ============== Funder-ready narrative (2026-06-18) ============== #}
{# Bedrock-generated 3-4 sentence underwriter-tone paragraph that the
   team can copy-paste into a funder Slack / call. Sits directly below
   the deal-summary card. The same string is prepended to the Close
   Note that posts when the operator clicks Submit-to-funder.

   Empty ``funder_narrative`` means Bedrock was unavailable when the
   dossier rendered — surface a small empty-state hint so the operator
   can re-load the dossier later instead of wondering whether the
   section is just missing. #}
{% if deal_summary %}
  <section class="funder-narrative-card" data-test-id="funder-narrative-card">
    <header class="funder-narrative-header">
      <strong>Funder summary</strong>
      {% if funder_narrative %}
        <button type="button"
                class="funder-narrative-copy"
                data-test-id="funder-narrative-copy"
                onclick="(function(btn){ const el=document.querySelector('[data-funder-narrative-body]'); if(!el)return; navigator.clipboard.writeText(el.innerText).then(function(){ const o=btn.textContent; btn.textContent='Copied ✓'; setTimeout(function(){btn.textContent=o;},1500); }); })(this);">
          Copy
        </button>
      {% endif %}
    </header>
    {% if funder_narrative %}
      <p class="funder-narrative-body"
         data-test-id="funder-narrative-body"
         data-funder-narrative-body>{{ funder_narrative }}</p>
    {% else %}
      <p class="funder-narrative-empty"
         data-test-id="funder-narrative-empty">Narrative not available right now — reload the dossier to try generation again.</p>
    {% endif %}
  </section>
{% endif %}

{# === sheet === #}
<div class="sheet">

  {# ============ left rail: nav, compliance, statements ============ #}
  <aside class="rail">
    <nav class="toc">
      <a href="#verdict"><span class="n">§ 1</span> Verdict</a>
      {% if analysis %}<a href="#evidence"><span class="n">§ 2</span> Cashflow evidence</a>{% endif %}
      {% if pattern_cards or stacking or (soft_signals and not soft_signals.is_empty) %}<a href="#findings"><span class="n">§ 3</span> Pattern findings</a>{% endif %}
      <a href="#routing"><span class="n">§ 4</span> Funder routing</a>
      {% if documents %}<a href="#statements"><span class="n">§ 4½</span> Statements ledger</a>{% endif %}
      {% if merchant.monthly_revenue or merchant.stated_daily_payment or merchant.stated_mca_positions or merchant.stated_current_lenders or merchant.stated_bank or merchant.use_of_funds or merchant.stated_mca_balance or merchant.stated_monthly_deposits or merchant.avg_monthly_cc_sales %}<a href="#application-data"><span class="n">§ 4⅔</span> Application data</a>{% endif %}
      <a href="#profile"><span class="n">§ 4¾</span> Merchant profile</a>
      <a href="#disposition"><span class="n">§ 5</span> Disposition</a>
      {% if funder_note_submissions %}<a href="#submissions"><span class="n">§ 5½</span> Funder submissions</a>{% endif %}
      <a href="#operator-notes"><span class="n">§ 6</span> Operator notes</a>
    </nav>

    <div class="compliance">
      <h4>Compliance posture</h4>
      {% if state_tier %}
        <div class="tier">{{ state_tier.label|default('Tier ?') }} · <em>{{ merchant.state }}</em></div>
        <div style="margin-top:4px">{{ state_tier.summary|default('State regulation context not yet audited.') }}</div>
        {% if state_tier.citation %}<div class="citation">{{ state_tier.citation }}<br>verified {{ state_tier.verified|default('') }}</div>{% endif %}
      {% else %}
        <div class="tier">Tier ? · <em>{{ merchant.state }}</em></div>
        <div style="margin-top:4px;color:var(--ink-3)">State regulation context unavailable on this deal.</div>
      {% endif %}

      <div style="margin-top:14px">
        {% if ofac_status == 'clean' %}<span class="pill ok">OFAC ✓ clean</span>
        {% elif ofac_status == 'match' %}<span class="pill bad">OFAC ✗ match</span>
        {% elif ofac_status == 'unavailable' %}<span class="pill warn">OFAC stale</span>
        {% else %}<span class="pill warn">OFAC pending</span>{% endif %}
        {% if merchant.is_renewal %}<span class="pill warn">renewal</span>{% endif %}
      </div>
    </div>

    {% if documents %}
      <div class="compliance">
        <h4>Statements · {{ documents|length }}</h4>
        <div class="doc-list">
          {% for entry in documents %}
            {% set d = entry.document %}
            {% set a = entry.analysis %}
            <a href="/ui/documents/{{ d.id }}" style="display:block;color:var(--accent);border-bottom:0;padding:2px 0">
              {% if a %}
                {{ a.statement_period_start.strftime('%b %Y') }} · <span class="stat-{{ d.parse_status }}">{{ d.parse_status }}</span>
              {% else %}
                (uploaded {{ d.uploaded_at.strftime('%Y-%m-%d') }}) · <span class="stat-{{ d.parse_status }}">{{ d.parse_status }}</span>
              {% endif %}
            </a>
          {% endfor %}
        </div>
      </div>
    {% endif %}

    <div class="compliance">
      <h4>Cross-references</h4>
      <div class="crosslink">
        <a href="/ui/merchants/{{ merchant.id }}/findings.csv">↗ Findings (audit CSV)</a>
        {% if _actions_locked %}
          <span title="{{ _locked_title }}" aria-disabled="true" style="color:var(--ink-3);cursor:not-allowed">↗ Funder match panel</span>
        {% else %}
          <a href="/ui/merchants/{{ merchant.id }}/match">↗ Funder match panel</a>
        {% endif %}
        <a href="/ui/merchants/{{ merchant.id }}/edit">↗ Edit merchant</a>
        {% if merchant.close_lead_id %}<a href="https://app.close.com/lead/{{ merchant.close_lead_id }}/" target="_blank" rel="noopener noreferrer">↗ Close lead {{ merchant.close_lead_id }}</a>{% endif %}
      </div>
      {% if merchant.close_lead_id %}
      <div class="crosslink close-rescan">
        <form method="post" action="/ui/merchants/{{ merchant.id }}/close-rescan" class="inline">
          <button type="submit">↻ Rescan Close attachments</button>
        </form>
        {% if close_last_orchestration_capped %}
        <form method="post" action="/ui/merchants/{{ merchant.id }}/close-rescan?override_cap=true" class="inline">
          <button type="submit" title="Last run hit the 15-attachment cap; this run processes all of them">⚠ Rescan all (override cap)</button>
        </form>
        {% endif %}
      </div>
      {% endif %}
      {# Migration 065 — operator soft-delete. Posts a plain form (no
         HTMX) so the dossier survives without JS; native confirm() is
         the codebase's de-facto destructive-action pattern (no modal
         infra mounted on the dossier). Sets merchants.deleted_at and
         redirects to the merchants list. The underlying row + its
         documents / analyses / decisions / audit log are preserved
         forever — only the operator surface hides them. #}
      <div class="crosslink delete-merchant">
        <form method="post"
              action="/ui/merchants/{{ merchant.id }}/delete"
              class="inline"
              data-test-id="merchant-delete-form"
              onsubmit="return confirm('Delete this merchant from the dossier?\n\nThe underlying records (documents, statements, decisions, audit log) are preserved. The merchant will simply disappear from every list. This cannot be undone from the dashboard.');">
          <button type="submit"
                  data-test-id="merchant-delete-button"
                  title="Soft-delete this merchant — hides from all lists; underlying data preserved"
                  style="color:var(--decline)">
            ✕ Delete merchant
          </button>
        </form>
      </div>
    </div>
  </aside>

  {# ============ main ============ #}
  <main class="main">

    {# 2026-06-28 — 60/40 split wrapper.
       Left column (60%): Verdict (with Track A/B/C inline via
       _unified_tracks_panel) → Cashflow evidence → Pattern findings —
       the analytical narrative the underwriter reads top-to-bottom.
       Right column (40%): Background checks → Funder matching →
       Statements ledger → Merchant profile — the lookup-table layer
       the underwriter references against the narrative.
       Below the wrapper, Disposition / Submissions / Operator notes
       resume full-width so they span the whole page. #}
    <div class="dossier-main-grid" data-test-id="dossier-main-two-col">
    <div class="dossier-col-left">

    {# ============== § 1 VERDICT ============== #}
    <section id="verdict" class="section">
      <header>
        <span class="n">§ 1</span>
        <h2>The verdict
          {% if score_result %}<em>· {{ score_result.recommendation }} </em>{% endif %}
        </h2>
        <span class="footnote">
          {% if score_window %}scored across {{ score_window.months_used }} month{{ '' if score_window.months_used == 1 else 's' }}{% else %}awaiting analysis{% endif %}
        </span>
        {# Operator-override button (mp Phase 10 / migration 072).
           Visible when the latest doc is in proceed/decline; manual_review
           is already operator-driven and pending/error/review have no
           recommendation to override yet. Opens an inline HTMX modal that
           POSTs to /ui/merchants/{id}/documents/{doc_id}/override and
           HX-Redirects back to the dossier on success. #}
        {% if show_override_button and document %}
          <a href="#override-modal"
             class="btn small"
             data-test-id="override-recommendation-btn"
             style="margin-left:auto;border:1px solid var(--rule,#d8d8d4);padding:6px 12px;border-radius:4px;font-size:11px;text-transform:uppercase;letter-spacing:0.08em;color:var(--ink-1);background:var(--ink-bg,#fafaf7);text-decoration:none">
            Override recommendation
          </a>
        {% endif %}
      </header>

      {# Override modal. CSS-only :target affordance — anchor click sets
         #override-modal in the URL fragment and the modal becomes visible;
         clicking the X / backdrop navigates to # (back to top) and hides
         it. Form posts via HTMX so the redirect lands without a full
         page reload. #}
      {% if show_override_button and document %}
        <div id="override-modal" class="override-modal-backdrop"
             style="display:none;position:fixed;inset:0;background:rgba(20,20,16,0.45);z-index:1000;align-items:center;justify-content:center"
             data-test-id="override-modal">
          <style>
            .override-modal-backdrop:target { display:flex !important; }
            .override-modal-body { background:#fafaf7; max-width:560px; width:90%; max-height:88vh; overflow-y:auto; padding:24px 28px; border:1px solid #d8d8d4; border-radius:6px; box-shadow:0 4px 32px rgba(0,0,0,0.18); }
            .override-modal-body h3 { margin:0 0 8px; font-size:18px; }
            .override-modal-body .muted { color:#6b6b66; font-size:12px; }
            .override-modal-body label { display:block; margin-top:14px; font-size:12px; text-transform:uppercase; letter-spacing:0.08em; color:#3d3d38; }
            .override-modal-body input[type=radio] { margin-right:6px; }
            .override-modal-body select, .override-modal-body textarea, .override-modal-body input[type=text] { width:100%; padding:8px; border:1px solid #d8d8d4; border-radius:4px; font:inherit; font-size:13px; box-sizing:border-box; margin-top:4px; }
            .override-modal-body textarea { min-height:80px; resize:vertical; }
            .override-modal-body .fp-list { margin-top:6px; padding:8px 12px; border:1px solid #d8d8d4; border-radius:4px; background:#fff; max-height:160px; overflow-y:auto; }
            .override-modal-body .fp-list label { text-transform:none; letter-spacing:0; font-size:12px; color:#1d1d18; display:flex; gap:8px; align-items:center; margin-top:6px; }
            .override-modal-body .fp-list label:first-child { margin-top:0; }
            .override-modal-body .row-buttons { display:flex; gap:10px; justify-content:flex-end; margin-top:20px; }
            .override-modal-body .row-buttons .btn-cancel { padding:8px 14px; border:1px solid #d8d8d4; border-radius:4px; color:#3d3d38; background:#fff; text-decoration:none; font-size:12px; text-transform:uppercase; letter-spacing:0.08em; }
            .override-modal-body .row-buttons button { padding:8px 16px; border:1px solid #1d1d18; border-radius:4px; background:#1d1d18; color:#fafaf7; cursor:pointer; font-size:12px; text-transform:uppercase; letter-spacing:0.08em; }
          </style>
          <div class="override-modal-body">
            <h3>Override recommendation</h3>
            <p class="muted">
              Current parse status: <strong>{{ document.parse_status }}</strong>.
              Your decision will replace it.
            </p>
            <form method="post"
                  action="/ui/merchants/{{ merchant.id }}/documents/{{ document.id }}/override"
                  hx-post="/ui/merchants/{{ merchant.id }}/documents/{{ document.id }}/override"
                  hx-swap="none">
              <input type="hidden" name="original_recommendation" value="{{ document.parse_status }}">
              {% if override_latest_decision_id %}
                <input type="hidden" name="decision_id" value="{{ override_latest_decision_id }}">
              {% endif %}

              <label>Decision</label>
              <div style="margin-top:6px">
                <label style="display:inline; text-transform:none; letter-spacing:0; font-size:13px; color:#1d1d18">
                  <input type="radio" name="operator_decision" value="approve" required> Approve
                </label>
                <label style="display:inline; margin-left:16px; text-transform:none; letter-spacing:0; font-size:13px; color:#1d1d18">
                  <input type="radio" name="operator_decision" value="decline" required> Decline
                </label>
              </div>

              <label for="override-reason-code">Reason</label>
              <select name="reason_code" id="override-reason-code" required>
                <option value="">— pick one —</option>
                <option value="score_too_conservative">Score too conservative</option>
                <option value="score_too_aggressive">Score too aggressive</option>
                <option value="funder_specific_fit">Funder-specific fit</option>
                <option value="merchant_context_external">External merchant context</option>
                <option value="data_quality_concern">Data-quality concern</option>
                <option value="pattern_false_positive">Pattern false positive</option>
                <option value="pattern_false_negative">Pattern false negative</option>
                <option value="gut">Gut call</option>
              </select>

              <label for="override-reason-detail">Note (optional)</label>
              <textarea name="reason_detail" id="override-reason-detail" maxlength="2000" placeholder="What does AEGIS miss / get wrong here?"></textarea>

              {% if override_pattern_codes %}
                <label>Pattern false positives (mark detectors that fired wrongly)</label>
                <div class="fp-list" data-test-id="override-pattern-fp-list">
                  {% for code in override_pattern_codes %}
                    <label>
                      <input type="checkbox" name="pattern_false_positives" value="{{ code }}">
                      <code>{{ code }}</code>
                    </label>
                  {% endfor %}
                </div>
              {% endif %}

              <div class="row-buttons">
                <a href="#" class="btn-cancel">Cancel</a>
                <button type="submit" data-test-id="override-submit-btn">Record override</button>
              </div>
            </form>
          </div>
        </div>
      {% endif %}

      {% if score_result %}
        <div class="verdict">
          <div class="anchor tier-{{ score_result.tier }}">
            <span class="letter">{{ score_result.tier }}</span>
            <span class="stamp">tier · {{ score_result.recommendation }}</span>
          </div>

          <div class="narrative">
            <p class="lede">
              {# Auto-generated narrative based on the score. Concise and human. #}
              {% if score_result.recommendation == 'approve' %}
                Cashflow is <strong>fundable</strong>.
              {% elif score_result.recommendation == 'refer' %}
                Cashflow is <strong>steady but conditional</strong>.
              {% else %}
                Cashflow <strong class="accent">does not clear</strong> AEGIS gates.
              {% endif %}

              {% if analysis %}
                Average daily balance is <strong>{{ analysis.avg_daily_balance | whole_money }}</strong>, monthly revenue runs near <strong>{{ analysis.monthly_revenue | whole_money }}</strong>, and the statement shows <strong>{{ analysis.num_nsf }}</strong> NSF event{{ '' if analysis.num_nsf == 1 else 's' }} over <strong>{{ analysis.days_negative }}</strong> day{{ '' if analysis.days_negative == 1 else 's' }} of negative balance.
              {% endif %}

              {% if score_result.recommendation == 'approve' %}
                Routing proceeds to <em>funder matching</em>.
              {% elif score_result.recommendation == 'refer' %}
                Recommend <em>manager sign-off</em> before submission &mdash; full revenue base supports the requested advance, but the soft concerns below warrant a sized-down counter.
              {% else %}
                {% if score_result.hard_decline_reasons %}
                  {# Summary preview shows the humanized TITLE of each top-2
                     reason. The full description renders below in the
                     detailed Hard Declines list. Same humanizer source
                     (`_pattern_cards.HARD_DECLINE_COPY`); titles only here
                     so the summary stays a one-line lede. #}
                  Hard decline driven by: <span class="accent">{% for reason in score_result.hard_decline_reasons[:2] %}{{ (reason|humanize_hard_decline).title }}{% if not loop.last %}, {% endif %}{% endfor %}{% if score_result.hard_decline_reasons|length > 2 %} <details class="reasons-more"><summary>and {{ score_result.hard_decline_reasons|length - 2 }} more</summary><span class="reasons-more-extras">, {% for reason in score_result.hard_decline_reasons[2:] %}{{ (reason|humanize_hard_decline).title }}{% if not loop.last %}, {% endif %}{% endfor %}</span></details>{% endif %}</span>.
                {% endif %}
              {% endif %}
            </p>

            {# ============== Document checklist (Feature 2) ============== #}
            {# Three on-file flags from migration 061 — voided check,
               driver's license, N months of bank statements. Plus, if
               the top matched funder requires a document that's missing,
               a warning banner is rendered above the Submit-to-Funder
               button. The route 400s if the operator clicks Submit
               while warnings are live, so this banner is the user-
               friendly preview of that gate. #}
            <div class="doc-checklist" data-test-id="doc-checklist"
                 style="margin:14px 0;padding:12px 14px;border:1px solid var(--ink-4, #d8d8d4);border-radius:6px;background:var(--ink-bg, #fafaf7)">
              <div class="doc-checklist-row" style="display:flex;gap:14px;flex-wrap:wrap;align-items:center;font-size:12px">
                <strong style="text-transform:uppercase;letter-spacing:0.08em;font-size:11px;color:var(--ink-3)">Documents on file</strong>
                <span class="chip {% if doc_checklist.voided_check_on_file %}pos{% else %}neg{% endif %}"
                      data-flag="voided_check_on_file">
                  {% if doc_checklist.voided_check_on_file %}&check;{% else %}&times;{% endif %}
                  Voided check
                </span>
                <span class="chip {% if doc_checklist.drivers_license_on_file %}pos{% else %}neg{% endif %}"
                      data-flag="drivers_license_on_file">
                  {% if doc_checklist.drivers_license_on_file %}&check;{% else %}&times;{% endif %}
                  Driver's license
                </span>
                <span class="chip {% if doc_checklist.bank_statements_months > 0 %}info{% else %}neg{% endif %}"
                      data-flag="bank_statements_months">
                  {{ doc_checklist.bank_statements_months }} month{% if doc_checklist.bank_statements_months != 1 %}s{% endif %} of statements
                </span>
                <a href="/ui/merchants/{{ merchant.id }}/edit" style="font-size:11px;color:var(--accent);border-bottom:0;text-transform:uppercase;letter-spacing:0.1em">edit ↗</a>
              </div>
              {# Sprint 6 Track A — bucketed stipulations rendered as
                 red/green/yellow chips. ``stips_result`` is None when
                 the merchant isn't yet scoreable or no funder matches;
                 the legacy completeness_warnings list is gone. Green
                 chips: required + on-file. Red chips: required + not
                 on-file (structured kinds only — operator toggles the
                 flag to clear). Yellow chips: unknown bullets — operator
                 confirms visually. Hard-unknown items also gate
                 Submit-to-Funder (see merchants router). #}
              {% if stips_result and (stips_result.on_file or stips_result.missing or stips_result.unknown) %}
                <div class="stipulations" data-test-id="stipulations"
                     style="margin-top:10px;padding:10px 12px;border-left:3px solid var(--rule, #d8d8d4);background:var(--ink-bg, #fafaf7);font-size:12px">
                  <strong>Stipulations{% if top_matched_funder_name %} ({{ top_matched_funder_name }}){% endif %}:</strong>
                  <div style="display:flex;flex-wrap:wrap;gap:6px;margin-top:6px">
                    {% for s in stips_result.on_file %}
                      <span class="chip pos"
                            data-stip-kind="{{ s.kind }}"
                            data-stip-bucket="on_file"
                            title="On file">&check; {{ s.requirement_text }}</span>
                    {% endfor %}
                    {% for s in stips_result.missing %}
                      {% if s.kind != 'unknown' %}
                        <span class="chip bad"
                              data-stip-kind="{{ s.kind }}"
                              data-stip-bucket="missing"
                              title="Missing — toggle on edit">&times; {{ s.requirement_text }}</span>
                      {% endif %}
                    {% endfor %}
                    {% for s in stips_result.unknown %}
                      <span class="chip warn"
                            data-stip-kind="unknown"
                            data-stip-bucket="unknown"
                            data-stip-hard="{{ 'true' if s.is_hard else 'false' }}"
                            title="Operator review">&#9888; {{ s.requirement_text }} (operator review)</span>
                    {% endfor %}
                  </div>
                  {% if stips_result.missing %}
                    <div style="margin-top:6px;color:var(--ink-3);font-size:11px">
                      Submit-to-Funder will refuse until each red stipulation is on file. Toggle on
                      <a href="/ui/merchants/{{ merchant.id }}/edit" style="color:var(--accent);border-bottom:0">edit</a>.
                    </div>
                  {% endif %}
                </div>
              {% endif %}
            </div>

            {# ============== Context panel (Feature D — migration 064) ============== #}
            {# Operator-editable ``deal_context`` textarea + read-only
               blocks for the three Close-derived context fields. Sits
               strictly below the chips section so the underwriter has
               the score + docs + stips picture before being asked to
               write deal context. The read-only blocks surface the
               Close lead description + most-recent notes + most-recent
               call transcripts that get injected into the Bedrock
               extraction prompt — the underwriter can preview the
               exact context the LLM will see. #}
            <section class="dossier-context-panel"
                     data-test-id="dossier-context-panel"
                     style="margin:14px 0;padding:12px 14px;border:1px solid var(--ink-4, #d8d8d4);border-radius:6px;background:var(--ink-bg, #fafaf7)">
              <header style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:8px">
                <strong style="text-transform:uppercase;letter-spacing:0.08em;font-size:11px;color:var(--ink-3)">Deal &amp; Close context</strong>
                <span class="footnote" style="font-size:11px;color:var(--ink-3)">injected into extraction prompts</span>
              </header>

              <form method="post"
                    action="/ui/merchants/{{ merchant.id }}/deal-context"
                    class="deal-context-form"
                    style="margin-bottom:10px">
                <label for="deal-context-textarea" style="display:block;font-size:11px;color:var(--ink-3);margin-bottom:4px">
                  Operator notes (free-form context about the deal)
                </label>
                <textarea id="deal-context-textarea"
                          name="deal_context"
                          rows="3"
                          maxlength="8000"
                          placeholder="Broker quirks, processor exclusions, prior pricing, anything that helps the LLM read the statements …"
                          style="width:100%;font-family:inherit;font-size:12px;padding:6px 8px;border:1px solid var(--ink-4, #d8d8d4);border-radius:4px">{{ merchant.deal_context or '' }}</textarea>
                <div style="margin-top:6px">
                  <button type="submit" style="font-size:11px">Save context</button>
                </div>
              </form>

              <div class="close-context-readonly" data-test-id="close-context-readonly">
                {% if merchant.close_lead_id %}
                  <form method="post"
                        action="/ui/merchants/{{ merchant.id }}/close-context/refresh"
                        style="float:right;margin:0">
                    <button type="submit"
                            data-test-id="refresh-close-context"
                            style="font-size:11px">↻ Refresh Close fields</button>
                  </form>
                {% endif %}

                <div class="context-block" data-field="close_lead_description" style="margin-bottom:8px">
                  <div style="font-size:11px;color:var(--ink-3);text-transform:uppercase;letter-spacing:0.05em;margin-bottom:3px">Close lead description</div>
                  {% if merchant.close_lead_description %}
                    <pre style="white-space:pre-wrap;font-family:inherit;font-size:12px;margin:0;padding:6px 8px;border-left:3px solid var(--rule, #d8d8d4);background:rgba(0,0,0,0.02)">{{ merchant.close_lead_description }}</pre>
                  {% else %}
                    <span style="color:var(--ink-3);font-size:11px;font-style:italic">— not set —</span>
                  {% endif %}
                </div>

                <div class="context-block" data-field="close_notes_summary" style="margin-bottom:8px">
                  <div style="font-size:11px;color:var(--ink-3);text-transform:uppercase;letter-spacing:0.05em;margin-bottom:3px">Recent Close notes</div>
                  {% if merchant.close_notes_summary %}
                    <pre style="white-space:pre-wrap;font-family:inherit;font-size:12px;margin:0;padding:6px 8px;border-left:3px solid var(--rule, #d8d8d4);background:rgba(0,0,0,0.02);max-height:200px;overflow-y:auto">{{ merchant.close_notes_summary }}</pre>
                  {% else %}
                    <span style="color:var(--ink-3);font-size:11px;font-style:italic">— no recent notes pulled —</span>
                  {% endif %}
                </div>

                <div class="context-block" data-field="close_call_transcripts">
                  <div style="font-size:11px;color:var(--ink-3);text-transform:uppercase;letter-spacing:0.05em;margin-bottom:3px">Recent call summaries</div>
                  {% if merchant.close_call_transcripts %}
                    <pre style="white-space:pre-wrap;font-family:inherit;font-size:12px;margin:0;padding:6px 8px;border-left:3px solid var(--rule, #d8d8d4);background:rgba(0,0,0,0.02);max-height:200px;overflow-y:auto">{{ merchant.close_call_transcripts }}</pre>
                  {% else %}
                    <span style="color:var(--ink-3);font-size:11px;font-style:italic">— no recent calls pulled —</span>
                  {% endif %}
                </div>
              </div>
            </section>

            {# ============== Web presence panel (migration 067) ============== #}
            {# Reputation scan via Bedrock + web_search. ``risk_flags``
               surface as ``FunderMatch.soft_concerns`` via
               ``match_funder`` so the underwriter sees them next to the
               other concerns; this panel just gives them the human-
               readable summary and a Refresh button. #}
            <section class="dossier-web-presence-panel"
                     data-test-id="dossier-web-presence-panel"
                     style="margin:14px 0;padding:12px 14px;border:1px solid var(--ink-4, #d8d8d4);border-radius:6px;background:var(--ink-bg, #fafaf7)">
              <header style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:8px">
                <strong style="text-transform:uppercase;letter-spacing:0.08em;font-size:11px;color:var(--ink-3)">Web presence</strong>
                <form method="post"
                      action="/ui/merchants/{{ merchant.id }}/refresh-web-presence"
                      style="margin:0">
                  <button type="submit"
                          data-test-id="refresh-web-presence"
                          style="font-size:11px">↻ Refresh</button>
                </form>
              </header>

              {% if merchant.web_presence_scanned_at %}
                <div style="font-size:11px;color:var(--ink-3);margin-bottom:6px">
                  scanned {{ merchant.web_presence_scanned_at.strftime('%Y-%m-%d %H:%M UTC') }}
                </div>
                {% if merchant.web_presence_summary %}
                  <p data-test-id="web-presence-summary"
                     style="margin:0 0 8px 0;font-size:12px;line-height:1.4">{{ merchant.web_presence_summary }}</p>
                {% else %}
                  <p style="margin:0 0 8px 0;font-size:11px;color:var(--ink-3);font-style:italic">— no summary returned —</p>
                {% endif %}
                {% if merchant.web_presence_flags %}
                  <div data-test-id="web-presence-flags" style="display:flex;flex-wrap:wrap;gap:4px">
                    {% for flag in merchant.web_presence_flags %}
                      <span class="chip chip-warn"
                            style="display:inline-block;padding:2px 8px;border-radius:10px;background:#fde7d4;color:#7a3b00;font-size:11px;font-family:var(--mono, monospace)">{{ flag }}</span>
                    {% endfor %}
                  </div>
                {% else %}
                  <span style="font-size:11px;color:var(--ink-3);font-style:italic">no risk flags</span>
                {% endif %}
              {% else %}
                <p data-test-id="web-presence-empty"
                   style="margin:0;font-size:11px;color:var(--ink-3);font-style:italic">
                  Not yet scanned. The next score will trigger an automatic scan;
                  click Refresh to scan now.
                </p>
              {% endif %}
            </section>

            {# ============== Legal & UCC panel (migration 068) ============== #}
            {# UCC filings + previous-default search via Bedrock + web_search.
               Soft signal only - both lists surface as match_funder
               soft_concerns. This panel renders the operator-readable
               source summary + a chip per finding + a Refresh button. #}
            <section class="dossier-ucc-panel"
                     data-test-id="dossier-ucc-panel"
                     style="margin:14px 0;padding:12px 14px;border:1px solid var(--ink-4, #d8d8d4);border-radius:6px;background:var(--ink-bg, #fafaf7)">
              <header style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:8px">
                <strong style="text-transform:uppercase;letter-spacing:0.08em;font-size:11px;color:var(--ink-3)">Legal &amp; UCC</strong>
                <form method="post"
                      action="/ui/merchants/{{ merchant.id }}/refresh-ucc"
                      style="margin:0">
                  <button type="submit"
                          data-test-id="refresh-ucc"
                          style="font-size:11px">↻ Refresh</button>
                </form>
              </header>

              {% if merchant.ucc_checked_at %}
                <div style="font-size:11px;color:var(--ink-3);margin-bottom:6px">
                  checked {{ merchant.ucc_checked_at.strftime('%Y-%m-%d %H:%M UTC') }}
                </div>
                {% if merchant.ucc_filings %}
                  <div data-test-id="ucc-filings" style="margin-bottom:6px">
                    <div style="font-size:11px;color:var(--ink-3);text-transform:uppercase;letter-spacing:0.05em;margin-bottom:3px">UCC filings</div>
                    {% for party in merchant.ucc_filings %}
                      <span style="display:inline-block;padding:2px 8px;border-radius:10px;background:#fde7d4;color:#7a3b00;font-size:11px;font-family:var(--mono, monospace);margin-right:4px;margin-bottom:2px">{{ party }}</span>
                    {% endfor %}
                  </div>
                {% endif %}
                {% if merchant.ucc_default_indicators %}
                  <div data-test-id="ucc-default-indicators" style="margin-bottom:6px">
                    <div style="font-size:11px;color:var(--ink-3);text-transform:uppercase;letter-spacing:0.05em;margin-bottom:3px">Previous default indicators</div>
                    {% for indicator in merchant.ucc_default_indicators %}
                      <span style="display:inline-block;padding:2px 8px;border-radius:10px;background:#f7c8c8;color:#7a0000;font-size:11px;font-family:var(--mono, monospace);margin-right:4px;margin-bottom:2px">{{ indicator }}</span>
                    {% endfor %}
                  </div>
                {% endif %}
                {% if not merchant.ucc_filings and not merchant.ucc_default_indicators %}
                  <p style="margin:0;font-size:11px;color:var(--ink-3);font-style:italic">No UCC filings or default indicators found.</p>
                {% endif %}
              {% else %}
                <p data-test-id="ucc-empty"
                   style="margin:0;font-size:11px;color:var(--ink-3);font-style:italic">
                  Not yet checked. The next score will trigger an automatic check;
                  click Refresh to check now.
                </p>
              {% endif %}
            </section>

            <div class="actions">
              {# Phase 7B inline-match (2026-06-19): the standalone match
                 link + global Submit-to-Funder button were retired from
                 this action row. Funder matching now renders inline in
                 § 4 below; per-funder Submit buttons sit on each card.
                 The standalone /match page is still reachable from the
                 Cross-references block for direct linking. #}
              <a class="btn primary" href="#routing">Funder matching ↓</a>
              <a class="btn" href="/ui/merchants/{{ merchant.id }}/edit">Edit deal terms</a>
              <a class="btn" href="/ui/merchants/{{ merchant.id }}/findings.csv">Audit CSV</a>
              <a class="btn" href="/ui/merchants/{{ merchant.id }}/dossier.pdf">Download PDF dossier</a>
            </div>

            <div class="byline">
              <span>filed by aegis · auto-scored</span>
              <span>
                {% if score_window %}window {{ score_window.period_start }} → {{ score_window.period_end }}{% endif %}
              </span>
            </div>
          </div>

          <div class="scoreboard">
            <div class="row">
              <span class="k">Composite</span>
              <span class="v">{{ score_result.score }}<span class="small">/100</span></span>
              <span class="qual">trailing window {% if score_window %}· {{ score_window.months_used }} month{{ '' if score_window.months_used == 1 else 's' }}{% endif %}</span>
            </div>
            <div class="row">
              <span class="k">Paper grade</span>
              <span class="v paper-grade paper-grade-{{ score_result.paper_grade|lower }}">{{ score_result.paper_grade }}</span>
              <span class="qual">
                {% if score_result.paper_grade == 'A' %}first-position prime &mdash; factor 1.15&ndash;1.25
                {% elif score_result.paper_grade == 'B' %}mainstream &mdash; factor 1.25&ndash;1.35
                {% elif score_result.paper_grade == 'C' %}sub-prime &mdash; factor 1.35&ndash;1.45
                {% else %}last-resort / high-decline band &mdash; factor 1.45&ndash;1.55{% endif %}
              </span>
            </div>
            {# 2026-06-28 — fraud_score row demoted from scoreboard. The
               retired single-axis score confused non-engineer underwriters
               ("0/100" read as "worst possible") and is no longer the
               decline driver (Track A integrity verdict + Track B band are,
               see scoring_v2/). Raw fraud_score still surfaces in the
               Statements ledger column for engineer audit. #}
            {% if unified_tracks and unified_tracks.integrity_worst_verdict %}
              <div class="row">
                <span class="k">Document integrity</span>
                <span class="v {% if unified_tracks.integrity_worst_verdict == 'fail' %}bad{% elif unified_tracks.integrity_worst_verdict == 'review' %}warn{% endif %}">
                  {% if unified_tracks.integrity_worst_verdict == 'fail' %}FAIL
                  {% elif unified_tracks.integrity_worst_verdict == 'review' %}REVIEW
                  {% elif unified_tracks.integrity_worst_verdict == 'clean' %}CLEAN
                  {% else %}—{% endif %}
                </span>
                <span class="qual">
                  {% if unified_tracks.integrity_worst_verdict == 'fail' %}Track A — request original bank export before submitting
                  {% elif unified_tracks.integrity_worst_verdict == 'review' %}Track A — verify integrity findings below
                  {% elif unified_tracks.integrity_worst_verdict == 'clean' %}Track A — statement appears unmodified
                  {% else %}Track A — no integrity signals captured{% endif %}
                </span>
              </div>
            {% endif %}
            <div class="row">
              <span class="k">Suggested max</span>
              <span class="v">{{ score_result.suggested_max_advance | whole_money }}</span>
              <span class="qual">tier × monthly revenue, $1k rounded</span>
            </div>
            <div class="row">
              <span class="k">Requested</span>
              <span class="v">{{ merchant.requested_amount | whole_money if merchant.requested_amount else '—' }}</span>
              <span class="qual">
                {% if merchant.requested_factor %}factor {{ merchant.requested_factor }}{% endif %}
                {% if merchant.requested_term_days %} · term {{ merchant.requested_term_days }} days{% endif %}
              </span>
            </div>
          </div>
        </div>

        {# Hard declines / soft concerns laid out below the verdict block.
           Reasons humanized through ``humanize_hard_decline`` /
           ``humanize_soft_concern`` (see ``_pattern_cards.HARD_DECLINE_COPY``
           / ``SOFT_CONCERN_COPY``). The raw identifier still renders as
           ``data-code`` for the audit CSV + browser-dev-tools query;
           the human-language title + description sit in front of it so
           a worker reading the dossier cold doesn't need a glossary
           tab open. #}
        {% if score_result.hard_decline_reasons or score_result.soft_concerns %}
          <div class="blockers">
            {% if score_result.hard_decline_reasons %}
              <h4 class="bad">Hard declines &mdash; {{ score_result.hard_decline_reasons|length }}</h4>
              <ul>
                {% for reason in score_result.hard_decline_reasons %}
                  {% set hr = reason|humanize_hard_decline %}
                  <li data-code="{{ hr.code }}">
                    <strong>{{ hr.title }}{% if hr.detail %} <span class="qual">· {{ hr.detail }}</span>{% endif %}</strong>
                    <span class="desc">— {{ hr.description }}</span>
                    {% if hr.code == 'ofac_sanctions_match' and score_result.decline_details.get('ofac_matches') %}
                      {% for m in score_result.decline_details.get('ofac_matches', []) %}
                        <span class="desc">— matched <strong>{{ m.matched_name }}</strong> on field <em>{{ m.input_field }}</em>{% if m.sdn_uid %} · <a href="https://sanctionssearch.ofac.treas.gov/Details.aspx?id={{ m.sdn_uid }}" target="_blank" rel="noopener">Treasury UID {{ m.sdn_uid }} ↗</a>{% endif %}</span>
                      {% endfor %}
                    {% endif %}
                  </li>
                {% endfor %}
              </ul>
            {% endif %}
            {% if score_result.soft_concerns %}
              <h4 class="warn">Soft concerns &mdash; {{ score_result.soft_concerns|length }}</h4>
              <ul>
                {% for concern in score_result.soft_concerns %}
                  {% set sc = concern|humanize_soft_concern %}
                  <li data-code="{{ sc.code }}">
                    <strong>{{ sc.title }}{% if sc.detail %} <span class="qual">· {{ sc.detail }}</span>{% endif %}</strong>
                    <span class="desc">— {{ sc.description }}</span>
                  </li>
                {% endfor %}
              </ul>
            {% endif %}
          </div>
        {% endif %}

        {# U18 — Operator review signals (shadow mode). Discreet
           ``<details>`` so the section stays collapsed by default and
           does not compete with hard-decline reasoning above. Every
           entry in this list is shadow-mode evidence (severity 0 on
           the parser side, no tier / decline impact on the scorer
           side). The operator-side rationale lives in the description
           sentence per ``aegis.web._flag_labels._FLAG_REGISTRY``;
           ``data-code`` carries the raw identifier for the audit CSV
           + browser-dev-tools query. #}
        {% if shadow_signals %}
          <details class="shadow-signals marginalia" data-shadow-count="{{ shadow_signals|length }}">
            <summary>Operator review signals (shadow mode) &mdash; {{ shadow_signals|length }}</summary>
            <ul>
              {% for hf in shadow_signals %}
                <li data-code="{{ hf.code }}">
                  <strong>{{ hf.title }}{% if hf.detail %} <span class="qual">· {{ hf.detail }}</span>{% endif %}</strong>
                  {% if hf.description %}<span class="desc">— {{ hf.description }}</span>{% endif %}
                </li>
              {% endfor %}
            </ul>
          </details>
        {% endif %}
      {% else %}
        <div class="marginalia">
          Score unavailable &mdash; no analyzed statement on file yet, or scoring failed during ingest. Upload at least one statement and refresh.
        </div>
      {% endif %}

      {# U22 — Merchant-level shadow signals persisted by the worker
         hook in ``merchants_shadow_signals`` (migration 044). Renders
         immediately after the U18 "Operator review signals" section
         above (and after the no-score "Score unavailable" branch) so
         the cross-statement / related-account signals U15 emitted at
         upload time are visible on the dossier regardless of whether
         the deal has reached the scoring step. Same humanizer + same
         shadow-only framing as the U18 section; ``detected_at`` is the
         persisted timestamp, ``data-signal-id`` ties the entry to its
         ``merchants_shadow_signals`` row for operator audit drill-down. #}
      {% if merchant_shadow_signals %}
        <details class="shadow-signals marginalia" data-merchant-shadow-count="{{ merchant_shadow_signals|length }}">
          <summary>Merchant-level shadow signals &mdash; {{ merchant_shadow_signals|length }}</summary>
          <ul>
            {% for mss in merchant_shadow_signals %}
              <li data-code="{{ mss.humanized.code }}" data-signal-id="{{ mss.record.id }}">
                <strong>{{ mss.humanized.title }}{% if mss.humanized.detail %} <span class="qual">· {{ mss.humanized.detail }}</span>{% endif %}</strong>
                {% if mss.humanized.description %}<span class="desc">— {{ mss.humanized.description }}</span>{% endif %}
                <span class="qual"> · detected {{ mss.record.detected_at.strftime('%Y-%m-%d %H:%M UTC') }}</span>
              </li>
            {% endfor %}
          </ul>
        </details>
      {% endif %}

      {# Unified A+B+C tracks panel — informational, additive.
         Renders alongside the score block above. #}
      {% if unified_tracks is defined and unified_tracks %}
        {% include "_unified_tracks_panel.html.j2" %}
      {% endif %}

      {# Statement coverage — surfaces the active (bank, last4) bundle, any
         alternate bundles for the merchant, and any missing months between
         the earliest and latest statement in the bundle. Always render when
         coverage data is present, even if scoring failed. #}
      {% if statement_coverage %}
        <div class="coverage marginalia">
          <h4>Statement coverage</h4>
          <p>
            {% set _bank = statement_coverage.bundle_bank_name %}
            {% set _last4 = statement_coverage.bundle_account_last4 %}
            {% if _bank or _last4 %}
              <strong>{{ _bank or 'Bank not detected' }}</strong>
              {% if _last4 %} · last4 <strong>{{ _last4 }}</strong>{% endif %}
            {% else %}
              <strong>Bank not detected</strong> &mdash; bundle unverified.
              Re-uploading statements with a visible bank name + account
              number lets AEGIS group them safely.
            {% endif %}
            &mdash; {{ statement_coverage.statements_in_bundle }} statement{{ '' if statement_coverage.statements_in_bundle == 1 else 's' }} bundled
            ({{ statement_coverage.period_start }} → {{ statement_coverage.period_end }}).
          </p>

          {% if statement_coverage.missing_months %}
            <p>
              <span class="warn">Coverage gaps:</span>
              {% for m in statement_coverage.missing_months %}
                <span class="chip warn">{{ m }}</span>
              {% endfor %}
            </p>
          {% endif %}

          {% if statement_coverage.bundle_options and statement_coverage.bundle_options|length > 1 %}
            <p>
              <span class="qual">Other accounts on file:</span>
              {% for opt in statement_coverage.bundle_options %}
                {% if not opt.is_active %}
                  <a href="/ui/merchants/{{ merchant.id }}?bundle={{ opt.query | urlencode }}">
                    {{ opt.bank_name or 'unknown bank' }}{% if opt.account_last4 %} · {{ opt.account_last4 }}{% endif %}
                    ({{ opt.count }})
                  </a>{% if not loop.last %} · {% endif %}
                {% endif %}
              {% endfor %}
            </p>
          {% endif %}
        </div>
      {% endif %}
    </section>

    {# ============== § 2 CASHFLOW EVIDENCE ============== #}
    {% if analysis %}
      <section id="evidence" class="section">
        <header>
          <span class="n">§ 2</span>
          <h2>Cashflow <em>evidence</em></h2>
          <span class="footnote">period {{ analysis.statement_period_start }} → {{ analysis.statement_period_end }} · {{ analysis.statement_days }} days</span>
        </header>

        <div class="spread">
          <div>
            <span class="k">True Revenue</span>
            <span class="v">{{ analysis.true_revenue | whole_money }}</span>
            <span class="qual">deposits net of transfers + chargebacks</span>
            <div class="drill">
              <button hx-get="/ui/documents/{{ document.id }}/aggregate/true_revenue" hx-target="#drilldown" hx-swap="innerHTML">drill down ↓</button>
            </div>
          </div>
          <div>
            <span class="k">Avg Daily Balance</span>
            <span class="v">{{ analysis.avg_daily_balance | whole_money }}</span>
            <span class="qual">time-weighted across the statement period</span>
            <div class="drill">
              <button hx-get="/ui/documents/{{ document.id }}/aggregate/avg_daily_balance" hx-target="#drilldown" hx-swap="innerHTML">drill down ↓</button>
            </div>
          </div>
          <div class="{% if analysis.num_nsf > 0 %}warn{% endif %}">
            <span class="k">NSF Count</span>
            <span class="v">{{ analysis.num_nsf }}</span>
            <span class="qual">non-sufficient-funds fees in the period</span>
            <div class="drill">
              <button hx-get="/ui/documents/{{ document.id }}/aggregate/num_nsf" hx-target="#drilldown" hx-swap="innerHTML">drill down ↓</button>
            </div>
          </div>
          <div class="{% if analysis.days_negative > 0 %}neg{% endif %}">
            <span class="k">Days Negative</span>
            <span class="v">{{ analysis.days_negative }}</span>
            <span class="qual">calendar days balance was below $0</span>
            <div class="drill">
              <button hx-get="/ui/documents/{{ document.id }}/aggregate/days_negative" hx-target="#drilldown" hx-swap="innerHTML">drill down ↓</button>
            </div>
          </div>
          <div class="{% if analysis.mca_daily_total > 0 %}warn{% endif %}">
            <span class="k">MCA Daily Total</span>
            <span class="v">{{ analysis.mca_daily_total | whole_money }}</span>
            <span class="qual">across {{ analysis.mca_positions }} active position{{ '' if analysis.mca_positions == 1 else 's' }}</span>
            <div class="drill">
              <button hx-get="/ui/documents/{{ document.id }}/aggregate/mca_daily_total" hx-target="#drilldown" hx-swap="innerHTML">drill down ↓</button>
            </div>
          </div>
          {# MCA stack chips — shadow-only decline triggers; live decline still
             governed by debt_to_revenue > 40% and mca_positions > 2 per
             score.py. Hidden when no MCA debits are detected. #}
          {% if mca_stack and mca_stack.active_mca_count > 0 %}
            <div class="{% if 'mca_stack_count_shadow' in (mca_stack.shadow_triggers | join(' ')) %}warn{% endif %}">
              <span class="k">Active MCA Counterparties</span>
              <span class="v">{{ mca_stack.active_mca_count }}</span>
              <span class="qual">distinct funder labels in the period</span>
            </div>
            <div class="warn">
              <span class="k">MCA Monthly Load</span>
              <span class="v">{{ mca_stack.mca_monthly_load | whole_money }}</span>
              <span class="qual">daily × 22 business days, all counterparties</span>
            </div>
            <div class="{% if 'mca_stack_overloaded_shadow' in (mca_stack.shadow_triggers | join(' ')) %}warn{% endif %}">
              <span class="k">Combined Holdback %</span>
              <span class="v">{% if mca_stack.estimated_combined_holdback_pct is none %}—{% else %}{{ mca_stack.estimated_combined_holdback_pct }}%{% endif %}</span>
              <span class="qual">monthly load / monthly revenue</span>
            </div>
            <div>
              <span class="k">Largest Single MCA</span>
              <span class="v">{{ mca_stack.largest_single_mca_monthly | whole_money }}</span>
              <span class="qual">{{ mca_stack.largest_single_mca_lender or '—' }} (monthly)</span>
            </div>
          {% endif %}
          {# Balance-health chips — shadow-only decline triggers; live decline
             still governed by days_negative > 15 per score.py. Hidden when
             the aggregation produced no balance data. #}
          {% if balance_health and balance_health.lowest_balance_date is not none %}
            <div class="{% if 'low_adb_shadow' in (balance_health.shadow_triggers | join(' ')) %}warn{% endif %}">
              <span class="k">ADB % of Deposits</span>
              <span class="v">{% if balance_health.adb_as_pct_of_monthly_deposits is none %}—{% else %}{{ balance_health.adb_as_pct_of_monthly_deposits }}%{% endif %}</span>
              <span class="qual">avg daily balance / monthly gross deposits</span>
            </div>
            <div class="{% if 'negative_days_shadow' in (balance_health.shadow_triggers | join(' ')) %}warn{% endif %}">
              <span class="k">Neg Days (trailing 3m)</span>
              <span class="v">{{ balance_health.negative_days_trailing_3m }}</span>
              <span class="qual">days with end-of-day balance ≤ 0 in last 90 days</span>
            </div>
          {% endif %}
          {# Suggested-offer chip — informational only; does not affect the
             live decline path. Hidden when the offer math returned None
             (sub-$5,000 floor or no remaining holdback capacity). The
             rationale renders as a sub-line so the underwriter sees the
             limiting factor (capacity cap / stack-overload discount /
             plain revenue multiple) inline with the amount. #}
          {% if offer %}
            <div>
              <span class="k">Suggested Offer</span>
              <span class="v">{{ offer.recommended_amount | whole_money }} – {{ offer.max_amount | whole_money }}</span>
              {% if offer.rationale %}
                <span class="qual">{{ offer.rationale }}</span>
              {% endif %}
            </div>
          {% endif %}
          {# Industry-tier chip — informational. Drawn from the merchant's
             Close-side Industry choice via aegis.scoring_v2.industry; the
             tier feeds Track B band adjustment elsewhere. Hidden when no
             industry is on file. Highlight when tier is high_volatility or
             hard_decline_class. #}
          {% if unified_tracks and unified_tracks.industry_tier %}
            <div class="{% if unified_tracks.industry_tier in ('high_volatility', 'hard_decline_class') %}warn{% endif %}">
              <span class="k">Industry Tier</span>
              <span class="v">{{ unified_tracks.industry_tier|replace('_', ' ') }}</span>
              <span class="qual">{{ unified_tracks.industry_tier_reason }}</span>
            </div>
          {% endif %}
          {# Multi-month trend chips (revenue_trends from
             aegis.scoring_v2.trends). Shadow-only: tokens do not
             feed the live decline path. Hidden when fewer than two
             months of data exist (months_compared < 2). #}
          {% if revenue_trends and revenue_trends.months_compared >= 2 %}
            <div class="{% if revenue_trends.revenue_trend == 'declining' %}warn{% endif %}">
              <span class="k">Revenue Trend</span>
              <span class="v">{{ revenue_trends.revenue_trend }}</span>
              <span class="qual">latest month vs prior · ±10% threshold</span>
            </div>
            <div class="{% if revenue_trends.adb_trend == 'declining' %}warn{% endif %}">
              <span class="k">ADB Trend</span>
              <span class="v">{{ revenue_trends.adb_trend }}</span>
              <span class="qual">latest month vs prior · ±10% threshold</span>
            </div>
            <div>
              <span class="k">NSF Trend</span>
              <span class="v">{{ revenue_trends.nsf_trend }}</span>
              <span class="qual">per-month NSF count · latest vs prior</span>
            </div>
          {% endif %}
        </div>
        {% if mca_stack and mca_stack.shadow_triggers %}
          <p class="marginalia">
            <strong>Shadow trigger{{ '' if mca_stack.shadow_triggers|length == 1 else 's' }}:</strong>
            {{ mca_stack.shadow_triggers | join(' · ') }}
            <em>(annotation only — live decline still governed by debt_to_revenue &gt; 40% / mca_positions &gt; 2)</em>
          </p>
        {% endif %}
        {% if balance_health and balance_health.shadow_triggers %}
          <p class="marginalia">
            <strong>Shadow trigger{{ '' if balance_health.shadow_triggers|length == 1 else 's' }}:</strong>
            {{ balance_health.shadow_triggers | join(' · ') }}
            <em>(annotation only — live decline still governed by days_negative &gt; 15)</em>
          </p>
        {% endif %}

        <div id="drilldown" class="drilldown-out"></div>

        {% if trend and trend.revenue_delta_pct is not none %}
          <p class="marginalia">
            Across {{ trend.statement_count }} statements, revenue is
            {% if trend.revenue_delta_pct > 0 %}up <strong>{{ trend.revenue_delta_pct }}%</strong>{% else %}down <strong>{{ trend.revenue_delta_pct }}%</strong>{% endif %}
            vs. the prior period
            {% if trend.adb_delta_pct is not none %}and average daily balance is {% if trend.adb_delta_pct > 0 %}up <strong>{{ trend.adb_delta_pct }}%</strong>{% else %}down <strong>{{ trend.adb_delta_pct }}%</strong>{% endif %}{% endif %}.
            {% if trend.nsf_delta is not none and trend.nsf_delta != 0 %}NSF count moved by {{ '+' if trend.nsf_delta > 0 }}{{ trend.nsf_delta }} events.{% endif %}
          </p>
        {% endif %}

        <div class="citation-strip">
          <strong>Source —</strong> all metrics on this page are derived deterministically from classified transactions on the underlying PDF statement. Every aggregate stores a list of contributing <code>transaction_id</code>s, each traceable to <code>source_page</code> + <code>source_line</code> on the original document. Click "drill down" on any metric to view the contributing rows with page/line citations.
        </div>
      </section>
    {% endif %}

    {# ============== § 2b PROCESSOR REVENUE ==============
       Renders only when a Stripe statement is present for the merchant.
       Sits alongside (not replacing) the bank-statement § 2 — card-heavy
       merchants will have both. #}
    {% include "_processor_revenue.html.j2" %}

    {# ============== § 3 PATTERN FINDINGS ============== #}
    {% if stacking or pattern_cards or (soft_signals and not soft_signals.is_empty) %}
      <section id="findings" class="section">
        <header>
          <span class="n">§ 3</span>
          <h2>Pattern <em>findings</em></h2>
          <span class="footnote">
            {{ (pattern_cards|length) + (1 if stacking else 0) }} pattern{{ '' if (pattern_cards|length) + (1 if stacking else 0) == 1 else 's' }} surfaced · severity descending
          </span>
        </header>

        {# stacking gets its own dossier-styled card (denser KPIs than a pattern). #}
        {% if stacking %}
          <article class="finding" style="grid-column:1 / -1">
            <div class="head">
              <h3>MCA stacking &mdash; {{ stacking.position_count }} active position{{ '' if stacking.position_count == 1 else 's' }}</h3>
              <span class="sev high">high · stacking detected</span>
            </div>
            <p class="desc">
              The debit stream shows {{ stacking.position_count }} distinct funder cadence{{ '' if stacking.position_count == 1 else 's' }} consistent with active MCA position{{ '' if stacking.position_count == 1 else 's' }}. Daily burden of <strong>${{ stacking.daily_total }}</strong> projects to roughly <strong>${{ stacking.monthly_burden }}/month</strong> across 22 business days.
            </p>
            <div class="stack-card">
              <div>
                <span class="k">Daily burden</span>
                <span class="v neg">${{ stacking.daily_total }}</span>
                <span class="qual">sum across positions</span>
              </div>
              <div>
                <span class="k">Monthly projection</span>
                <span class="v neg">${{ stacking.monthly_burden }}</span>
                <span class="qual">× 22 business days</span>
              </div>
              <div>
                <span class="k">Active positions</span>
                <span class="v">{{ stacking.position_count }}</span>
                <span class="qual">distinct funder cadences</span>
              </div>
              <div>
                <span class="k">MCA debits found</span>
                <span class="v">{{ stacking.debit_count }}</span>
                <span class="qual">across the period</span>
              </div>
              {% if stacking.mca_pct_of_deposits is not none %}
                <div title="Monthly MCA burden (daily × 22 business days) divided by monthly revenue. Values above 100% mean the debt-service stream exceeds incoming revenue — read as an underwriting red flag, not a render bug.">
                  <span class="k">MCA burden</span>
                  <span class="v {% if stacking.mca_pct_of_deposits > 100 %}neg{% endif %}">{{ stacking.mca_pct_of_deposits }}%</span>
                  <span class="qual">of monthly revenue</span>
                </div>
              {% endif %}
            </div>
            {% if stacking.debits %}
              <details>
                <summary>{{ stacking.debits|length }} debit{{ '' if stacking.debits|length == 1 else 's' }} across {{ stacking.position_count }} position{{ '' if stacking.position_count == 1 else 's' }} — click to expand</summary>
                {# Group by lender_label so the worker sees the per-funder
                   cadence rather than a flat date-sorted list. groupby
                   requires its input to be pre-sorted by the group
                   attribute. #}
                {% for lender, lender_debits in (stacking.debits|sort(attribute='lender_label'))|groupby('lender_label') %}
                  <details class="lender-group" open>
                    <summary>{{ lender }} &mdash; {{ lender_debits|length }} debit{{ '' if lender_debits|length == 1 else 's' }}</summary>
                    {# R4.8 (2026-06-09): table-scroll wrapper allows the
                       ledger to scroll horizontally on phones without
                       breaking the dossier's main column layout. #}
                    <div class="table-scroll">
                    <table class="ledger">
                      <thead>
                        <tr><th>Date</th><th>Amount</th><th>Source</th></tr>
                      </thead>
                      <tbody>
                        {% for d in lender_debits|sort(attribute='posted_date') %}
                          <tr>
                            <td>{{ d.posted_date }}</td>
                            <td class="amt">${{ d.amount }}</td>
                            <td class="cite">p{{ d.source_page }} L{{ d.source_line }}</td>
                          </tr>
                        {% endfor %}
                      </tbody>
                    </table>
                    </div>
                  </details>
                {% endfor %}
              </details>
            {% endif %}
          </article>
        {% endif %}

        {# pattern cards in two-column grid #}
        {% if pattern_cards %}
          <div class="findings">
            {% for card in pattern_cards %}
              <article class="finding">
                <div class="head">
                  <h3>{{ card.title }}</h3>
                  <span class="sev {% if card.severity >= 30 %}high{% elif card.severity >= 15 %}med{% else %}low{% endif %}">severity {{ card.severity }} / 100</span>
                </div>
                <p class="desc">{{ card.description }}</p>
                <div class="quote">
                  What we found: <strong>{{ card.detail }}</strong>
                </div>
                {% include "_evidence_panel.html.j2" %}
              </article>
            {% endfor %}
          </div>
        {% endif %}

        {# soft signals — concentration / payroll / NSF overlap.

           ``soft_signals.customer_concentration`` is sourced from the
           ``aggregate.py``-emitted ``top_counterparty_concentration:`` flag
           and is the SAME underlying fact the ``customer_concentration``
           Pattern detector emits. When both fire the dossier used to
           render two cards (v2 catalog Bucket B.1). Suppress the
           soft-signals one when the Pattern card is already on the page
           — the pattern card carries severity banding + source-row
           drill-down + the same top_payee + share_pct in its detail
           string, so the worker loses nothing. The legacy operator
           field ``customer_concentration_severe`` continues to render
           through the humanized soft-concern list above. #}
        {% if soft_signals and not soft_signals.is_empty %}
          <div class="findings" style="margin-top:36px">
            {% if soft_signals.customer_concentration and not has_concentration_pattern %}
              {% set cc = soft_signals.customer_concentration %}
              <article class="finding">
                <div class="head">
                  <h3>Customer concentration</h3>
                  <span class="sev {% if cc.share_pct >= 70 %}high{% elif cc.share_pct >= 50 %}med{% else %}low{% endif %}">{{ cc.share_pct }}% top payee</span>
                </div>
                <p class="desc">
                  The single largest deposit payer — <em>{{ cc.top_payee }}</em> — accounted for <strong>{{ cc.share_pct }}%</strong> of revenue this period.
                  {% if cc.share_pct >= 70 %}High concentration — if that customer leaves, revenue collapses.
                  {% elif cc.share_pct >= 50 %}Moderate concentration. Verify the relationship is contractual rather than one-off.
                  {% else %}Healthy diversification — top payer is under half of revenue.{% endif %}
                </p>
              </article>
            {% endif %}

            {% if soft_signals.payroll_cadence %}
              {% set pr = soft_signals.payroll_cadence %}
              <article class="finding">
                <div class="head">
                  <h3>Payroll cadence</h3>
                  <span class="sev low">{{ pr.cadence }}{% if pr.pct_of_revenue is not none %} · {{ pr.pct_of_revenue }}%{% endif %}</span>
                </div>
                <p class="desc">
                  Payroll runs <strong>{{ pr.cadence }}</strong>{% if pr.pct_of_revenue is not none %}, absorbing <strong>{{ pr.pct_of_revenue }}%</strong> of revenue{% endif %}.
                  {% if pr.cadence in ['weekly','biweekly'] %}Standard W-2 cadence; confirms an active workforce.
                  {% elif pr.cadence == 'monthly' %}Monthly payroll — less common for hourly-worker businesses.
                  {% else %}Irregular cadence. Could mean 1099 contractors, off-statement processor, or shrinking headcount.{% endif %}
                </p>
              </article>
            {% endif %}

            {% if soft_signals.nsf_negative_overlap %}
              {% set nso = soft_signals.nsf_negative_overlap %}
              <article class="finding">
                <div class="head">
                  <h3>NSF on negative-balance days</h3>
                  <span class="sev {% if nso.ratio_pct >= 50 %}high{% elif nso.ratio_pct >= 25 %}med{% else %}low{% endif %}">{{ nso.overlap }} of {{ nso.total }} ({{ nso.ratio_pct }}%)</span>
                </div>
                <p class="desc">
                  {{ nso.overlap }} of {{ nso.total }} NSF fees this period landed on days the account was already in the red.
                  {% if nso.ratio_pct >= 50 %}Majority are structural cashflow stress, not isolated processing accidents.
                  {% elif nso.ratio_pct >= 25 %}A meaningful share coincides with negative days — verify the merchant has a buffer plan.
                  {% else %}Most NSFs occurred on otherwise-positive days — more likely processing anomalies than stress.{% endif %}
                </p>
              </article>
            {% endif %}
          </div>
        {% endif %}

        {% if pattern_cards|length >= 2 %}
          <div class="pull-quote">
            {% if score_result and score_result.recommendation == 'approve' %}
              {{ pattern_cards|length }} pattern finding{{ '' if pattern_cards|length == 1 else 's' }}, none of consequence. The deal clears AEGIS gates with the soft concerns documented above.
            {% elif score_result and score_result.recommendation == 'refer' %}
              {{ pattern_cards|length }} pattern finding{{ '' if pattern_cards|length == 1 else 's' }} warrant a sized-down counter — fundable, but on tighter terms than requested.
            {% else %}
              {{ pattern_cards|length }} pattern finding{{ '' if pattern_cards|length == 1 else 's' }} block this deal from auto-approval. Hard declines must be addressed before resubmission.
            {% endif %}
            <span class="attr">— underwriting narrative · auto-generated</span>
          </div>
        {% endif %}
      </section>
    {% endif %}

    </div>{# /.dossier-col-left — Verdict + Cashflow + Findings #}
    <div class="dossier-col-right">

    {# Background-checks section (§ 3¾) sits between Track C (pattern
       findings + concentration) and § 4 (funder matching) so the
       underwriter sees the soft-signal layer (UCC filings / previous
       defaults / web presence / OFAC) BEFORE picking funders. Markup
       lives in ``_background_checks_section.html.j2`` so the two HTMX
       refresh routes can re-render the section in place without
       duplicating the inline block. Replaces the A1 visible-stub
       placeholder (``dossier-background-checks-stub``); the live
       section now exposes ``data-test-id="dossier-background-checks"``. #}
    {% include "_background_checks_section.html.j2" %}

    {# Migration 083 — OFAC SDN hard gate. Red banner replaces the
       funder-matching grid when ``ofac_blocked`` is true. The
       compliance team's call: a sanctioned merchant must not see a
       funder list, even a degraded one. Operator can refresh the
       check via the Background-checks ``Refresh`` button after
       resolving a false-positive with the compliance team. #}
    {% if ofac_blocked %}
      <section class="section section-blocked"
               data-test-id="dossier-ofac-block-banner"
               style="border:2px solid var(--danger,#b91c1c);
                      background:#fef2f2;
                      padding:16px;
                      border-radius:6px;">
        <header>
          <span class="n">⛔</span>
          <h2 style="color:var(--danger,#b91c1c);">OFAC SDN match —
              funder matching blocked</h2>
        </header>
        <p style="margin-top:8px;">
          This merchant matched the OFAC Specially Designated Nationals
          list (or the Consolidated Sanctions list). Funder matching is
          suppressed pending compliance review.
        </p>
        {% if ofac_match_detail %}
          <details style="margin-top:8px;">
            <summary>Match details ({{ ofac_match_detail|length }})</summary>
            <ul style="margin-top:8px;font-family:monospace;font-size:12px;">
              {% for m in ofac_match_detail %}
                <li>{{ m }}</li>
              {% endfor %}
            </ul>
          </details>
        {% endif %}
      </section>
    {% endif %}

    {# ============== § 4 FUNDER MATCHING (inline) ==============
       Phase 7B inline-match (2026-06-19). Lifted the side-by-side
       comparison from /ui/merchants/{id}/match into the dossier so the
       full underwriting workflow (score → see matches → submit) lands
       on one page. The standalone /match panel stays reachable for
       direct linking. Each card carries its own Submit button posting
       to /submit-to-funder with the funder_id form field; an HTMX swap
       converts the button to a "Submitted ✓" chip on success. #}
    {# PA A9 — product chip. Reads ``merchant.product_type``
       defensively via Jinja's missing-attr-is-falsy semantics; legacy
       rows pre-PA-A7 land on "revenue_based" and render the default
       label. The chip uses the existing system-chip CSS class. #}
    {% set _product_labels = {
      "revenue_based": "Revenue-based",
      "business_loan": "Business loan",
      "line_of_credit": "Line of credit",
      "equipment": "Equipment finance",
      "asset_based": "Asset-based",
      "receivables": "Receivables factoring",
    } %}
    {% set _product_type = (merchant.product_type|string) if merchant.product_type else "revenue_based" %}
    <section id="routing" class="section" data-test-id="dossier-funder-matching">
      <header>
        <span class="n">§ 4</span>
        <h2>Funder <em>matching</em></h2>
        <span class="chip" data-test-id="dossier-funder-matching-product-chip">Product: {{ _product_labels.get(_product_type, "Revenue-based") }}</span>
        <span class="footnote">
          {% if matched_funders %}{{ matched_funders|length }} active funder{{ '' if matched_funders|length == 1 else 's' }} considered{% else %}no matches yet{% endif %}
          &middot;
          <a href="/ui/merchants/{{ merchant.id }}/match" style="color:inherit">standalone view ↗</a>
        </span>
      </header>

      {# Phase E — trade-licensing gate. Replaces the per-funder Submit
         buttons with a verification banner when the merchant's
         industry_naics requires state licensure AND we know a verified
         portal URL for the state+industry. The operator clicks through
         to the state portal, verifies the license, and clicks "✓ Mark
         license verified" to unblock submission (HX-Refresh on success
         reloads the dossier with the gate cleared). Per AEGIS rule:
         when we don't know how to verify, the gate doesn't fire — never
         block with a wrong portal link. #}
      {% if license_gate and license_gate.required %}
        <div id="license-gate"
             class="alert manual-review-banner"
             data-test-id="dossier-license-gate"
             data-industry-key="{{ license_gate.industry_key }}"
             style="padding:10px 12px;margin-bottom:12px">
          <strong>⚠️ License verification required.</strong>
          Industry: <strong>{{ license_gate.industry_label }}</strong>
          &middot;
          State: <strong>{{ merchant.state }}</strong>
          <br>
          →
          <a href="{{ license_gate.portal_url }}"
             target="_blank"
             rel="noopener noreferrer"
             data-test-id="dossier-license-gate-portal-link">
            Search {{ license_gate.state_name or merchant.state }} licensing portal
          </a>
          <button class="btn"
                  type="button"
                  data-test-id="dossier-license-gate-verify-button"
                  hx-post="/ui/merchants/{{ merchant.id }}/verify-license"
                  hx-target="#license-gate"
                  hx-swap="outerHTML"
                  hx-confirm="Confirm: you've verified the merchant holds an active license on the state portal. This unblocks Submit-to-funder."
                  style="margin-left:8px">✓ Mark license verified</button>
        </div>
      {% endif %}

      {% if score_result and score_result.recommendation == 'decline' %}
        <div class="funder-summary" data-test-id="dossier-funder-matching-decline">
          <div class="copy">
            Deal is currently a hard decline &mdash; <em>no funders will be matched</em>. Resolve the hard-decline reasons above before routing.
          </div>
        </div>
      {% elif not matched_funders %}
        <div class="funder-summary" data-test-id="dossier-funder-matching-empty">
          <div class="copy">
            {# Fix 2 (2026-06-26) — distinguish three empty branches:
                 (a) merchant has an analysis row + a score → matcher
                     simply found no qualifying funder. Suggest import.
                 (b) merchant has an analysis row but no score yet
                     (manual_review-only, not finalized, etc.) → tell
                     the operator the matcher hasn't run.
                 (c) no analysis at all → original "not yet scoreable"
                     copy. #}
            {% if score_result %}
              No active funders match this merchant today. <a href="/ui/funders/import">Import a funder</a> or review the criteria comparison on the standalone match page.
            {% elif analysis %}
              Funder matching has not run for this deal yet. Verify the merchant is finalized and any integrity findings above, then refresh.
            {% else %}
              The deal isn&apos;t yet scoreable &mdash; upload at least one analyzed statement before funder matching runs.
            {% endif %}
          </div>
        </div>
      {% else %}
        {# Fix 2 (2026-06-26) — when every statement is manual_review and
           the matcher still returned cards, surface an amber banner so
           the underwriter verifies the integrity findings above before
           clicking Submit. Renders BEFORE the actions row + grid so it
           is the first thing the underwriter reads in this section. #}
        {% if all_statements_manual_review %}
          <div class="manual-review-banner"
               data-test-id="dossier-funder-matching-manual-review-banner">
            <strong>Statements in manual review.</strong>
            Funder matches below are based on the available analysis &mdash; verify integrity findings before submitting.
          </div>
        {% endif %}
        {# Fix 5 — stacking alert banner. Read mca_confirmed_count /
           mca_pattern_count off the unified Track B CashflowSignals
           (live, additive context); falls back to 0/0 when Track B
           isn't built (insufficient data or not-finalized merchant). #}
        {% set _cf = unified_tracks.risk_band.cashflow if unified_tracks and unified_tracks.risk_band else None %}
        {% set _mca_confirmed = (_cf.mca_confirmed_count if _cf else 0) or 0 %}
        {% set _mca_pattern = (_cf.mca_pattern_count if _cf else 0) or 0 %}
        {% if _mca_confirmed >= 1 %}
          <div class="stacking-alert stacking-alert--confirmed"
               data-test-id="dossier-stacking-alert"
               data-stacking-severity="confirmed">
            <strong>Confirmed MCA stack detected.</strong>
            {{ _mca_confirmed }} confirmed funder cadence{{ '' if _mca_confirmed == 1 else 's' }} on this account &mdash; resolve before sizing.
          </div>
        {% elif _mca_pattern >= 3 %}
          <div class="stacking-alert stacking-alert--pattern"
               data-test-id="dossier-stacking-alert"
               data-stacking-severity="pattern">
            <strong>Possible MCA stack.</strong>
            {{ _mca_pattern }} pattern-only debit cadences without a named funder &mdash; verify by calling the merchant before submitting.
          </div>
        {% endif %}
        <div class="funder-matching-actions"
             style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;margin:8px 0 14px;font-size:12px">
          <a class="btn"
             data-test-id="dossier-matched-funders-csv"
             href="/ui/merchants/{{ merchant.id }}/matched-funders.csv">↓ Matched-funders CSV</a>
          <span style="color:var(--ink-3);font-family:var(--mono);font-size:11px;letter-spacing:0.06em">
            paper trail of every funder considered &middot; deal metrics + match scores + estimated terms
          </span>
        </div>

        <div data-test-id="dossier-matched-funders-grid"
             style="display:grid;grid-template-columns:repeat(auto-fill,minmax(360px,1fr));gap:14px;margin-bottom:18px">
          {% for c in matched_funders %}
            {% set _color_var = 'var(--approve)' if c.color == 'green' else 'var(--review)' if c.color == 'yellow' else 'var(--decline)' %}
            {% set _already_submitted = c.funder_id in submitted_funder_ids %}
            <div data-test-id="dossier-matched-funder-card"
                 data-funder-id="{{ c.funder_id }}"
                 data-color="{{ c.color }}"
                 {% if c.is_marketplace %}data-marketplace="true"{% endif %}
                 style="border:1px solid var(--rule);border-left:3px solid {{ _color_var }};background:var(--paper);padding:14px 14px 12px;{% if c.color == 'green' and not c.is_marketplace %}box-shadow:0 0 0 1px color-mix(in oklch, var(--approve) 30%, transparent);{% endif %}">
              <div style="display:flex;justify-content:space-between;align-items:baseline;gap:10px;margin-bottom:8px">
                <span style="font-family:var(--serif);font-weight:500;font-size:15px;letter-spacing:-0.005em;color:var(--ink)">
                  <a href="/ui/funders/{{ c.funder_id }}" style="color:inherit;border-bottom:0">{{ c.funder_name }}</a>
                </span>
                {% if c.is_marketplace %}
                  {# Marketplace / aggregator funder — no published criteria
                     means the match score has nothing to evaluate against.
                     Surface the badge in place of the score so the operator
                     doesn't misread an empty match as a meaningful one. #}
                  <span class="chip"
                        data-test-id="dossier-matched-funder-marketplace-badge"
                        style="font-family:var(--mono);font-size:10px;letter-spacing:0.14em;text-transform:uppercase;background:var(--rule);color:var(--ink-2);padding:3px 8px">
                    Marketplace
                  </span>
                {% else %}
                  <span style="font-family:var(--serif);font-size:24px;font-weight:600;letter-spacing:-0.022em;color:{{ _color_var }};font-variant-numeric:tabular-nums">{{ c.match_score }}<span style="font-family:var(--mono);font-size:10px;color:var(--ink-3);margin-left:2px">/100</span></span>
                {% endif %}
              </div>

              {% if c.hard_reasons %}
                <div style="margin-top:8px">
                  <div style="font-family:var(--mono);font-size:9.5px;letter-spacing:0.16em;text-transform:uppercase;color:var(--decline);margin-bottom:4px">Hard fails &middot; {{ c.hard_reasons|length }}</div>
                  <ul style="margin:0;padding-left:14px;font-family:var(--serif);font-size:12px;color:var(--ink-2);line-height:1.45">
                    {% for r in c.hard_reasons %}<li>{{ r }}</li>{% endfor %}
                  </ul>
                </div>
              {% endif %}
              {% if c.soft_concerns %}
                <div style="margin-top:8px">
                  <div style="font-family:var(--mono);font-size:9.5px;letter-spacing:0.16em;text-transform:uppercase;color:var(--review);margin-bottom:4px">Soft concerns &middot; {{ c.soft_concerns|length }}</div>
                  <ul style="margin:0;padding-left:14px;font-family:var(--serif);font-size:12px;color:var(--ink-2);line-height:1.45">
                    {% for r in c.soft_concerns %}<li>{{ r }}</li>{% endfor %}
                  </ul>
                </div>
              {% endif %}
              {% if c.color == 'green' %}
                <div style="margin-top:6px;font-family:var(--mono);font-size:10px;letter-spacing:0.14em;text-transform:uppercase;color:var(--approve)">No blockers</div>
              {% endif %}

              {% if c.estimated_terms is not none %}
                {% set et = c.estimated_terms %}
                <div style="margin-top:10px;padding-top:8px;border-top:1px dashed var(--rule)">
                  <div style="font-family:var(--mono);font-size:9.5px;letter-spacing:0.16em;text-transform:uppercase;color:var(--ink-3);margin-bottom:6px">Estimated terms</div>
                  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(70px,1fr));gap:8px 12px;font-family:var(--serif);font-size:12px;color:var(--ink-2);line-height:1.35">
                    <div>
                      <div style="font-family:var(--mono);font-size:9px;letter-spacing:0.12em;text-transform:uppercase;color:var(--ink-3)">Advance</div>
                      <div class="mono-cell" style="font-size:13px;color:var(--ink);font-weight:500">{{ et.estimated_advance | whole_money }}</div>
                    </div>
                    <div>
                      <div style="font-family:var(--mono);font-size:9px;letter-spacing:0.12em;text-transform:uppercase;color:var(--ink-3)">Factor</div>
                      <div class="mono-cell" style="font-size:13px;color:var(--ink);font-weight:500">{{ et.estimated_factor }}x</div>
                    </div>
                    <div>
                      <div style="font-family:var(--mono);font-size:9px;letter-spacing:0.12em;text-transform:uppercase;color:var(--ink-3)">Holdback</div>
                      <div class="mono-cell" style="font-size:13px;color:var(--ink);font-weight:500">{{ et.estimated_holdback_pct | format_pct }}</div>
                    </div>
                    <div>
                      <div style="font-family:var(--mono);font-size:9px;letter-spacing:0.12em;text-transform:uppercase;color:var(--ink-3)">APR</div>
                      <div class="mono-cell" style="font-size:13px;color:{% if et.estimated_apr is none %}var(--ink-3){% else %}var(--ink){% endif %};font-weight:500">{{ et.estimated_apr | format_pct }}</div>
                    </div>
                  </div>
                </div>
              {% endif %}

              {% set _resp = (matched_funder_responses or {}).get(c.funder_id) %}
              {% if _resp %}
                {% set _rs_cls = {'approved':'pos','declined':'bad','countered':'warn','pending':''}.get(_resp.status, '') %}
                <div style="margin-top:10px;padding-top:8px;border-top:1px dashed var(--rule)">
                  <div style="font-family:var(--mono);font-size:9px;letter-spacing:0.16em;text-transform:uppercase;color:var(--ink-3);margin-bottom:4px">Funder reply</div>
                  <div style="display:flex;flex-wrap:wrap;gap:6px;align-items:center">
                    <span class="chip {{ _rs_cls }}">{{ _resp.status }}</span>
                    {% if _resp.offered_amount %}<span class="mono-cell" style="font-size:11.5px">${{ _resp.offered_amount }}</span>{% endif %}
                    {% if _resp.offered_factor %}<span class="mono-cell" style="font-size:11.5px">&times;{{ _resp.offered_factor }}</span>{% endif %}
                    {% if _resp.offered_term_days %}<span class="mono-cell" style="font-size:11.5px">{{ _resp.offered_term_days }}d</span>{% endif %}
                  </div>
                </div>
              {% endif %}

              {# Per-funder submit button. Posts to /submit-to-funder
                 with funder_id form field; the route filters matched
                 funders to just this one. HTMX swaps the button with
                 the "Submitted ✓" chip on 200. Disabled states:
                 (a) red card — funder hard-fails this merchant;
                 (b) merchant has no close_lead_id;
                 (c) operator already submitted to this funder
                     (one durable row already exists). #}
              <div style="margin-top:12px;padding-top:10px;border-top:1px solid var(--rule);display:flex;justify-content:flex-end">
                {% if _already_submitted %}
                  <span class="btn primary is-disabled"
                        data-test-id="dossier-submit-funder-already-submitted"
                        data-submit-to-funder="already-submitted"
                        aria-disabled="true">Submitted &check;</span>
                {% elif license_gate and license_gate.required %}
                  {# Phase E — trade licensing gate. Banner above explains;
                     per-card buttons render disabled so the operator can't
                     submit via keyboard tab-stop or HTMX bypass. #}
                  <span class="btn is-disabled"
                        data-test-id="dossier-submit-funder-disabled-license-gate"
                        data-submit-to-funder="disabled-license-gate"
                        aria-disabled="true"
                        title="License verification required — see the banner at the top of § 4.">Submit to {{ c.funder_name }}</span>
                {% elif c.color == 'red' %}
                  <span class="btn is-disabled"
                        data-test-id="dossier-submit-funder-disabled-hard-fail"
                        data-submit-to-funder="disabled-hard-fail"
                        aria-disabled="true"
                        title="Funder hard-fails this merchant — resolve the hard-fail reasons above to enable">Submit to {{ c.funder_name }}</span>
                {% elif not merchant.close_lead_id %}
                  <span class="btn is-disabled"
                        data-test-id="dossier-submit-funder-disabled-no-lead"
                        data-submit-to-funder="disabled-no-lead"
                        aria-disabled="true"
                        title="Link a Close Lead before submitting to a funder">Submit to {{ c.funder_name }}</span>
                {% else %}
                  <button class="btn primary"
                          type="button"
                          data-test-id="dossier-submit-funder-button"
                          data-funder-id="{{ c.funder_id }}"
                          name="funder_id"
                          value="{{ c.funder_id }}"
                          hx-post="/ui/merchants/{{ merchant.id }}/submit-to-funder/{{ c.funder_id }}"
                          hx-target="this"
                          hx-swap="outerHTML"
                          hx-confirm="Submit deal to {{ c.funder_name }}? This posts the AEGIS funder note to Close.">Submit to {{ c.funder_name }}</button>
                {% endif %}
              </div>

              {# Phase 7C deep-link — quiet "View history" link routes to
                 the per-merchant submissions page anchored on this
                 funder's row so the operator can review the timeline of
                 prior submissions / responses for this funder pair. #}
              <div style="margin-top:6px;text-align:right;font-family:var(--mono);font-size:10px;letter-spacing:0.06em;color:var(--ink-3)">
                <a href="/ui/merchants/{{ merchant.id }}/submissions#funder-{{ c.funder_id }}"
                   data-test-id="dossier-funder-card-view-history"
                   style="color:inherit">View history ↗</a>
              </div>
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </section>

    {# ============== § 4½ STATEMENTS LEDGER ============== #}
    {% if documents %}
    <section id="statements" class="section">
      <header>
        <span class="n">§ 4½</span>
        <h2>Statements <em>· ledger</em></h2>
        <span class="footnote">{{ documents|length }} on file · click any row → full detail</span>
      </header>
      {# R4.8 (2026-06-09): table-scroll wrapper — statements ledger has
         8 columns and will not fit on a phone viewport. #}
      <div class="table-scroll">
      <table class="audit-ledger">
        <thead>
          <tr>
            <th style="width:140px">Period</th>
            <th style="width:120px">Parse status</th>
            <th class="num" style="width:80px;text-align:right">Fraud</th>
            <th class="num" style="width:130px;text-align:right">True revenue</th>
            <th class="num" style="width:100px;text-align:right">NSFs</th>
            <th class="num" style="width:100px;text-align:right">Neg days</th>
            <th style="width:120px">File</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {% for entry in documents %}
            {% set d = entry.document %}
            {% set a = entry.analysis %}
            <tr style="cursor:pointer" onclick="window.location.href='/ui/documents/{{ d.id }}'">
              <td class="when">
                {% if a %}{{ a.statement_period_start.strftime('%b %Y') }}{% else %}<span style="color:var(--ink-3)">{{ d.uploaded_at.strftime('%Y-%m-%d') }}</span>{% endif %}
              </td>
              <td class="action">
                {# Fix 3 (2026-06-26) — render the plain-English label
                   in the main column; ``plain_status_label`` re-emits
                   the raw parse_status as a small tag chip next to it. #}
                {{ plain_status_label(d) }}
              </td>
              <td class="details" style="text-align:right;font-family:var(--mono);color:{% if d.fraud_score is number and d.fraud_score >= 65 %}var(--decline){% elif d.fraud_score is number and d.fraud_score >= 35 %}var(--review){% elif d.fraud_score is number %}var(--approve){% endif %}">
                {% if d.fraud_score is number %}{{ d.fraud_score }}{% else %}—{% endif %}
              </td>
              <td class="details" style="text-align:right;font-family:var(--mono)">
                {% if a %}${{ "{:,.0f}".format(a.true_revenue) }}{% else %}—{% endif %}
              </td>
              <td class="details" style="text-align:right;font-family:var(--mono)">{% if a %}{{ a.num_nsf }}{% else %}—{% endif %}</td>
              <td class="details" style="text-align:right;font-family:var(--mono)">{% if a %}{{ a.days_negative }}{% else %}—{% endif %}</td>
              <td class="details" style="font-family:var(--mono);font-size:10.5px;color:var(--ink-3);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:140px" title="{{ d.original_filename }}">{{ d.original_filename }}</td>
              <td class="details" style="text-align:right">
                {# Chunk-C view-original link. Only shown when the parse
                   reached a status that implies a pdf_store row has
                   been written by the worker (proceed / review /
                   manual_review). ``error`` and ``pending`` documents
                   have no ciphertext on file. #}
                {% if d.parse_status in ('proceed', 'review', 'manual_review') %}
                  <a href="/ui/merchants/{{ merchant.id }}/documents/{{ d.id }}/pdf"
                     target="_blank"
                     onclick="event.stopPropagation()"
                     style="font-family:var(--mono);font-size:10px;letter-spacing:0.14em;text-transform:uppercase;color:var(--accent);border-bottom:0;margin-right:8px">
                    PDF ↗
                  </a>
                {% endif %}
                <a href="/ui/documents/{{ d.id }}" onclick="event.stopPropagation()" style="font-family:var(--mono);font-size:10px;letter-spacing:0.14em;text-transform:uppercase;color:var(--accent);border-bottom:0">open ↗</a>
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
      </div>
    </section>
    {% endif %}

    {# ============== § 4⅔ APPLICATION DATA FROM CLOSE ==============
       What the MERCHANT told us at intake (Close FINANCIAL block,
       parsed from the Lead description by migration 087). Distinct
       from § 2 (AEGIS-measured cashflow) — the contrast between the
       two is exactly what the impossible-payment-load + stated-vs-
       measured-revenue-divergence detectors evaluate.
       Visual contrast: amber border-left so the operator can see at a
       glance that this band is unverified-merchant-assertion data,
       not AEGIS-measured. #}
    {% set has_application_data = merchant.monthly_revenue or merchant.stated_daily_payment or merchant.stated_mca_positions or merchant.stated_current_lenders or merchant.stated_bank or merchant.use_of_funds or merchant.stated_mca_balance or merchant.stated_monthly_deposits or merchant.avg_monthly_cc_sales or merchant.requested_amount %}
    {% if has_application_data %}
    <section id="application-data" class="section" style="border-left:3px solid var(--amber, #c99317);padding-left:14px">
      <header>
        <span class="n">§ 4⅔</span>
        <h2>Application data <em>· what the merchant told us</em></h2>
        <span class="footnote">parsed from Close · unverified merchant assertions</span>
      </header>
      <div class="table-scroll">
      <table class="audit-ledger">
        <tbody>
          {% if merchant.requested_amount %}<tr><td class="when" style="width:200px">Requested advance</td><td class="details"><span class="mono">${{ "{:,.0f}".format(merchant.requested_amount) }}</span></td></tr>{% endif %}
          {% if merchant.use_of_funds %}<tr><td class="when">Use of funds</td><td class="details">{{ merchant.use_of_funds }}</td></tr>{% endif %}
          {% if merchant.monthly_revenue %}<tr><td class="when">Stated monthly revenue</td><td class="details"><span class="mono">${{ "{:,.0f}".format(merchant.monthly_revenue) }}</span> <span style="color:var(--ink-3);font-size:11px">/ month (merchant-reported)</span></td></tr>{% endif %}
          {% if merchant.avg_monthly_cc_sales %}<tr><td class="when">Avg monthly CC sales</td><td class="details"><span class="mono">${{ "{:,.0f}".format(merchant.avg_monthly_cc_sales) }}</span></td></tr>{% endif %}
          {% if merchant.stated_monthly_deposits is not none %}<tr><td class="when">Monthly deposit count</td><td class="details"><span class="mono">{{ merchant.stated_monthly_deposits }}</span> deposits/month</td></tr>{% endif %}
          {% if merchant.stated_mca_positions is not none %}<tr><td class="when">Existing MCA positions</td><td class="details"><span class="mono">{{ merchant.stated_mca_positions }}</span>{% if merchant.stated_current_lenders %} · {{ merchant.stated_current_lenders | join(', ') }}{% endif %}</td></tr>{% elif merchant.stated_current_lenders %}<tr><td class="when">Current lenders</td><td class="details">{{ merchant.stated_current_lenders | join(', ') }}</td></tr>{% endif %}
          {% if merchant.stated_mca_balance %}<tr><td class="when">Existing MCA balance</td><td class="details"><span class="mono">${{ "{:,.0f}".format(merchant.stated_mca_balance) }}</span></td></tr>{% endif %}
          {% if merchant.stated_daily_payment %}<tr><td class="when">Daily/weekly payment</td><td class="details"><span class="mono">${{ "{:,.0f}".format(merchant.stated_daily_payment) }}</span></td></tr>{% endif %}
          {% if merchant.stated_bank %}<tr><td class="when">Bank</td><td class="details">{{ merchant.stated_bank }}</td></tr>{% endif %}
        </tbody>
      </table>
      </div>
    </section>
    {% endif %}

    {# ============== § 4¾ MERCHANT PROFILE ============== #}
    <section id="profile" class="section">
      <header>
        <span class="n">§ 4¾</span>
        <h2>Merchant <em>· profile</em></h2>
        <span class="footnote">all fields · <a href="/ui/merchants/{{ merchant.id }}/edit" style="border-bottom:0">edit ↗</a></span>
      </header>
      {# R4.8 (2026-06-09): table-scroll wrapper for the merchant-profile
         key/value ledger. Two columns fit on most phones but the 200px
         label column can force overflow on narrow widths. #}
      <div class="table-scroll">
      <table class="audit-ledger">
        <tbody>
          <tr><td class="when" style="width:200px">Business name</td><td class="details" style="font-family:var(--serif);font-size:15px;font-weight:500">{{ merchant.business_name }}{% if merchant.dba %} <em style="color:var(--ink-3)">· DBA {{ merchant.dba }}</em>{% endif %}</td></tr>
          <tr><td class="when">Owner</td><td class="details">{{ merchant.owner_name }}</td></tr>
          <tr><td class="when">State</td><td class="details"><span class="mono">{{ merchant.state }}</span></td></tr>
          <tr><td class="when">Entity type</td><td class="details">{{ merchant.entity_type or '—' }}</td></tr>
          <tr><td class="when">EIN</td><td class="details"><span class="mono">{% if merchant.ein %}{{ merchant.ein[:3] }}-XX-XXXX{% else %}—{% endif %}</span> <span style="font-size:10px;color:var(--ink-3);font-family:var(--mono)">· masked</span></td></tr>
          <tr><td class="when">Industry</td><td class="details">{{ (naics_name if naics_name is defined else None) or merchant.industry_naics or '—' }}{% if merchant.industry_naics %} <span class="mono" style="color:var(--ink-3);font-size:11px">· NAICS {{ merchant.industry_naics }}</span>{% endif %}{% if merchant.industry_risk_tier %} · {{ merchant.industry_risk_tier }}{% endif %}</td></tr>
          <tr><td class="when">FICO</td><td class="details"><span class="mono">{{ merchant.credit_score or '—' }}</span></td></tr>
          <tr><td class="when">Time in business</td><td class="details">{% if merchant.time_in_business_months %}<span class="mono">{{ merchant.time_in_business_months }}</span> months{% else %}—{% endif %}</td></tr>
          <tr><td class="when">Contact</td><td class="details">{% if merchant.email %}<span class="mono">{{ merchant.email }}</span>{% else %}—{% endif %}{% if merchant.phone %} · <span class="mono">{{ merchant.phone }}</span>{% endif %}</td></tr>
          <tr><td class="when">Requested advance</td><td class="details">{% if merchant.requested_amount %}<span class="mono">${{ "{:,.0f}".format(merchant.requested_amount) }}</span>{% else %}—{% endif %}</td></tr>
          <tr><td class="when">Requested factor</td><td class="details">{% if merchant.requested_factor %}<span class="mono">×{{ merchant.requested_factor }}</span>{% else %}—{% endif %}</td></tr>
          <tr><td class="when">Requested term</td><td class="details">{% if merchant.requested_term_days %}<span class="mono">{{ merchant.requested_term_days }}</span> days{% else %}—{% endif %}</td></tr>
          <tr><td class="when">Source / broker</td><td class="details">{{ merchant.broker_source or '—' }}</td></tr>
          <tr><td class="when">Intake date</td><td class="details"><span class="mono">{{ merchant.intake_date or '—' }}</span></td></tr>
          <tr><td class="when">Renewal</td><td class="details">{% if merchant.is_renewal %}<span class="pill warn">renewal</span>{% else %}<span style="color:var(--ink-3)">no</span>{% endif %}</td></tr>
          <tr><td class="when">Close lead</td><td class="details"><span class="mono">{{ merchant.close_lead_id or '—' }}</span></td></tr>
          <tr><td class="when">Created</td><td class="details"><span class="mono" style="font-size:11px">{% if merchant.created_at %}{{ merchant.created_at.strftime('%Y-%m-%d %H:%M UTC') }}{% else %}—{% endif %}</span></td></tr>
          <tr><td class="when">Updated</td><td class="details"><span class="mono" style="font-size:11px">{% if merchant.updated_at %}{{ merchant.updated_at.strftime('%Y-%m-%d %H:%M UTC') }}{% else %}—{% endif %}</span></td></tr>
          <tr><td class="when">Merchant ID</td><td class="details"><span class="mono" style="font-size:10.5px">{{ merchant.id }}</span></td></tr>
        </tbody>
      </table>
      </div>
    </section>

    </div>{# /.dossier-col-right — Background + Funder + Ledger + Profile #}
    </div>{# /.dossier-main-grid — main 60/40 split #}

    {# ============== § 5 DISPOSITION ============== #}
    <section id="disposition" class="section">
      <header>
        <span class="n">§ 5</span>
        <h2>Disposition</h2>
        <span class="footnote">awaiting manager sign-off</span>
      </header>
      <div class="disposition">
        <div class="copy">
          {% if score_result and score_result.recommendation == 'approve' %}
            <h3>Approve. Submit at requested terms.</h3>
            <p>Deal clears AEGIS gates. Recommend submission to the top-ranked funders on the match panel. Standard disclosure required at signature.</p>
          {% elif score_result and score_result.recommendation == 'refer' %}
            <h3>Refer to manager. Counter on size.</h3>
            <p>Cashflow supports the deal but soft concerns warrant a counter at <em>{{ score_result.suggested_max_advance | whole_money }}</em>. Manager sign-off required before routing.</p>
          {% elif score_result %}
            <h3>Decline. Resolve blockers before resubmission.</h3>
            <p>Hard declines flagged above block routing. Either address the underlying issues (re-upload corrected statements, supply missing data) or close the deal.</p>
          {% else %}
            <h3>Awaiting analysis.</h3>
            <p>Score and disposition will populate once at least one statement is parsed.</p>
          {% endif %}
        </div>
        <div class="sign">
          <div class="sig">awaiting</div>
          <div class="who">manager sign-off</div>
        </div>
      </div>
    </section>

    {# ============== § 5½ FUNDER SUBMISSIONS ============== #}
    {% if funder_note_submissions %}
      <section id="submissions" class="section">
        <header>
          <span class="n">§ 5½</span>
          <h2>Funder <em>submissions</em></h2>
          <span class="footnote">{{ funder_note_submissions|length }} submission{{ '' if funder_note_submissions|length == 1 else 's' }} · newest first</span>
        </header>
        <div class="table-scroll">
        <table class="audit-ledger">
          <thead>
            <tr>
              <th style="width:170px">Submitted</th>
              <th style="width:140px">Funder</th>
              <th style="width:110px">Status</th>
              <th style="width:140px">Offer</th>
              <th>Responded</th>
              <th style="width:130px">Outcome</th>
            </tr>
          </thead>
          <tbody>
            {% for s in funder_note_submissions %}
              {% include "_submission_row.html.j2" %}
            {% endfor %}
          </tbody>
        </table>
        </div>
      </section>
    {% endif %}

    {# HTMX host for the "Record outcome" modal. Sits outside the
       submissions table so the swap target survives row-level HTMX
       swaps that replace individual <tr> elements. The Record-outcome
       button in the row partial targets this host. #}
    <div id="outcome-modal-host"></div>

    <!-- BEGIN: record-outcome -->
    {# Post-fund outcome capture (migration 074 deal_outcomes — outcome
       feedback loop). Sibling to the per-row pre-fund "Record outcome"
       button in § 5½: that one writes to funder_replies (pre-fund);
       this writes to deal_outcomes (post-fund — paying / paid_in_full /
       charged_off / etc). Shows only when the merchant has a recorded
       decision (override_latest_decision_id is the deepest signal we
       have today for "scored + decision snapshot exists"). #}
    {% if override_latest_decision_id %}
      <section id="post-fund-outcome"
               class="section"
               data-test-id="post-fund-outcome-section"
               style="margin-top:1.5rem">
        <header>
          <span class="n">§ 5¾</span>
          <h2>Post-fund <em>outcome</em></h2>
          <span class="footnote">record what happened after this deal funded</span>
        </header>
        <div style="display:flex;gap:10px;align-items:center;padding:8px 0">
          <button type="button"
                  class="record-deal-outcome-btn"
                  style="font-size:12px;padding:6px 12px"
                  hx-get="/ui/merchants/{{ merchant.id }}/decisions/{{ override_latest_decision_id }}/outcome-modal"
                  hx-target="#deal-outcome-modal-host"
                  hx-swap="innerHTML"
                  data-test-id="record-deal-outcome-btn">
            Record outcome
          </button>
          <span style="font-size:11px;color:#777">
            Captures paying / paid_in_full / charged_off / defaulted /
            renewed for the calibration feedback loop. The pre-fund
            "Record outcome" buttons in § 5½ are distinct — those capture
            the funder's reply.
          </span>
        </div>
      </section>
      <div id="deal-outcome-modal-host"></div>
    {% endif %}
    <!-- END: record-outcome -->

    {# ============== Raw flags (audit / drill-down) ==============
       Fix 5 (2026-06-26) — drop the raw ``all_flags`` list into a
       collapsible at the bottom of the main area. Open-by-default ONLY
       when ``narrator_summary`` is absent so legacy / unsummarized
       deals still surface their underlying flags without an extra
       click; collapsed when the narrator already explains the deal in
       plain English. #}
    {% if document and document.all_flags %}
      <section id="raw-flags" class="section" data-test-id="dossier-raw-flags-section">
        <header>
          <span class="n">&sect;</span>
          <h2>Raw <em>flags</em></h2>
          <span class="footnote">{{ document.all_flags|length }} flag{{ '' if document.all_flags|length == 1 else 's' }} on the latest document &middot; audit-only drill-down</span>
        </header>
        <details data-test-id="dossier-raw-flags-details"{% if narrator_summary is none %} open{% endif %}>
          <summary>Show flags</summary>
          <ul style="margin:8px 0 0 0;padding-left:18px;font-family:var(--mono);font-size:11.5px;color:var(--ink-2);line-height:1.6">
            {% for f in document.all_flags %}
              <li>{{ f }}</li>
            {% endfor %}
          </ul>
        </details>
      </section>
    {% endif %}

    {# ============== § 6 OPERATOR NOTES ============== #}
    {# Moved from the top-of-dossier slot (above the chips) to the
       bottom of main on 2026-06-18, replacing the audit-log section.
       Audit-log was internal telemetry — operators never read it on
       the dossier; it stays on the Admin / Audit Log surface. Reads
       its inputs from the route's TemplateResponse: ``operator_notes``
       (list, newest-first) + ``operator_note_max_chars``. #}
    <section id="operator-notes" class="section">
      {% include "_merchant_notes_block.html.j2" %}
    </section>

  </main>
</div>

</body>
</html>
