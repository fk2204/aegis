{# Reclassify form partial — loaded via HTMX into #reclassify-modal
   when the operator clicks the ↻ button on a transaction row.
   POSTs to /ui/merchants/{merchant_id}/transactions/{transaction_id}/reclassify
   on save; closes the modal on cancel. #}
<div class="reclassify-form" data-test-id="reclassify-form">
  <form hx-post="/ui/merchants/{{ merchant_id }}/transactions/{{ transaction_id }}/reclassify"
        hx-target="#reclassify-modal"
        hx-swap="innerHTML">
    <h4 style="margin:0 0 8px;font-family:var(--serif);font-size:14px">
      Reclassify transaction
    </h4>
    <label style="display:block;font-size:12px;color:var(--ink-3);margin-bottom:4px">
      Counterparty class
    </label>
    <select name="counterparty_class"
            required
            style="width:100%;padding:6px 8px;font-family:var(--mono);font-size:12px;margin-bottom:10px">
      {% for c in classes %}
        <option value="{{ c }}">{{ c }}</option>
      {% endfor %}
    </select>
    <label style="display:block;font-size:12px;color:var(--ink-3);margin-bottom:4px">
      Reason (operator note)
    </label>
    <input type="text"
           name="reason"
           maxlength="200"
           placeholder="why this row should be reclassified"
           style="width:100%;padding:6px 8px;font-size:12px;margin-bottom:10px">
    <div style="display:flex;gap:8px;justify-content:flex-end">
      <button type="button"
              hx-get="/ui/merchants/{{ merchant_id }}/transactions/cancel-reclassify"
              hx-target="#reclassify-modal"
              hx-swap="innerHTML"
              style="padding:6px 12px;background:none;border:1px solid var(--rule);border-radius:3px;cursor:pointer">
        Cancel
      </button>
      <button type="submit"
              style="padding:6px 12px;background:var(--brand);color:white;border:none;border-radius:3px;cursor:pointer">
        Save override
      </button>
    </div>
  </form>
</div>
