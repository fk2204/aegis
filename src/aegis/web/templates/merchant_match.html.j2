{% extends "base.html.j2" %}
{% set active = 'Deals' %}
{% block title %}{{ merchant.business_name }} — Funder match · AEGIS{% endblock %}

{% block deck %}
<header class="deck">
  <h1>{{ merchant.business_name }}<em> · funder match</em></h1>
  <div class="meta">
    {{ merchant.owner_name }} &nbsp;·&nbsp; {{ merchant.state }} &nbsp;·&nbsp; match · {{ merchant.id|string|truncate(8, True, '') }}
  </div>
  <div class="actions">
    <a class="btn ghost" href="/ui/merchants/{{ merchant.id }}">← Detail</a>
  </div>
</header>
{% endblock %}

{% block body %}
<section class="body cols-1">
  <div>

    {# Preselect banner — operator arrived from a funder detail page's
       "Record a submission" picker but the chosen funder hard-fails
       this merchant (or isn't active). We surface the reasons and
       leave the matching checkbox unchecked rather than silently
       selecting a non-eligible funder. #}
    {% if preselect_banner %}
      <div class="preselect-banner">
        <div class="preselect-banner-title">
          <span class="chip warn">Not eligible</span>
          {{ preselect_banner.name }} cannot fund this merchant
        </div>
        <ul class="preselect-banner-reasons">
          {% for r in preselect_banner.reasons %}<li>{{ r }}</li>{% endfor %}
        </ul>
      </div>
    {% endif %}

    {% if missing == "no_document" %}
      <div class="empty">No analyzed document yet<span class="copy"><a href="/ui/upload">Upload a statement →</a></span></div>
    {% else %}

      {# === score strip === #}
      <section class="strip" style="--strip-cols:5">
        <div class="cell">
          <div class="k">Tier</div>
          <div class="v" style="font-size:48px">{{ score_result.tier }}</div>
        </div>
        <div class="cell">
          <div class="k">Score</div>
          <div class="v">{{ score_result.score }}<span class="sub">/100</span></div>
        </div>
        <div class="cell">
          <div class="k">Recommendation</div>
          <div class="v" style="font-size:22px">
            {% set _rec_cls = {'approve':'pos','refer':'warn','decline':'bad'}.get(score_result.recommendation, '') %}
            <span class="chip {{ _rec_cls }}">{{ score_result.recommendation }}</span>
          </div>
        </div>
        <div class="cell">
          <div class="k">Suggested max</div>
          <div class="v">${{ score_result.suggested_max_advance }}</div>
        </div>
        <div class="cell">
          <div class="k">Matched funders</div>
          <div class="v">{{ matches|length }}</div>
        </div>
      </section>

      {# === scoring window === #}
      {% if score_window %}
        <header class="sect-head" style="margin-top:32px">
          <h2>Scoring window</h2>
          <div class="rule"></div>
          <div class="meta">{{ score_window.months_used }} statement{{ '' if score_window.months_used == 1 else 's' }} aggregated</div>
        </header>
        <div class="feed">
          <div class="event">
            <div class="t">P</div>
            <div class="txt">
              <strong>Period</strong>&nbsp;&nbsp;<span class="mono-inline">{{ score_window.period_start }} → {{ score_window.period_end }}</span>
              {% if score_window.months_used == 1 %}&nbsp;&nbsp;<span class="chip warn">only 1 month — trend not reliable</span>{% endif %}
              {% if score_window.any_manual_review %}&nbsp;&nbsp;<span class="chip bad">some statements in manual_review</span>{% endif %}
            </div>
          </div>
        </div>
      {% endif %}

      {# === hard declines === #}
      {% if score_result.hard_decline_reasons %}
        <header class="sect-head" style="margin-top:32px">
          <h2>Hard declines</h2>
          <div class="rule"></div>
          <div class="meta" style="color:var(--decline)">{{ score_result.hard_decline_reasons|length }} blocker{{ '' if score_result.hard_decline_reasons|length == 1 else 's' }}</div>
        </header>
        <div class="feed">
          {% for r in score_result.hard_decline_reasons %}
            <div class="event"><div class="t" style="color:var(--decline)">!</div><div class="txt"><strong style="color:var(--decline)">{{ r }}</strong></div></div>
          {% endfor %}
        </div>
      {% endif %}

      {# === matched funders === #}
      <header class="sect-head" style="margin-top:32px">
        <h2>Matched funders</h2>
        <div class="rule"></div>
        <div class="meta">sorted by score · green clean · yellow soft · red hard-fail</div>
      </header>

      <form method="post" action="/ui/merchants/{{ merchant.id }}/submit">
        {% if not matches %}
          <div class="empty">No active funders configured<span class="copy"><a href="/ui/funders/import">Import a funder</a> to begin.</span></div>
        {% else %}
          <div class="form-actions" style="margin:14px 0">
            <button class="btn primary" type="submit">Download submission package</button>
            <button class="btn ghost" type="button" onclick="document.querySelectorAll('input[name=funder_ids][data-color=green]').forEach(b => b.checked = true)">Select all green</button>
            <button class="btn ghost" type="button" onclick="document.querySelectorAll('input[name=funder_ids]').forEach(b => b.checked = false)">Clear</button>
            <span class="mono-cell" style="margin-left:auto">ZIP of N CSVs · AEGIS does not transmit — forward via your channel (email, phone, portal)</span>
          </div>

          <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(360px,1fr));gap:14px">
            {% for c in matches %}
              {% set _disabled = (c.color == 'red') %}
              {% set _color_var = 'var(--approve)' if c.color == 'green' else 'var(--review)' if c.color == 'yellow' else 'var(--decline)' %}
              <label style="display:block;cursor:{% if _disabled %}not-allowed{% else %}pointer{% endif %};border:1px solid var(--rule);border-left:3px solid {{ _color_var }};background:var(--paper);padding:14px 14px 12px;{% if c.color == 'green' %}box-shadow:0 0 0 1px color-mix(in oklch, var(--approve) 30%, transparent);{% endif %}">
                <div style="display:flex;justify-content:space-between;align-items:baseline;gap:10px;margin-bottom:8px">
                  <span style="display:flex;align-items:center;gap:8px;font-family:var(--serif);font-weight:500;font-size:15px;letter-spacing:-0.005em;color:var(--ink)">
                    <input type="checkbox" name="funder_ids" value="{{ c.funder_id }}" data-color="{{ c.color }}" {% if _disabled %}disabled{% endif %} {% if preselect_funder_id and c.funder_id == preselect_funder_id %}checked{% endif %} style="width:auto">
                    <a href="/ui/funders/{{ c.funder_id }}" onclick="event.stopPropagation()" style="color:inherit;border-bottom:0">{{ c.funder_name }}</a>
                  </span>
                  {% if c.is_marketplace %}
                    {# Marketplace / aggregator funder — no published
                       criteria. Surface the badge instead of the score so
                       the operator doesn't misread an empty match as
                       meaningful. #}
                    <span class="chip"
                          data-test-id="match-card-marketplace-badge"
                          style="font-family:var(--mono);font-size:10px;letter-spacing:0.14em;text-transform:uppercase;background:var(--rule);color:var(--ink-2);padding:3px 8px">
                      Marketplace
                    </span>
                  {% else %}
                    <span style="font-family:var(--serif);font-size:24px;font-weight:600;letter-spacing:-0.022em;color:{{ _color_var }};font-variant-numeric:tabular-nums">{{ c.match_score }}<span style="font-family:var(--mono);font-size:10px;color:var(--ink-3);margin-left:2px">/100</span></span>
                  {% endif %}
                </div>

                {% if c.hard_reasons %}
                  <div style="margin-top:8px">
                    <div style="font-family:var(--mono);font-size:9.5px;letter-spacing:0.16em;text-transform:uppercase;color:var(--decline);margin-bottom:4px">Hard fails · {{ c.hard_reasons|length }}</div>
                    <ul style="margin:0;padding-left:14px;font-family:var(--serif);font-size:12px;color:var(--ink-2);line-height:1.45">
                      {% for r in c.hard_reasons %}<li>{{ r }}</li>{% endfor %}
                    </ul>
                  </div>
                {% endif %}
                {% if c.soft_concerns %}
                  <div style="margin-top:8px">
                    <div style="font-family:var(--mono);font-size:9.5px;letter-spacing:0.16em;text-transform:uppercase;color:var(--review);margin-bottom:4px">Soft concerns · {{ c.soft_concerns|length }}</div>
                    <ul style="margin:0;padding-left:14px;font-family:var(--serif);font-size:12px;color:var(--ink-2);line-height:1.45">
                      {% for r in c.soft_concerns %}<li>{{ r }}</li>{% endfor %}
                    </ul>
                  </div>
                {% endif %}
                {% if c.color == "green" %}
                  <div style="margin-top:6px;font-family:var(--mono);font-size:10px;letter-spacing:0.14em;text-transform:uppercase;color:var(--approve)">No blockers</div>
                {% endif %}

                {# Sprint 4 — historical approval rate for similar
                   prior submissions (same merchant industry tier, same
                   AEGIS score tier, last 90 days). Surfaces only when
                   the matcher had a ≥5-sample cell; absence reads as
                   "no track record yet" rather than 0%. The +5 / -10
                   match_score swing has already been applied — this
                   row is the explanation. #}
                {% if c.historical_approval_rate is not none %}
                  {% set _rate_pct = (c.historical_approval_rate * 100) | round(0, 'floor') | int %}
                  {% set _rate_color = 'var(--approve)' if c.historical_approval_rate > 0.60 else 'var(--decline)' if c.historical_approval_rate < 0.20 else 'var(--ink-3)' %}
                  <div style="margin-top:8px;display:flex;align-items:baseline;gap:6px">
                    <span style="font-family:var(--mono);font-size:9.5px;letter-spacing:0.16em;text-transform:uppercase;color:var(--ink-3)">Track record · 90d</span>
                    <span style="font-family:var(--mono);font-size:11px;color:{{ _rate_color }};font-variant-numeric:tabular-nums">{{ _rate_pct }}% approved</span>
                    <span style="font-family:var(--serif);font-size:11px;color:var(--ink-3)">on similar deals</span>
                  </div>
                {% endif %}

                {# === Estimated terms (R4.2 + R4.3) ===
                   Per-funder pricing guidance interpolated from the
                   funder's typical_factor / typical_holdback envelope
                   and the deal's score tier. ``None`` when the funder
                   has no published envelope or the tier is out of range;
                   block is omitted entirely in that case (no empty row).

                   APR rendering: ``None`` → "unavailable" (NOT 0.00%) —
                   R0.4 regulator-grade-lie discipline. A 0% APR next to
                   a 1.30x factor is the lie we refuse to render. #}
                {# === Tier qualification matrix (U28) ===
                   Per-tier qualify / disqualify breakdown for funders with
                   a published ``tiers`` JSONB (Logic Advance Elite/Premium/
                   Standard/High-Risk, UCS's 7 product lines, Highland Hill's
                   5-rate ladder). Empty for legacy / broker-only funders —
                   in which case the whole block is suppressed (no empty
                   "Tiers:" heading).

                   Sort: most-permissive (lowest ``estimated_factor_low``)
                   first. ``None`` factor ranges sort last so unpriced tiers
                   never preempt a quoted Elite row. The first qualifying
                   tier picks up a ``★ best`` badge — the operator's
                   one-glance answer to "which Logic Advance tier do I land
                   on if I submit this deal?"

                   SHADOW MODE: ``tier_matches`` does not influence
                   ``match_score`` or the green/yellow/red color rail (see
                   ``TierMatch`` docstring) — this block is annotation only. #}
                {% if c.tier_matches %}
                  {# Sort most-permissive (lowest buy_rate) first; tiers
                     without a published buy_rate (``estimated_factor_low is
                     None``) sink to the bottom so unpriced rows never
                     preempt a quoted Elite. Two-bucket split avoids
                     Python's ``None < Decimal`` TypeError that bites a
                     naive ``sort(attribute=...)`` with mixed None / value. #}
                  {% set _priced = c.tier_matches | rejectattr('estimated_factor_low', 'none') | list | sort(attribute='estimated_factor_low') %}
                  {% set _unpriced = c.tier_matches | selectattr('estimated_factor_low', 'none') | list %}
                  {% set _tier_sorted = _priced + _unpriced %}
                  {% set _qualifying_tiers = _tier_sorted | selectattr('qualifies') | list %}
                  {% set _qualifying_count = _qualifying_tiers | length %}
                  {% set _best_tier_name = _qualifying_tiers[0].tier_name if _qualifying_count else None %}
                  <div style="margin-top:10px;padding-top:8px;border-top:1px dashed var(--rule)">
                    <div style="font-family:var(--mono);font-size:9.5px;letter-spacing:0.16em;text-transform:uppercase;color:var(--ink-3);margin-bottom:6px">Tier qualification · {{ _qualifying_count }} of {{ c.tier_matches|length }} qualify</div>
                    <div style="display:flex;flex-direction:column;gap:6px">
                      {% for t in _tier_sorted %}
                        {% set _is_best = (t.qualifies and t.tier_name == _best_tier_name) %}
                        {% if t.qualifies %}
                          <div style="display:flex;flex-wrap:wrap;align-items:baseline;gap:8px;padding:6px 8px;background:{% if _is_best %}color-mix(in oklch, var(--approve) 8%, transparent){% else %}transparent{% endif %};border:1px solid {% if _is_best %}color-mix(in oklch, var(--approve) 35%, var(--rule)){% else %}var(--rule){% endif %}">
                            <span class="chip pos" style="font-size:9.5px">{{ t.tier_name }}</span>
                            {% if _is_best %}<span style="font-family:var(--mono);font-size:9px;letter-spacing:0.14em;text-transform:uppercase;color:var(--approve);font-weight:600">★ best</span>{% endif %}
                            {% if t.estimated_factor_low is not none and t.estimated_factor_high is not none %}
                              <span class="mono-cell" style="font-size:11.5px;color:var(--ink-2)">{{ t.estimated_factor_low }}x–{{ t.estimated_factor_high }}x</span>
                            {% elif t.estimated_factor_low is not none %}
                              <span class="mono-cell" style="font-size:11.5px;color:var(--ink-2)">{{ t.estimated_factor_low }}x</span>
                            {% endif %}
                            {% if t.estimated_advance is not none %}
                              <span class="mono-cell" style="font-size:11.5px;color:var(--ink);font-weight:500">{{ t.estimated_advance | whole_money }}</span>
                            {% endif %}
                            {% if t.estimated_holdback is not none %}
                              <span class="mono-cell" style="font-size:11.5px;color:var(--ink-2)">{{ t.estimated_holdback | format_pct }} holdback</span>
                            {% endif %}
                            {# U37 — per-tier payback total + daily-payment hint.
                               ``estimated_payback_total``/``estimated_daily_payment``
                               are populated by ``estimate_tier_pricing`` only when
                               the tier publishes ``buy_rate_*`` AND the score
                               supplies a positive advance. ``None`` → omit the
                               span (no fabricated placeholder). #}
                            {% if t.estimated_payback_total is not none %}
                              <span class="mono-cell" style="font-size:11.5px;color:var(--ink-2)">{{ t.estimated_payback_total | whole_money }} payback</span>
                            {% endif %}
                            {% if t.estimated_daily_payment is not none %}
                              <span class="mono-cell" style="font-size:11.5px;color:var(--ink-2)">{{ t.estimated_daily_payment | whole_money }}/day</span>
                            {% endif %}
                          </div>
                        {% else %}
                          <details style="padding:6px 8px;border:1px solid var(--rule);background:transparent">
                            <summary style="cursor:pointer;display:flex;flex-wrap:wrap;align-items:baseline;gap:8px;list-style:none">
                              <span style="font-family:var(--mono);font-size:9.5px;letter-spacing:0.14em;text-transform:uppercase;color:var(--ink-3);text-decoration:line-through">{{ t.tier_name }}</span>
                              <span style="font-family:var(--mono);font-size:10px;letter-spacing:0.12em;text-transform:uppercase;color:var(--ink-3)">does not qualify · {{ t.disqualifying_reasons|length }}</span>
                              {% if t.estimated_factor_low is not none and t.estimated_factor_high is not none %}
                                <span class="mono-cell" style="font-size:11px;color:var(--ink-3)">{{ t.estimated_factor_low }}x–{{ t.estimated_factor_high }}x</span>
                              {% endif %}
                            </summary>
                            {% if t.disqualifying_reasons %}
                              <ul style="margin:6px 0 0;padding-left:18px;font-family:var(--serif);font-size:11.5px;color:var(--ink-3);line-height:1.45">
                                {% for r in t.disqualifying_reasons %}<li>{{ r }}</li>{% endfor %}
                              </ul>
                            {% endif %}
                          </details>
                        {% endif %}
                      {% endfor %}
                    </div>
                  </div>
                {% endif %}

                {% if c.estimated_terms is not none %}
                  {% set et = c.estimated_terms %}
                  <div style="margin-top:10px;padding-top:8px;border-top:1px dashed var(--rule)">
                    <div style="font-family:var(--mono);font-size:9.5px;letter-spacing:0.16em;text-transform:uppercase;color:var(--ink-3);margin-bottom:6px">Estimated terms (interpolated from funder tier)</div>
                    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(70px,1fr));gap:8px 12px;font-family:var(--serif);font-size:12px;color:var(--ink-2);line-height:1.35">
                      <div>
                        <div style="font-family:var(--mono);font-size:9px;letter-spacing:0.12em;text-transform:uppercase;color:var(--ink-3)">Advance</div>
                        <div class="mono-cell" style="font-size:13px;color:var(--ink);font-weight:500">{{ et.estimated_advance | whole_money }}</div>
                      </div>
                      <div>
                        <div style="font-family:var(--mono);font-size:9px;letter-spacing:0.12em;text-transform:uppercase;color:var(--ink-3)">Factor</div>
                        <div class="mono-cell" style="font-size:13px;color:var(--ink);font-weight:500">{{ et.estimated_factor }}x</div>
                      </div>
                      <div>
                        <div style="font-family:var(--mono);font-size:9px;letter-spacing:0.12em;text-transform:uppercase;color:var(--ink-3)">Holdback</div>
                        <div class="mono-cell" style="font-size:13px;color:var(--ink);font-weight:500">{{ et.estimated_holdback_pct | format_pct }}</div>
                      </div>
                      <div>
                        <div style="font-family:var(--mono);font-size:9px;letter-spacing:0.12em;text-transform:uppercase;color:var(--ink-3)">Daily</div>
                        <div class="mono-cell" style="font-size:13px;color:var(--ink);font-weight:500">{{ et.estimated_daily_payment | whole_money }}</div>
                      </div>
                      <div>
                        <div style="font-family:var(--mono);font-size:9px;letter-spacing:0.12em;text-transform:uppercase;color:var(--ink-3)">APR</div>
                        <div class="mono-cell" style="font-size:13px;color:{% if et.estimated_apr is none %}var(--ink-3){% else %}var(--ink){% endif %};font-weight:500">{{ et.estimated_apr | format_pct }}</div>
                      </div>
                    </div>
                    <details style="margin-top:6px">
                      <summary style="cursor:pointer;font-family:var(--mono);font-size:9.5px;letter-spacing:0.14em;text-transform:uppercase;color:var(--ink-3)">How this was computed</summary>
                      <div style="font-family:var(--mono);font-size:11px;color:var(--ink-2);margin-top:4px;line-height:1.5;padding:6px 0 0">{{ et.interpolation_evidence }}</div>
                    </details>
                  </div>
                {% endif %}

                {% if c.criteria_comparison %}
                  <details style="margin-top:10px">
                    <summary style="cursor:pointer;font-family:var(--mono);font-size:10px;letter-spacing:0.14em;text-transform:uppercase;color:var(--ink-3)">{{ c.criteria_comparison|length }} criteria · compare</summary>
                    <table class="queue" style="margin-top:6px;font-size:12px">
                      <thead>
                        <tr><th>Criterion</th><th class="num">Required</th><th class="num">Deal</th><th></th></tr>
                      </thead>
                      <tbody>
                        {% for row in c.criteria_comparison %}
                          {% set _rc = 'var(--approve)' if row.status == 'pass' else 'var(--review)' if row.status == 'warn' else 'var(--decline)' %}
                          <tr class="no-click">
                            <td style="font-size:11.5px;padding:6px 8px 6px 0">{{ row.label }}</td>
                            <td class="mono-cell" style="text-align:right;font-size:11.5px;padding:6px 8px 6px 0">
                              {% if row.unit == 'money' %}{{ row.funder_value | whole_money }}{% elif row.unit == 'fico' %}{{ row.funder_value }} FICO{% elif row.unit == 'months' %}{{ row.funder_value }} mo{% else %}{{ row.funder_value }}{% endif %}
                            </td>
                            <td class="mono-cell" style="text-align:right;font-size:11.5px;color:{{ _rc }};font-weight:500;padding:6px 8px 6px 0">
                              {% if row.deal_value == 'missing' %}<em style="color:var(--ink-3)">missing</em>{% elif row.unit == 'money' %}{{ row.deal_value | whole_money }}{% elif row.unit == 'fico' %}{{ row.deal_value }} FICO{% elif row.unit == 'months' %}{{ row.deal_value }} mo{% else %}{{ row.deal_value }}{% endif %}
                            </td>
                            <td style="font-family:var(--mono);font-size:10px;letter-spacing:0.10em;text-transform:uppercase;color:{{ _rc }};padding:6px 0">{{ row.status }}</td>
                          </tr>
                        {% endfor %}
                      </tbody>
                    </table>
                  </details>
                {% endif %}

                {% set _resp = (funder_responses or {}).get(c.funder_id) %}
                {% if _resp %}
                  {% set _rs_cls = {'approved':'pos','declined':'bad','countered':'warn','pending':''}.get(_resp.status, '') %}
                  <div style="margin-top:10px;padding-top:8px;border-top:1px dashed var(--rule)">
                    <div style="font-family:var(--mono);font-size:9px;letter-spacing:0.16em;text-transform:uppercase;color:var(--ink-3);margin-bottom:4px">Funder reply</div>
                    <div style="display:flex;flex-wrap:wrap;gap:6px;align-items:center">
                      <span class="chip {{ _rs_cls }}">{{ _resp.status }}</span>
                      {% if _resp.offered_amount %}<span class="mono-cell" style="font-size:11.5px">${{ _resp.offered_amount }}</span>{% endif %}
                      {% if _resp.offered_factor %}<span class="mono-cell" style="font-size:11.5px">×{{ _resp.offered_factor }}</span>{% endif %}
                      {% if _resp.offered_term_days %}<span class="mono-cell" style="font-size:11.5px">{{ _resp.offered_term_days }}d</span>{% endif %}
                    </div>
                    {% if _resp.notes %}
                      <div style="font-family:var(--serif);font-size:12px;color:var(--ink-2);margin-top:4px;line-height:1.4">{{ _resp.notes }}</div>
                    {% endif %}
                  </div>
                {% endif %}
              </label>
            {% endfor %}
          </div>
        {% endif %}
      </form>

      {# === record reply === #}
      {% if matches %}
        <header class="sect-head" style="margin-top:32px">
          <h2>Record funder reply</h2>
          <div class="rule"></div>
          <div class="meta">audited · latest reply shown on each card</div>
        </header>
        <form class="form" method="post" action="/ui/merchants/{{ merchant.id }}/funder-response" style="margin-top:14px">
          <div class="row" style="grid-template-columns:1.4fr 1fr 1fr 1fr 1fr auto;gap:10px;align-items:end">
            <div class="field">
              <label>Funder</label>
              <select name="funder_id" required>
                {% for c in matches %}<option value="{{ c.funder_id }}">{{ c.funder_name }}</option>{% endfor %}
              </select>
            </div>
            <div class="field">
              <label>Status</label>
              <select name="response_status" required>
                <option value="approved">approved</option>
                <option value="countered">countered</option>
                <option value="declined">declined</option>
                <option value="pending">pending</option>
              </select>
            </div>
            <div class="field">
              <label>Amount · $</label>
              <input class="mono-input" name="offered_amount" type="text" inputmode="decimal" placeholder="50000">
            </div>
            <div class="field">
              <label>Factor</label>
              <input class="mono-input" name="offered_factor" type="text" inputmode="decimal" placeholder="1.30">
            </div>
            <div class="field">
              <label>Term · d</label>
              <input class="mono-input" name="offered_term_days" type="text" inputmode="numeric" placeholder="120">
            </div>
            <div class="field">
              <button class="btn primary" type="submit">Record reply</button>
            </div>
          </div>
          <div class="field">
            <label>Notes · optional</label>
            <input name="notes" type="text" placeholder="e.g. funder wants 6 months of statements before final approval">
          </div>
        </form>
      {% endif %}

    {% endif %}

  </div>
</section>
{% endblock %}
