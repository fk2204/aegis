{% extends "base.html.j2" %}
{% set active = 'Upload' %}
{% block title %}Upload statements — AEGIS{% endblock %}

{% block subhead %}
<div class="subhead">
  <div>
    <h1>Upload bank statements</h1>
    <div class="meta" style="margin-top:4px">
      <span><span class="dot"></span>PDF only · per-file cap 25 MB</span>
      <span>SHA-256 deduped · re-upload returns the same document id</span>
    </div>
  </div>
</div>
{% endblock %}

{% block body %}
<div class="body cols-1">
  <main class="main" style="max-width:780px">
    {% if error %}
      <div class="form-error">{{ error }}</div>
    {% endif %}

    <div class="panel">
      <div class="panel-head">
        <span class="panel-title">Drop statements</span>
        <span class="panel-actions mono">3–4 months per merchant</span>
      </div>
      <div class="panel-body">
        <form action="/ui/upload" method="post" enctype="multipart/form-data">
          <label>Merchant</label>
          <select name="merchant_id">
            <option value="">(no merchant — orphan upload, link later)</option>
            {% for m in merchants %}
              <option value="{{ m.id }}">{{ m.business_name }} ({{ m.state }})</option>
            {% endfor %}
          </select>
          <span class="field-help">Or <a href="/ui/intake">create merchant + upload in one step</a>.</span>

          <label>Statement PDFs</label>
          <div class="dropzone">
            <div class="big">Drop one or more PDFs</div>
            <div class="small">…or use the file picker below</div>
            <input type="file" name="files" accept="application/pdf" multiple required style="max-width:none;background:transparent">
          </div>

          <div class="form-actions">
            <button class="btn btn-primary" type="submit">Upload &amp; queue parse</button>
            <a class="btn" href="/ui/deals">Cancel</a>
          </div>
        </form>
      </div>
    </div>

    {% if results %}
      <div class="panel">
        <div class="panel-head">
          <span class="panel-title">Upload results</span>
          <span class="panel-actions mono">{{ results|length }} file{{ '' if results|length == 1 else 's' }}</span>
        </div>
        <div class="panel-body flush">
          <table class="data">
            <thead>
              <tr>
                <th>File</th>
                <th>Status</th>
                <th>Detail</th>
                <th>Document</th>
              </tr>
            </thead>
            <tbody>
              {% for r in results %}
              <tr>
                <td><span class="mono" style="font-size:11.5px">{{ r.filename }}</span></td>
                <td>
                  {% if r.status == 'ok' %}
                    <span class="tag pos"><span class="dot"></span>ok</span>
                  {% elif r.status == 'duplicate' %}
                    <span class="tag warn"><span class="dot"></span>duplicate</span>
                  {% else %}
                    <span class="tag neg"><span class="dot"></span>error</span>
                  {% endif %}
                </td>
                <td><span style="color:var(--muted);font-size:11.5px">{{ r.detail }}</span></td>
                <td>
                  {% if r.document_id %}
                    <span class="mono" style="font-size:11px;color:var(--muted)">{{ r.document_id[:8] }}…</span>
                  {% else %}
                    —
                  {% endif %}
                </td>
              </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>
    {% endif %}
  </main>
</div>
{% endblock %}
