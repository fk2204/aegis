{% extends "base.html.j2" %}
{% set active = 'Upload' %}
{% block title %}Upload statements — AEGIS{% endblock %}

{% block deck %}
{% set title = "Upload" %}
{% set subtitle = "· bank statements" %}
{% set meta = "PDF only · per-file 25 MB · SHA-256 deduped" %}
{% set actions = [
  {"label": "Deals →", "href": "/ui/deals"},
] %}
{% include "_page_header.html.j2" %}
{% endblock %}

{% block body %}
<section class="body cols-1">
  <div>

    {% if error %}
      <div class="form-error">{{ error }}</div>
    {% endif %}

    <header class="sect-head">
      <h2>Drop statements</h2>
      <div class="rule"></div>
      <div class="meta">3-4 months per merchant</div>
    </header>

    <form class="form" action="/ui/upload" method="post" enctype="multipart/form-data" style="margin-top:14px">
      <div class="field">
        <label>Merchant</label>
        <select name="merchant_id">
          <option value="">(no merchant — orphan upload, link later)</option>
          {# Filter to finalized merchants only. Provisional and
             needs_manual_naming merchants are blocked from the route
             at router.py:530-535 (migration 034 guard) — surfacing
             them in the dropdown would only produce 403s on submit. #}
          {% for m in merchants if m.is_finalized %}
            <option value="{{ m.id }}">{{ m.business_name }} ({{ m.state }})</option>
          {% endfor %}
        </select>
        <span class="help">Or <a href="/ui/intake">create merchant + upload in one step</a>.</span>
      </div>

      <div class="field">
        <label>Statement PDFs</label>
        <div class="dropzone">
          <div class="big">Drop one or more PDFs</div>
          <div class="small">or use the file picker below</div>
          <input type="file" name="files" accept="application/pdf" multiple required>
        </div>
        <span class="help">Drop 3&ndash;6 statements for the same merchant. AEGIS bundles them by bank account automatically and flags any missing months.</span>
      </div>

      <div class="form-actions">
        <button class="btn primary" type="submit">Upload &amp; queue parse</button>
        <a class="btn ghost" href="/ui/deals">Cancel</a>
      </div>
    </form>

    {% if results %}
      {% set _ok_count = results | selectattr('status','equalto','ok') | list | length %}
      {% set _dup_count = results | selectattr('status','equalto','duplicate') | list | length %}
      {% set _err_count = results | selectattr('status','equalto','error') | list | length %}

      {% if _ok_count > 0 or _dup_count > 0 %}
        <div class="panel pos" style="margin-top:28px">
          <div class="panel-head">
            <span class="panel-title">Upload complete · what's next</span>
            <span class="panel-actions">{{ _ok_count }} new &nbsp;·&nbsp; {{ _dup_count }} duplicate{% if _err_count %} &nbsp;·&nbsp; {{ _err_count }} error{% endif %}</span>
          </div>
          <div class="panel-body">
            <div style="font-family:var(--serif);font-size:14px;color:var(--ink-2);margin-bottom:14px;line-height:1.5">
              {% if _ok_count > 0 %}
                Queued for parsing. Typical parse completes in 30-90 seconds per document. Parse status lands on the merchant detail page.
              {% elif _dup_count > 0 %}
                These statements were already uploaded (matched by SHA-256). No new parse queued.
              {% endif %}
            </div>
            <div class="form-actions">
              {% if merchant_just_uploaded %}
                <a class="btn primary" href="/ui/merchants/{{ merchant_just_uploaded.id }}">View {{ merchant_just_uploaded.business_name }}</a>
                <a class="btn" href="/ui/merchants/{{ merchant_just_uploaded.id }}/match">Match funders →</a>
              {% else %}
                <a class="btn primary" href="/ui/deals">View deals</a>
              {% endif %}
              <a class="btn ghost" href="/ui/upload">Upload more</a>
              {% if _err_count > 0 %}
                <span class="chip bad" style="margin-left:auto">{{ _err_count }} file{{ '' if _err_count == 1 else 's' }} failed — see below</span>
              {% endif %}
            </div>
          </div>
        </div>
      {% endif %}

      <header class="sect-head" style="margin-top:28px">
        <h2>Upload results</h2>
        <div class="rule"></div>
        <div class="meta">{{ results|length }} file{{ '' if results|length == 1 else 's' }}</div>
      </header>
      <table class="queue">
        <thead>
          <tr>
            <th>File</th>
            <th>Status</th>
            <th>Detail</th>
            <th>Document</th>
          </tr>
        </thead>
        <tbody>
          {% for r in results %}
            <tr class="no-click">
              <td class="mono-cell">{{ r.filename }}</td>
              <td>
                {% if r.status == 'ok' %}
                  {% set tone = "good" %}{% set label = "OK" %}
                {% elif r.status == 'duplicate' %}
                  {% set tone = "warn" %}{% set label = "DUPLICATE" %}
                {% else %}
                  {% set tone = "bad" %}{% set label = "ERROR" %}
                {% endif %}
                {% include "_status_chip.html.j2" %}
              </td>
              <td class="flags">{{ r.detail }}</td>
              <td class="mono-cell">{% if r.document_id %}{{ r.document_id[:8] }}…{% else %}—{% endif %}</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    {% endif %}
  </div>
</section>
{% endblock %}
