<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% block title %}AEGIS{% endblock %}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/ui/static/aegis.css">
  <script src="https://unpkg.com/htmx.org@2.0.4" defer></script>
  <style>
    html, body { margin: 0; padding: 0; height: 100%; }
    body { background: var(--paper); }
  </style>
</head>
<body>
<div class="aegis">
  <div class="topbar">
    <div class="brand">
      <span class="brand-mark"></span>
      AEGIS
    </div>
    <nav class="nav">
      {% set _active = active|default('') %}
      <a href="/ui/"          class="{% if _active == 'Today' %}active{% endif %}">Today</a>
      <a href="/ui/intake"    class="{% if _active == 'Intake' %}active{% endif %}">Intake</a>
      <a href="/ui/upload"    class="{% if _active == 'Upload' %}active{% endif %}">Upload</a>
      <a href="/ui/deals"     class="{% if _active == 'Deals' %}active{% endif %}">Deals</a>
      <a href="/ui/merchants" class="{% if _active == 'Merchants' %}active{% endif %}">Merchants</a>
      <a href="/ui/funders"   class="{% if _active == 'Funders' %}active{% endif %}">Funders</a>
      <a href="/ui/review"    class="{% if _active == 'Review' %}active{% endif %}">Review</a>
    </nav>
    <div class="topbar-right">
      <div class="search">
        <span>Search merchants, deals, EINs…</span>
        <span class="kbd">⌘K</span>
      </div>
      {% if queue_count is defined %}
        <div class="topbar-btn">Queue · {{ queue_count }}</div>
      {% endif %}
      <div class="topbar-btn">
        <span class="avatar">{{ operator_initials|default('FK') }}</span>
        {{ operator_handle|default('fk2204') }}
      </div>
    </div>
  </div>

  {% block subhead %}{% endblock %}

  {% block body %}
    {# Default: single-column content area. Pages that want side rails
       override this block entirely. #}
    <div class="body cols-1">
      <main class="main">
        {% block content %}{% endblock %}
      </main>
    </div>
  {% endblock %}

  <div class="statusbar">
    <span class="live">LIVE</span>
    <span>node: aegis-prod</span>
    <span class="sep">·</span>
    <span>parser v{{ parser_version|default('4.2.1') }}</span>
    <span class="sep">·</span>
    <span>queue depth {{ queue_count|default(0) }}</span>
    <span style="margin-left:auto">{{ now|default('') }}</span>
  </div>
</div>
</body>
</html>
