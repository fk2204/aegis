{# Base template — dossier-tool chrome (cream paper, Fraunces +
   JetBrains Mono, compact topstrip nav). All operator pages extend
   this; merchant_detail_dossier.html.j2 deliberately does NOT extend
   (it's self-contained for editorial purity on the deal detail view).

   Blocks pages override:
     - title    : <title> contents
     - deck     : page title + actions row (.deck wrapper)
     - body     : main content area (no default wrapper — pages choose)
     - ribbon   : bottom strip (no default content; pages may inject one)

   Variables provided by the route's index handler (Today):
     - now, queue_count, parser_version, operator_handle/initials —
     all optional, statusbar falls back to safe defaults.
#}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% block title %}AEGIS{% endblock %}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Poppins:wght@600;700;800&display=swap" rel="stylesheet">
  {# UI redesign Wave 1 (2026-06-03) — aegis-system.css loaded FIRST so
     dossier + tool inherit canonical tokens. Token-definition block
     moved out of aegis-dossier.css into system; computed values
     identical. v queries bumped to bust browser cache after the move. #}
  <link rel="stylesheet" href="/ui/static/aegis-system.css?v=1">
  <link rel="stylesheet" href="/ui/static/aegis-dossier.css?v=11">
  <link rel="stylesheet" href="/ui/static/aegis-tool.css?v=14">
  <script src="https://unpkg.com/htmx.org@2.0.4" defer></script>
  <script src="/ui/static/evidence_copy.js?v=1" defer></script>
</head>
<body class="dossier-page body-root">

{# === compact topstrip — same chrome as the merchant dossier ===
   Wave 1: nav-active highlight moved from inline style
   `style="color:#fff;font-weight:600"` to `class="is-active"`
   (rule in aegis-system.css). Same computed result for the active
   link; existing render for inactive links unchanged. #}
<div class="topstrip">
  <div class="links">
    {% set _active = active|default('') %}
    <a href="/ui/"          {% if _active == 'Today'     %}class="is-active"{% endif %}>Today</a>
    <a href="/ui/deals"     {% if _active == 'Deals'     %}class="is-active"{% endif %}>Deals</a>
    <a href="/ui/merchants" {% if _active == 'Merchants' %}class="is-active"{% endif %}>Merchants</a>
    <a href="/ui/funders"   {% if _active == 'Funders'   %}class="is-active"{% endif %}>Funders</a>
    <a href="/ui/upload"    {% if _active == 'Upload'    %}class="is-active"{% endif %}>Upload</a>
    <a href="/ui/intake"    {% if _active == 'Intake'    %}class="is-active"{% endif %}>Intake</a>
    <a href="/ui/review"    {% if _active == 'Review'    %}class="is-active"{% endif %}>Review queue</a>
  </div>
  <div class="view-toggle">
    <span style="color:var(--sage)">aegis · {{ now|default('') }}</span>
  </div>
</div>

{% block deck %}{% endblock %}

{% block body %}{% endblock %}

{% block ribbon %}{% endblock %}

<div class="statusbar">
  <span class="live">LIVE</span>
  <span>node · aegis-prod</span>
  <span class="sep">·</span>
  <span>parser v{{ parser_version|default('4.2.1') }}</span>
  <span class="sep">·</span>
  <span>queue depth {{ queue_count|default(0) }}</span>
  <span class="spacer"></span>
  <span>{{ now|default('') }}</span>
</div>

</body>
</html>
