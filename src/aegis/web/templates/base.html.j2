<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% block title %}AEGIS{% endblock %}</title>
  <script src="https://unpkg.com/htmx.org@2.0.4" defer></script>
  <style>
    body { font-family: -apple-system, system-ui, sans-serif; margin: 0; color: #111; }
    nav { background: #1a1a2e; color: #fff; padding: 12px 24px; display: flex; gap: 24px; }
    nav a { color: #fff; text-decoration: none; font-weight: 500; }
    nav a:hover { text-decoration: underline; }
    main { padding: 24px; max-width: 1100px; margin: 0 auto; }
    h1 { margin-top: 0; }
    table { width: 100%; border-collapse: collapse; margin: 16px 0; }
    th, td { text-align: left; padding: 8px 12px; border-bottom: 1px solid #eaeaea; font-size: 14px; }
    th { background: #f6f6f6; font-weight: 600; }
    .tile { display: inline-block; min-width: 180px; padding: 16px; border: 1px solid #e0e0e0;
            border-radius: 8px; margin: 8px 8px 8px 0; vertical-align: top; }
    .tile-label { font-size: 12px; text-transform: uppercase; color: #666; letter-spacing: 0.06em; }
    .tile-value { font-size: 24px; font-weight: 700; margin-top: 4px; }
    .tile button { margin-top: 8px; padding: 4px 10px; font-size: 12px; cursor: pointer;
                   background: #1a1a2e; color: #fff; border: none; border-radius: 4px; }
    .tag { display: inline-block; padding: 2px 8px; border-radius: 4px; font-size: 11px;
           font-weight: 600; text-transform: uppercase; }
    .tag-proceed { background: #d6f4d6; color: #1c5e1c; }
    .tag-review { background: #fff4cc; color: #8a6800; }
    .tag-manual_review, .tag-error { background: #fad7d7; color: #8a1c1c; }
    .src-ref { color: #666; font-size: 12px; }
  </style>
</head>
<body>
  <nav>
    <a href="/ui/">AEGIS</a>
    <a href="/ui/upload">Upload</a>
    <a href="/ui/merchants">Merchants</a>
  </nav>
  <main>
    {% block content %}{% endblock %}
  </main>
</body>
</html>
