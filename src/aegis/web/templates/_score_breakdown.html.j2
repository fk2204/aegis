{# Score-breakdown panel.

  Inputs:
    - score_result: ScoreResult | None
#}
{% if score_result is none %}
  <div style="padding:16px;color:var(--muted);font-size:12px">
    Score unavailable — analysis missing or scoring failed.
  </div>
{% else %}
  {% set _tier_cls = {
      'A': 'pos',
      'B': 'accent',
      'C': 'warn',
      'D': 'warn',
      'F': 'neg',
  } %}
  {% set _rec_cls = {
      'approve': 'pos',
      'refer':   'warn',
      'decline': 'neg',
  } %}

  <div style="display:flex;align-items:center;gap:14px;margin-bottom:14px">
    <span class="tag {{ _tier_cls.get(score_result.tier, '') }}" style="font-size:11.5px;padding:4px 10px">
      <span class="dot"></span>Tier {{ score_result.tier }}
    </span>
    <span style="font-family:var(--mono);font-size:18px;font-weight:500;font-variant-numeric:tabular-nums">
      {{ score_result.score }}<span style="color:var(--muted);font-size:13px"> / 100</span>
    </span>
    <span class="tag {{ _rec_cls.get(score_result.recommendation, '') }}">
      <span class="dot"></span>{{ score_result.recommendation }}
    </span>
  </div>

  {% if score_result.hard_decline_reasons %}
    <div class="panel-title" style="margin-bottom:6px;color:var(--neg)">Hard declines</div>
    {% for reason in score_result.hard_decline_reasons %}
      <div class="flag-row">
        <span class="flag-icon neg">!</span>
        <div><div class="flag-title">{{ reason }}</div></div>
      </div>
    {% endfor %}
  {% endif %}

  {% if score_result.breakdown %}
    <div class="panel-title" style="margin:14px 0 6px">Per-factor delta</div>
    <table class="data" style="max-width:520px">
      <thead>
        <tr><th>Factor</th><th class="num">Delta</th></tr>
      </thead>
      <tbody>
        {% for entry in score_result.breakdown %}
          <tr>
            <td>{{ entry.factor }}</td>
            <td class="num" style="color:{% if entry.delta > 0 %}var(--pos){% elif entry.delta < 0 %}var(--neg){% else %}var(--muted){% endif %};font-weight:500">
              {{ '+' if entry.delta > 0 }}{{ entry.delta }}
            </td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  {% endif %}

  {% if score_result.soft_concerns %}
    <div class="panel-title" style="margin:14px 0 6px;color:var(--warn)">Soft concerns</div>
    {% for concern in score_result.soft_concerns %}
      <div class="flag-row">
        <span class="flag-icon warn">?</span>
        <div><div class="flag-title">{{ concern }}</div></div>
      </div>
    {% endfor %}
  {% endif %}

  <div class="kv" style="margin-top:14px">
    <span class="k">Suggested max</span>
    <span class="v">${{ score_result.suggested_max_advance }}</span>
    <span class="k">Factor</span>
    <span class="v">{{ score_result.recommended_factor_rate }}</span>
    <span class="k">Holdback</span>
    <span class="v">{{ score_result.recommended_holdback_pct }}</span>
    {% if score_result.estimated_payback_days %}
      <span class="k">Payback</span>
      <span class="v">~{{ score_result.estimated_payback_days }} days</span>
    {% endif %}
  </div>
{% endif %}
