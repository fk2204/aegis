{# Score-breakdown panel.

  Inputs:
    - score_result: ScoreResult | None
#}
{% if score_result is none %}
  <p class="src-ref">Score unavailable — analysis missing or scoring failed.</p>
{% else %}
  <div class="score-summary">
    <span class="score-tier score-tier-{{ score_result.tier }}">Tier {{ score_result.tier }}</span>
    <span class="score-value">{{ score_result.score }}/100</span>
    <span class="score-rec score-rec-{{ score_result.recommendation }}">
      {{ score_result.recommendation }}
    </span>
  </div>

  {% if score_result.hard_decline_reasons %}
    <h4>Hard declines</h4>
    <ul class="hard-decline">
      {% for reason in score_result.hard_decline_reasons %}
        <li>{{ reason }}</li>
      {% endfor %}
    </ul>
  {% endif %}

  {% if score_result.breakdown %}
    <h4>Per-factor delta</h4>
    <table class="score-breakdown">
      <thead>
        <tr><th>Factor</th><th style="text-align: right;">Delta</th></tr>
      </thead>
      <tbody>
        {% for entry in score_result.breakdown %}
          <tr>
            <td>{{ entry.factor }}</td>
            <td style="text-align: right;
                       color: {% if entry.delta > 0 %}#1c5e1c{% elif entry.delta < 0 %}#8a1c1c{% else %}#555{% endif %};">
              {{ '+' if entry.delta > 0 }}{{ entry.delta }}
            </td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  {% endif %}

  {% if score_result.soft_concerns %}
    <h4>Soft concerns</h4>
    <ul class="soft-concerns">
      {% for concern in score_result.soft_concerns %}
        <li>{{ concern }}</li>
      {% endfor %}
    </ul>
  {% endif %}

  <p class="src-ref">
    Suggested max advance: {{ score_result.suggested_max_advance }}
    · Factor {{ score_result.recommended_factor_rate }}
    · Holdback {{ score_result.recommended_holdback_pct }}
    {% if score_result.estimated_payback_days %}
      · Payback ~{{ score_result.estimated_payback_days }} days
    {% endif %}
  </p>
{% endif %}

<style>
  .score-summary { margin: 8px 0; display: flex; align-items: center; gap: 12px; }
  .score-tier { padding: 4px 12px; border-radius: 4px; font-weight: 700; font-size: 16px; }
  .score-tier-A { background: #d6f4d6; color: #1c5e1c; }
  .score-tier-B { background: #d8e8f6; color: #1c4a7a; }
  .score-tier-C { background: #fff4cc; color: #8a6800; }
  .score-tier-D { background: #ffe0c2; color: #8a4a00; }
  .score-tier-F { background: #fad7d7; color: #8a1c1c; }
  .score-value { font-size: 18px; font-weight: 600; }
  .score-rec { padding: 2px 10px; border-radius: 4px; font-size: 12px; text-transform: uppercase; font-weight: 600; }
  .score-rec-approve { background: #d6f4d6; color: #1c5e1c; }
  .score-rec-refer { background: #fff4cc; color: #8a6800; }
  .score-rec-decline { background: #fad7d7; color: #8a1c1c; }
  .hard-decline li { color: #8a1c1c; }
  .soft-concerns li { color: #8a6800; }
  table.score-breakdown { max-width: 480px; }
  table.score-breakdown td, table.score-breakdown th { font-size: 13px; }
</style>
