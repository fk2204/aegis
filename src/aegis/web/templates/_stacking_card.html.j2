{# Stacking summary card.

  Inputs:
    - stacking: StackingCard | None  (None hides the card entirely)
#}
{% if stacking is not none %}
  <div class="kpi-row" style="border-color:color-mix(in oklch, var(--neg) 30%, var(--line));margin-bottom:12px">
    <div class="kpi">
      <div class="label">Daily MCA burden</div>
      <div class="value">${{ stacking.daily_total }}</div>
    </div>
    <div class="kpi">
      <div class="label">Monthly projection</div>
      <div class="value">${{ stacking.monthly_burden }}</div>
      <div class="delta">× 22 business days</div>
    </div>
    <div class="kpi">
      <div class="label">Active positions</div>
      <div class="value">{{ stacking.position_count }}</div>
    </div>
    <div class="kpi">
      <div class="label">MCA debits found</div>
      <div class="value">{{ stacking.debit_count }}</div>
    </div>
    <div class="kpi">
      <div class="label">Risk</div>
      <div class="value" style="color:var(--neg);font-size:18px">stacked</div>
    </div>
  </div>

  {% if stacking.debits %}
    <details>
      <summary style="cursor:pointer;font-family:var(--mono);font-size:11px;color:var(--muted);padding:8px 14px;border-top:1px solid var(--line-2)">
        {{ stacking.debits|length }} contributing debit row(s) — click to expand
      </summary>
      <table class="data">
        <thead>
          <tr>
            <th>Date</th>
            <th>Lender (best-effort)</th>
            <th class="num">Amount</th>
            <th>Source</th>
          </tr>
        </thead>
        <tbody>
          {% for d in stacking.debits %}
            <tr>
              <td><span class="mono" style="font-size:11.5px">{{ d.posted_date }}</span></td>
              <td>{{ d.lender_label }}</td>
              <td class="num">${{ d.amount }}</td>
              <td><span class="mono" style="font-size:10.5px;color:var(--muted)">p{{ d.source_page }} L{{ d.source_line }}</span></td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </details>
  {% endif %}
{% endif %}
