{#
  Shared compact topstrip — simplified 2026-06-29 from 6 grouped dropdowns
  to 4 main items + a settings gear dropdown for admin surfaces.

  Main nav (left): Today, Deals, Funders, Upload — the four surfaces an
  underwriter touches per deal. Pipeline / Bank coverage / Calibration /
  Overrides / Probe review move into a ⚙ dropdown on the right next to
  the notification bell.

  Extracted from base.html.j2 in Wave 2.4 (2026-06-03) so the dossier
  (which intentionally does NOT extend base) can include the same nav
  row instead of hand-maintaining its own copy.

  The active link is styled via `class="is-active"` (rule in
  aegis-system.css); inactive links render unchanged. Routes pass an
  ``active`` value as the IA group name (e.g. "Deals" highlights the
  Deals link even from /ui/review).

  Inputs (all optional):
    active — one of "Today" | "Deals" | "Funders" | "Upload" |
             "Pipeline" | "Admin"; the matching main-nav or settings
             item gets `class="is-active"`. Pages that do not highlight
             any nav (e.g. the dossier) simply omit `active`.

             Child→group mapping the route handlers still use; some
             groups (Portfolio, Funders dropdown children) no longer
             have a dedicated nav slot — that's intentional. The
             routes are reachable from Today / deep links / the
             settings menu; they don't need permanent nav real estate.

    now    — display string for the right-hand view-toggle span. Same
             default convention as base.html.j2 (falls back to '').
#}
<div class="topstrip">
  <div class="links">
    {% set _active = active|default('') %}
    <a href="/ui/" {% if _active == 'Today' %}class="is-active"{% endif %}>Today</a>
    <a href="/ui/merchants" {% if _active == 'Deals' %}class="is-active"{% endif %}>Deals</a>
    <a href="/ui/funders" {% if _active == 'Funders' %}class="is-active"{% endif %}>Funders</a>
    <a href="/ui/upload" {% if _active == 'Upload' %}class="is-active"{% endif %}>Upload</a>
  </div>
  <div class="view-toggle">
    {# Operator identity + role chip. Populated by the /ui router-level
       ``Depends(current_operator)`` which stashes the resolved Operator
       on request.state.operator. Silent when the dependency hasn't run
       (e.g. plain ``_base.html.j2`` smoke tests). #}
    {% set _op = request.state.operator if request and request.state and request.state.operator is defined else None %}
    {% if _op %}
      {% include "_notifications_bell.html.j2" %}
      <div class="settings-dropdown">
        <button type="button"
                class="settings-trigger"
                aria-haspopup="true"
                aria-label="Settings"
                title="Settings">⚙</button>
        <div class="settings-menu" role="menu">
          <a href="/ui/pipeline" role="menuitem" data-test-id="settings-pipeline">Pipeline view</a>
          <a href="/ui/portfolio" role="menuitem" data-test-id="settings-portfolio">Portfolio</a>
          <a href="/ui/bank-coverage" role="menuitem" data-test-id="settings-bank-coverage">Bank coverage</a>
          <a href="/ui/calibration" role="menuitem" data-test-id="settings-calibration">Calibration</a>
          <a href="/ui/overrides/summary" role="menuitem" data-test-id="settings-overrides">Overrides</a>
          <a href="/ui/close-queue" role="menuitem" data-test-id="settings-close-queue">Close queue</a>
          <a href="/ui/disclosure-events" role="menuitem" data-test-id="settings-disclosure-events">Disclosure events</a>
          <a href="/ui/admin/text-layer-probe-review" role="menuitem" data-test-id="settings-probe-review">Probe review</a>
        </div>
      </div>
      {% set _name_parts = (_op.display_name or '').split() %}
      {% set _initials = ((_name_parts[0][0] if _name_parts else '') ~ (_name_parts[-1][0] if _name_parts|length > 1 else (_name_parts[0][1] if _name_parts and _name_parts[0]|length > 1 else '')))|upper %}
      <span class="op-avatar op-avatar--{{ _op.role }}"
            title="{{ _op.display_name }} · {{ _op.role }} · {{ _op.email }}"
            data-test-id="op-avatar">{{ _initials or '?' }}</span>
    {% endif %}
    <span style="color:var(--sage)">aegis · {{ now|default('') }}</span>
  </div>
</div>
