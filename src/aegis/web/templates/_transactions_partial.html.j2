<div class="panel" style="margin-top:0">
  <div class="panel-head">
    <span class="panel-title">{{ aggregate_label }} — contributing transactions</span>
    <span class="panel-actions mono">{{ transactions|length }} row{{ '' if transactions|length == 1 else 's' }}</span>
  </div>
  <div class="panel-body flush">
    {% if not transactions %}
      <div style="padding:16px;color:var(--muted);font-size:12px">No transactions contributed to this aggregate.</div>
    {% else %}
      <table class="data">
        <thead>
          <tr>
            <th>Date</th>
            <th>Description</th>
            <th class="num">Amount</th>
            <th class="num">Balance</th>
            <th>Category</th>
            <th>Source</th>
          </tr>
        </thead>
        <tbody>
          {% for t in transactions|sort(attribute='posted_date') %}
          <tr>
            <td><span class="mono" style="font-size:11.5px">{{ t.posted_date }}</span></td>
            <td>{{ t.description }}</td>
            <td class="num">{{ t.amount }}</td>
            <td class="num">{{ t.running_balance or "" }}</td>
            <td><span class="tag"><span class="dot"></span>{{ t.category }}</span></td>
            <td><span class="mono" style="font-size:10.5px;color:var(--muted)" title="page {{ t.source_page }}, line {{ t.source_line }}">page {{ t.source_page }}, line {{ t.source_line }}</span></td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    {% endif %}
  </div>
</div>
