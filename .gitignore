# Secrets — never commit. Three layers of coverage:
#   - .env             (literal repo-root file)
#   - .env.*           (anything starting with .env., e.g. .env.local)
#   - *.env            (anything ending in .env, e.g. aegis.env if the
#                       operator copies the Hetzner /etc/aegis/aegis.env
#                       file into the repo by mistake)
# Example files (.env.example, deploy/aegis.env.example) end in
# .example so the *.env rule does not match them; the explicit
# negation below keeps .env.example committable.
.env
.env.*
*.env
!.env.example
!*.env.example

# Operator-only PowerShell helpers with hardcoded tokens (bearer, Cloudflare
# tunnel). These live on the operator box and are never in version control.
install-cloudflare-tunnel.ps1
upload-statements.ps1
upload-statements-*.ps1

# Cloudflare API + connector tokens — operator-only, never in version control.
# Pattern catches scratch files an operator might create to stash a token
# (cf-token.txt, CF_TOKEN.env, .cf_token, cloudflare-token.txt, etc.).
cf-token*
CF_TOKEN*
.cf_token*
cloudflare-token*
*.cf-token

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
*.egg-info/
build/
dist/

# Test / type / lint caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/
.coverage
htmlcov/

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Claude Code: track config (CLAUDE.md, settings.json, rules) but exclude session artifacts
.claude/worktrees/
.claude/settings.local.json
.claude/cache/
.claude/projects/
.claude/sessions/
.claude/file-history/
.claude/shell-snapshots/
.claude/tasks/
.claude/todos/
.claude/plans/
.claude/debug/
.claude/paste-cache/
.claude/image-cache/
.claude/session-env/
.claude/telemetry/
.claude/ide/
.claude/backups/
.claude/.credentials.json
.claude/.last-cleanup
.claude/history.jsonl
.claude/mcp-needs-auth-cache.json
.claude/stats-cache.json
.claude/.benchmarks/

# App-local
.tmp/
logs/
*.log

# Cohort backtest reports (scripts/cohort_backtest.py). The JSON output
# is operator-side inspection, never committed.
reports/

# Node (we don't use it but listed per spec)
node_modules/
.tmp/

CLAUDE.local.md
