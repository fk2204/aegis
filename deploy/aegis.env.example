# /etc/aegis/aegis.env — AEGIS production environment file.
#
# Copy to /etc/aegis/aegis.env on the box and populate. NEVER commit a
# populated copy. systemd loads this file via EnvironmentFile= in both
# aegis-web.service and aegis-worker.service.
#
# Source of truth for AEGIS-side vars: src/aegis/config.py (Settings
# class). Pydantic env names are the lowercase-underscore form of the
# Python attribute; the case-insensitive lookup means UPPERCASE here
# is what systemd EnvironmentFile expects.
#
# 22 AEGIS vars + 1 systemd-side override (UV_CACHE_DIR, not in
# Settings — set here so the systemd units inherit a writable cache
# path under ProtectHome=true; see the section near the end).

# ---------------------------------------------------------------------------
# Data residency (REQUIRED — boot guard refuses to start without this)
# ---------------------------------------------------------------------------
# Acknowledges that AEGIS routes bank statements through US-only
# infrastructure. The boot guard in config.get_settings() raises
# DataResidencyError if this is anything other than literal "true".
AEGIS_DATA_RESIDENCY_CONFIRMED=true

# ---------------------------------------------------------------------------
# AWS Bedrock (REQUIRED for parser pipeline)
# ---------------------------------------------------------------------------
# Region the Bedrock client targets. Must be a US region.
AWS_REGION=us-east-1

# IAM credentials for the bedrock-only user. Optional here — if absent,
# boto3 falls back to its standard credential chain (instance profile,
# ~/.aws/credentials, etc.). On Hetzner there is no instance profile, so
# populate these.
AWS_ACCESS_KEY_ID=<your-aegis-bedrock-access-key>
AWS_SECRET_ACCESS_KEY=<your-aegis-bedrock-secret-key>

# Bedrock model ID. The boot guard ENFORCES the "us." prefix (regional
# inference profile) — bank statements must NEVER transit non-US regions.
# The default below is the production model; uncomment only if pinning a
# different US-regional model.
# BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6

# ---------------------------------------------------------------------------
# Supabase / Postgres (REQUIRED when AEGIS_STORAGE_BACKEND=supabase)
# ---------------------------------------------------------------------------
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_SERVICE_KEY=<your-supabase-service-role-key>

# ---------------------------------------------------------------------------
# API auth (REQUIRED — every non-/healthz route checks this token)
# ---------------------------------------------------------------------------
# 32 bytes hex is fine; rotate per RUNBOOK "Rotate the API bearer token".
# Generate: openssl rand -hex 32
API_BEARER_TOKEN=<your-api-bearer-token>

# ---------------------------------------------------------------------------
# Redis / arq queue (REQUIRED for the worker; defaults to localhost)
# ---------------------------------------------------------------------------
# install.sh installs redis-server bound to loopback. Override only if
# Redis lives off-box (not the standard topology).
REDIS_URL=redis://127.0.0.1:6379

# ---------------------------------------------------------------------------
# Close CRM integration
# ---------------------------------------------------------------------------
# HTTP Basic auth: the API key is sent as the username, password blank.
# CLOSE_WEBHOOK_SECRET is the hex-encoded signature_key returned by Close
# when the subscription is created via POST /api/v1/webhook/.
CLOSE_API_KEY=<your-close-api-key>
CLOSE_WEBHOOK_SECRET=<your-close-webhook-signature-key-hex>

# ---------------------------------------------------------------------------
# Close → AEGIS callback router (/api/close-callback/*)
# ---------------------------------------------------------------------------
# CLOSE_CALLBACK_HMAC_SECRET — REQUIRED. Hex signature_key returned by Close
# when the second webhook subscription (the one pointing at
# /api/close-callback/*) is created via POST /api/v1/webhook/. Same shape
# as CLOSE_WEBHOOK_SECRET; distinct value so the two subscriptions rotate
# independently. Unset -> the callback router 503s fail-closed.
#
# CLOSE_CALLBACK_TOKEN — OPTIONAL bearer for defense in depth. When set,
# the router requires Authorization: Bearer <token> in ADDITION to the
# HMAC signature. When unset, the bearer check is skipped (HMAC alone
# protects). Engage only if you've confirmed Close webhook subscriptions
# can carry custom HTTP headers; otherwise leave unset. Generate in your
# OWN terminal (never via the AEGIS agent's chat or tool output):
#   openssl rand -hex 32
CLOSE_CALLBACK_HMAC_SECRET=<paste-close-callback-subscription-signature-key-hex>
# CLOSE_CALLBACK_TOKEN=<optional-operator-generated-bearer-hex>
# Default api.close.com — only override for a non-default Close base URL.
# CLOSE_API_BASE=https://api.close.com
# Default is the "Docs In — Pre-UW" status in the Commera Sales pipeline.
# Override only if that stage is renamed in Close.
# CLOSE_DOCS_IN_PRE_UW_STATUS_ID=stat_1YZuVqdPWC8HLjWWvnXqL3NBJUPSjw3upy9mdBYXRqI

# ---------------------------------------------------------------------------
# App tuning (OPTIONAL — defaults are production-sane)
# ---------------------------------------------------------------------------
# uvicorn bind port. Systemd unit defaults to 5555 explicitly via the
# uvicorn CLI; this env var is read by code paths that introspect the
# port (logs, dashboard banner). 1-65535.
# APP_PORT=5555

# Logger level (DEBUG / INFO / WARNING / ERROR / CRITICAL).
# LOG_LEVEL=INFO

# Storage backend. "supabase" = production Postgres via supabase-py;
# "memory" = in-process dict (tests + offline development only).
# AEGIS_STORAGE_BACKEND=supabase

# Where uploaded PDFs land before the worker picks them up. The worker
# deletes the file in a finally block — nothing here is long-lived.
# Override the default tmp path for box-specific layouts.
AEGIS_UPLOAD_DIR=/var/lib/aegis/uploads

# uv cache — NOT an AEGIS Settings field; this is a uv runtime env var
# that systemd inherits via EnvironmentFile=. Required because the
# systemd units run with ProtectHome=true (uv's default ~/.cache/uv
# becomes unreachable) and ProtectSystem=strict (only paths in
# ReadWritePaths are writable). install.sh creates this dir owned by
# the aegis user; the systemd units list /var/lib/aegis in
# ReadWritePaths. Caught during first live deploy on Hetzner CPX21 —
# without this default, both units crash-loop on cache init.
UV_CACHE_DIR=/var/lib/aegis/uv-cache

# Hard cap on uploaded PDF size, in bytes (default 25 MB).
# AEGIS_MAX_UPLOAD_BYTES=26214400

# Worker concurrency: max parallel parse_document jobs (1-32).
# AEGIS_WORKER_MAX_CONCURRENT=4

# Worker job timeout in seconds (>= 30; default tolerates LLM retries).
# AEGIS_WORKER_JOB_TIMEOUT=600

# ---------------------------------------------------------------------------
# Alerting (mp Phase 11 — OPTIONAL; unset = log-only, no external alerts)
# ---------------------------------------------------------------------------
# Three channels, each independently activatable. Unset = the alerting
# module logs the alert at INFO level + writes the audit_log row but
# never posts externally. This is the right behavior for offline
# development and the right safety net for prod: missing creds never
# crash the unit, only suppress one alerting channel.
#
# Healthchecks.io is a free hosted dead-man's-switch. Create one check
# per process (web + worker), copy the ping URL from the dashboard.
# AEGIS_HEALTHCHECK_WEB_URL=https://hc-ping.com/<web-check-uuid>
# AEGIS_HEALTHCHECK_WORKER_URL=https://hc-ping.com/<worker-check-uuid>
#
# ntfy.sh is a free hosted pub-sub. Pick a hard-to-guess topic name
# (the URL is the auth surface) and subscribe via the ntfy iOS/Android
# app or the web UI.
# AEGIS_NTFY_TOPIC_URL=https://ntfy.sh/aegis-commera-<random-suffix>

# ---------------------------------------------------------------------------
# Daily backup (mp Phase 11 task #4 — OPTIONAL but recommended for prod)
# ---------------------------------------------------------------------------
# Triggered by aegis-backup.{service,timer} at 02:00 UTC daily.
# Reads from the same /etc/aegis/aegis.env this file becomes on the box.
#
# Postgres DSN to dump (Supabase Settings → Database → Connection
# string → URI). Same shape as MIGRATIONS_DB_URL_PROD; reused so the
# operator only has to maintain one connection string.
# AEGIS_BACKUP_DB_URL=postgresql://postgres:...@db.<ref>.supabase.co:6543/postgres
#
# Destination: "s3" | "b2" | "local". Unset = dump locally only (not
# recommended for prod).
# AEGIS_BACKUP_DEST=s3
#
# S3 destination (when AEGIS_BACKUP_DEST=s3):
# AEGIS_BACKUP_S3_URL=s3://commera-aegis-backups/
#
# Backblaze B2 destination (when AEGIS_BACKUP_DEST=b2):
# AEGIS_BACKUP_B2_BUCKET=commera-aegis-backups
# AEGIS_BACKUP_B2_PREFIX=aegis
#
# How many days of LOCAL dumps to keep on the Hetzner box before GC.
# Off-box copies are kept by the destination's own retention policy.
# AEGIS_BACKUP_KEEP_LOCAL=7
