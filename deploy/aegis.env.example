# /etc/aegis/aegis.env — AEGIS production environment file.
#
# Copy to /etc/aegis/aegis.env on the box and populate. NEVER commit a
# populated copy. systemd loads this file via EnvironmentFile= in both
# aegis-web.service and aegis-worker.service.
#
# Source of truth for every variable below: src/aegis/config.py
# (Settings class). Pydantic env names are the lowercase-underscore form
# of the Python attribute; the case-insensitive lookup means UPPERCASE
# here is what systemd EnvironmentFile expects.
#
# 22 variables total. Required vs optional is called out per section.

# ---------------------------------------------------------------------------
# Data residency (REQUIRED — boot guard refuses to start without this)
# ---------------------------------------------------------------------------
# Acknowledges that AEGIS routes bank statements through US-only
# infrastructure. The boot guard in config.get_settings() raises
# DataResidencyError if this is anything other than literal "true".
AEGIS_DATA_RESIDENCY_CONFIRMED=true

# ---------------------------------------------------------------------------
# AWS Bedrock (REQUIRED for parser pipeline)
# ---------------------------------------------------------------------------
# Region the Bedrock client targets. Must be a US region.
AWS_REGION=us-east-1

# IAM credentials for the bedrock-only user. Optional here — if absent,
# boto3 falls back to its standard credential chain (instance profile,
# ~/.aws/credentials, etc.). On Hetzner there is no instance profile, so
# populate these.
AWS_ACCESS_KEY_ID=<your-aegis-bedrock-access-key>
AWS_SECRET_ACCESS_KEY=<your-aegis-bedrock-secret-key>

# Bedrock model ID. The boot guard ENFORCES the "us." prefix (regional
# inference profile) — bank statements must NEVER transit non-US regions.
# The default below is the production model; uncomment only if pinning a
# different US-regional model.
# BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6

# ---------------------------------------------------------------------------
# Supabase / Postgres (REQUIRED when AEGIS_STORAGE_BACKEND=supabase)
# ---------------------------------------------------------------------------
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_SERVICE_KEY=<your-supabase-service-role-key>

# ---------------------------------------------------------------------------
# API auth (REQUIRED — every non-/healthz route checks this token)
# ---------------------------------------------------------------------------
# 32 bytes hex is fine; rotate per RUNBOOK "Rotate the API bearer token".
# Generate: openssl rand -hex 32
API_BEARER_TOKEN=<your-api-bearer-token>

# ---------------------------------------------------------------------------
# Redis / arq queue (REQUIRED for the worker; defaults to localhost)
# ---------------------------------------------------------------------------
# install.sh installs redis-server bound to loopback. Override only if
# Redis lives off-box (not the standard topology).
REDIS_URL=redis://127.0.0.1:6379

# ---------------------------------------------------------------------------
# Zoho CRM integration (OPTIONAL — Phase 5 feature; leave blank to disable)
# ---------------------------------------------------------------------------
# When all four are populated, AEGIS syncs deal state to the Commera Zoho
# CRM and accepts inbound webhooks. Empty values disable the integration
# without breaking the boot guard.
ZOHO_CLIENT_ID=<your-zoho-client-id>
ZOHO_CLIENT_SECRET=<your-zoho-client-secret>
ZOHO_REFRESH_TOKEN=<your-zoho-refresh-token>
ZOHO_WEBHOOK_SECRET=<your-zoho-webhook-shared-secret>
# Zoho host bases — defaults match the US data center; uncomment + edit
# only for EU / India / China data center deployments.
# ZOHO_ACCOUNTS_BASE=https://accounts.zoho.com
# ZOHO_API_BASE=https://www.zohoapis.com

# ---------------------------------------------------------------------------
# App tuning (OPTIONAL — defaults are production-sane)
# ---------------------------------------------------------------------------
# uvicorn bind port. Systemd unit defaults to 5555 explicitly via the
# uvicorn CLI; this env var is read by code paths that introspect the
# port (logs, dashboard banner). 1-65535.
# APP_PORT=5555

# Logger level (DEBUG / INFO / WARNING / ERROR / CRITICAL).
# LOG_LEVEL=INFO

# Storage backend. "supabase" = production Postgres via supabase-py;
# "memory" = in-process dict (tests + offline development only).
# AEGIS_STORAGE_BACKEND=supabase

# Where uploaded PDFs land before the worker picks them up. The worker
# deletes the file in a finally block — nothing here is long-lived.
# Override the default tmp path for box-specific layouts.
AEGIS_UPLOAD_DIR=/var/lib/aegis/uploads

# Hard cap on uploaded PDF size, in bytes (default 25 MB).
# AEGIS_MAX_UPLOAD_BYTES=26214400

# Worker concurrency: max parallel parse_document jobs (1-32).
# AEGIS_WORKER_MAX_CONCURRENT=4

# Worker job timeout in seconds (>= 30; default tolerates LLM retries).
# AEGIS_WORKER_JOB_TIMEOUT=600
